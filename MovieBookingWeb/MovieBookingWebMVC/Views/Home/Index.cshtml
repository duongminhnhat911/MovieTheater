}
@functions {
    public string GetEmbedUrl(string trailerUrl)
    {
        if (string.IsNullOrEmpty(trailerUrl)) return "";
        string videoId = trailerUrl.Contains("watch?v=")
            ? trailerUrl.Split("watch?v=")[1].Split('&')[0]
            : trailerUrl.Split('/').Last();

        return $"https://www.youtube.com/embed/{videoId}?autoplay=1&mute=1&loop=1&playlist={videoId}&controls=0&showinfo=0&rel=0";
    }
}
