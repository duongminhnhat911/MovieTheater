<!-- Merged layout.cshtml with color variables and theme from File 1, logic from File 2 -->
<!-- DOCTYPE,  directives, layout logic, header & footer logic remain from File 2 -->
<!-- Added :root CSS variables and body background from File 1 -->
@{
    var isAdmin = User?.Identity?.IsAuthenticated == true && User.IsInRole("Admin");
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var showAdminSidebar = isAdmin && new[] { "Admin", "Movie", "User", "AdminShowtime", "AdminRoom" }.Contains(currentController);
    var showUserSidebar = User?.Identity?.IsAuthenticated == true && currentController == "Account" && currentAction == "Profile";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

    <style>
        :root {
            --primary-red: #DC2626;
            --primary-gold: #F59E0B;
            --dark-bg: #0F172A;
            --dark-card: #1E293B;
            --dark-accent: #334155;
            --text-primary: #F8FAFC;
            --text-secondary: #CBD5E1;
            --accent-blue: #3B82F6;
            --accent-purple: #8B5CF6;
            --gradient-primary: linear-gradient(135deg, var(--primary-red), var(--primary-gold));
            --gradient-dark: linear-gradient(135deg, var(--dark-bg), var(--dark-card));
            --shadow-glow: 0 20px 40px rgba(220, 38, 38, 0.3);
        }

        body {
            font-family: 'Inter', sans-serif !important;
            background: linear-gradient(135deg, #2193b0 0%, #6dd5ed 100%);
            color: var(--text-primary);
            line-height: 1.6;
            overflow: auto;
        }

        main {
            padding-bottom: 2rem;
        }

        footer {
            margin: 0 !important;
        }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body>
    <div class="wrapper d-flex flex-column min-vh-100">
        <header>
            <nav class="navbar navbar-expand-lg website-navbar px-3">
                <div class="container-fluid h-100">
                    <div class="d-flex align-items-center">
                        <a class="navbar-brand text-white d-flex align-items-center" href="/">
                            <img src="~/images/Logo.png" alt="CineMax Logo" style="height: 50px;" />

                        </a>
                    </div>
<button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                        <i class="fas fa-bars text-white"></i>
                    </button>

                    <div class="collapse navbar-collapse" id="mainNavbar">
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-1">
                            <li class="nav-item mx-2">
                                <a class="nav-link" href="/">
                                    Trang chủ
                                </a>
                            </li>
                            <li class="nav-item mx-2">
                                <a class="nav-link" href="#">
                                    Lịch chiếu
                                </a>
                            </li>
                            <li class="nav-item mx-2">
                                <a class="nav-link" href="#">
                                    Phim
                                </a>
                            </li>
                            <li class="nav-item mx-2">
                                <a class="nav-link" href="#">
                                    Khuyến mãi
                                </a>
                            </li>
                        </ul>
                    </div>

                    <div class="d-flex align-items-center">
                        <form class="d-flex me-3" role="search">
                            <div class="position-relative">
                                <input class="form-control form-control-sm me-2" type="search" aria-label="Search" style="padding-left: 35px;">
                            </div>
                            <button class="btn btn-outline-light btn-sm" type="submit" style="margin-left: 10px;">
                                <i class="fas fa-search me-1"></i>Tìm
                            </button>
                        </form>

                        @if (User?.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <div class="dropdown"  style="position: relative;">
                                <a class="d-flex align-items-center text-decoration-none dropdown-toggle" href="#" id="accountDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                    <img src="/images/default-avatar.jpg" alt="Avatar" id="dropdownAvatar" class="rounded-circle me-2" style="width: 36px; height: 36px; object-fit: cover;">
<span class="fw-semibold" id="dropdown-username">@User.Identity.Name</span>
                                    <i class="fas fa-chevron-down ms-2 opacity-75" style="font-size: 0.8rem;"></i>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" aria-labelledby="accountDropdown" style="min-width: 240px;">
                                    <li>
                                        <div class="px-3 pb-2 border-bottom" style="border-color: rgba(220, 38, 38, 0.2) !important;">
                                            <small style="color: white;">Xin chào</small><br />
                                            <strong style="color: var(--text-primary);">@User.Identity.Name</strong>
                                        </div>
                                    </li>
                                    <li>
                                        <a asp-area="User" asp-controller="Account" asp-action="Profile" class="dropdown-item">
                                            <i class="bi bi-person me-2"></i> Thông tin tài khoản
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="User" asp-controller="Account" asp-action="ChangePassword">
                                            <i class="bi bi-key me-2"></i> Đổi mật khẩu
                                        </a>
                                    </li>
                                                                     
                                    @if (User.IsInRole("User"))
                                    {
                                    <li>
                                        <a class="dropdown-item" href="#">
                                            <i class="fas fa-ticket-alt me-2"></i> Lịch sử đặt vé
                                        </a>
                                    </li>
                                    }
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a class="dropdown-item" asp-area="Movie" asp-controller="Movie" asp-action="ViewMovie">
                                                <i class="bi bi-person-gear me-2"></i> Trang quản trị
                                            </a>
                                        </li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form method="post" asp-area="User" asp-controller="Account" asp-action="Logout" class="mb-0">
                                            <button class="dropdown-item text-danger" type="submit">
                                                <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a asp-area="User" asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-sm me-2">
                                <i class="fas fa-sign-in-alt me-1"></i>Đăng nhập
                            </a>
                            <a asp-area="User" asp-controller="Account" asp-action="Register" class="btn btn-light btn-sm">
                                <i class="fas fa-user-plus me-1"></i>Đăng ký
                            </a>
                        }
                    </div>
                </div>
            </nav>
        </header>

        @if (showAdminSidebar)
        {
            <div class="d-flex flex-grow-1">
                <aside class="sidebar">
                    <nav class="nav flex-column">
                        <h5 class="text-secondary mb-3 ms-1">Trang quản trị (Admin)</h5>
                        <a class="nav-link d-flex align-items-center gap-2 text-dark ms-1 hover-effect
     @(currentController == "Admin" && currentAction == "ViewMovie" ? "active" : "")"
                           asp-area="Movie" asp-controller="Movie" asp-action="ViewMovie">
                            <i class="fas fa-film"></i> 
                            <span>Danh sách phim</span>
                        </a>

                        <a class="nav-link d-flex align-items-center gap-2 text-dark ms-1 hover-effect
    @(currentController == "AdminRoom" && currentAction == "Index" ? "active" : "")"
                           asp-area="Booking" asp-controller="AdminRoom" asp-action="Index">
                            <i class="fas fa-door-open"></i> Danh sách phòng chiếu
                        </a>

                        <a class="nav-link d-flex align-items-center gap-2 text-dark ms-1 hover-effect
                            @(currentController == "Admin" && currentAction == "ViewPromotions" ? "active" : "")"
                           href="#">
                            <i class="fas fa-gift"></i> 
                            <span>Danh sách khuyến mãi</span>
                        </a>
                        <a class="nav-link d-flex align-items-center gap-2 text-dark ms-1 hover-effect
                            @(currentController == "Admin" && currentAction == "ViewEmployee" ? "active" : "")"
                           href="#">
                            <i class="fas fa-user-tie"></i> Danh sách nhân viên
                        </a>
                        <a class="nav-link d-flex align-items-center gap-2 text-dark ms-1 hover-effect
    @(currentController == "Admin" && currentAction == "ViewAccounts" ? "active" : "")"
                           asp-area="User"
                           asp-controller="Admin"
                           asp-action="ViewAccounts">
                            <i class="fas fa-user"></i> Danh sách thành viên
                        </a>

                        <a class="nav-link sidebar-link d-flex align-items-center gap-2" href="#">
                            <i class="fas fa-chart-bar"></i> 
                            <span>Thống kê & Báo cáo</span>
                        </a>
                    </nav>
                </aside>
                <main role="main" class="main-content">
                    @RenderBody()
                </main>
            </div>
        }
        else if (showUserSidebar)
        {
            <div class="d-flex flex-grow-1">
                <aside class="sidebar">
                    <nav class="nav flex-column">
                        <h5 class="mb-3">
                            <i class="fas fa-user-circle me-2"></i>Tài khoản cá nhân
                        </h5>
                        <a class="nav-link sidebar-link d-flex align-items-center gap-2 @(currentController == "Account" && currentAction == "Profile" ? "active" : "")" 
                           href="/Account/Profile">
                            <i class="fa-solid fa-user"></i> 
                            <span>Thông tin cá nhân</span>
                        </a>
                        
                        @if (User!.IsInRole("User"))
                        {
                            <a class="nav-link sidebar-link d-flex align-items-center gap-2 @(currentController == "Account" && currentAction == "BookingHistory" ? "active" : "")" 
                               href="#">
                                <i class="fas fa-history"></i> 
                                <span>Lịch sử đặt vé</span>
                            </a>
                            
                            <a class="nav-link sidebar-link d-flex align-items-center gap-2" href="#">
                                <i class="fas fa-gift"></i> 
                                <span>Ưu đãi & Điểm thưởng</span>
                            </a>
                        }
                    </nav>
                </aside>
                <main role="main" class="main-content">
                    @RenderBody()
                </main>
            </div>
        }
        else
        {
            <main role="main" class="main-content">
                @RenderBody()
            </main>
        }

        <footer class="footer">
            <div class="container">
<div class="row">
                    <div class="col-md-3 mb-4">
                        <h5 class="text-uppercase">
                            <i class="fas fa-film me-2"></i>Movie Booking Web
                        </h5>
                        <ul class="list-unstyled">
                            <li><a href="/about" class="footer-link"><span>Về chúng tôi</span> <i class="fas fa-external-link-alt"></i></a></li>
                            <li><a href="/contact" class="footer-link"><span>Liên hệ</span> <i class="fas fa-external-link-alt"></i></a></li>
                            <li><a href="/careers" class="footer-link"><span>Cơ hội nghề nghiệp</span> <i class="fas fa-external-link-alt"></i></a></li>
                            <li><a href="/news" class="footer-link"><span>Tin tức</span> <i class="fas fa-external-link-alt"></i></a></li>
                        </ul>
                    </div>

                    <div class="col-md-3 mb-4">
                        <h5 class="text-uppercase">
                            <i class="fas fa-concierge-bell me-2"></i>Dịch vụ
                        </h5>
                        <ul class="list-unstyled">
                            <li><a href="/movies" class="footer-link"><span>Phim đang chiếu</span> <i class="fas fa-external-link-alt"></i></a></li>
                            <li><a href="/showtimes" class="footer-link"><span>Lịch chiếu</span> <i class="fas fa-external-link-alt"></i></a></li>
                            <li><a href="/booking" class="footer-link"><span>Đặt vé online</span> <i class="fas fa-external-link-alt"></i></a></li>
                            <li><a href="/promotions" class="footer-link"><span>Khuyến mãi</span> <i class="fas fa-external-link-alt"></i></a></li>
                            <li><a href="/membership" class="footer-link"><span>Thành viên VIP</span> <i class="fas fa-external-link-alt"></i></a></li>
                        </ul>
                    </div>

                    <div class="col-md-3 mb-4">
                        <h5 class="text-uppercase">
                            <i class="fas fa-shield-alt me-2"></i>Chính sách
                        </h5>
                        <ul class="list-unstyled">
                            <li><a href="/terms-conditions" class="footer-link"><span>Điều khoản chung</span> <i class="fas fa-external-link-alt"></i></a></li>
                            <li><a href="/terms-use" class="footer-link"><span>Điều khoản giao dịch</span> <i class="fas fa-external-link-alt"></i></a></li>
                            <li><a href="/payment-policy" class="footer-link"><span>Chính sách thanh toán</span> <i class="fas fa-external-link-alt"></i></a></li>
<li><a href="/privacy-policy" class="footer-link"><span>Bảo mật thông tin</span> <i class="fas fa-external-link-alt"></i></a></li>
                            <li><a href="/faq" class="footer-link"><span>Câu hỏi thường gặp</span> <i class="fas fa-external-link-alt"></i></a></li>
                        </ul>
                    </div>

                    <div class="col-md-3 mb-4">
                        <h5 class="text-uppercase">
                            <i class="fas fa-share-alt me-2"></i>Kết nối với chúng tôi
                        </h5>
                        <ul class="list-inline">
                            <li class="list-inline-item">
                                <a href="https://facebook.com" target="_blank" title="Facebook">
                                    <i class="fab fa-facebook"></i>
                                </a>
                            </li>
                            <li class="list-inline-item">
                                <a href="https://twitter.com" target="_blank" title="Twitter">
                                    <i class="fab fa-twitter"></i>
                                </a>
                            </li>
                            <li class="list-inline-item">
                                <a href="https://instagram.com" target="_blank" title="Instagram">
                                    <i class="fab fa-instagram"></i>
                                </a>
                            </li>
                            <li class="list-inline-item">
                                <a href="https://youtube.com" target="_blank" title="YouTube">
                                    <i class="fab fa-youtube"></i>
                                </a>
                            </li>
                        </ul>
                    </div>
</div>

                <hr class="my-4" />

                <div class="row align-items-center">
                    <div class="col-md-6">
                        <p class="mb-0" style="color: white">
                            &copy; 2025 MovieBookingWeb. Tất cả quyền được bảo lưu.
                        </p>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <div class="d-flex justify-content-md-end align-items-center">
                            <span class="me-1" style="color: white">Được phát triển bởi</span>
                            <span style="color: var(--primary-red); font-weight: 600;">MovieBookingWeb Team</span>
                        </div>
                    </div>
                </div>
            </div>
        </footer>
    </div>

    @RenderSection("Scripts", required: false)
    <script src="~/js/site.js"></script>
    <script src="~/js/alerts.js"></script>
</body>
</html>
