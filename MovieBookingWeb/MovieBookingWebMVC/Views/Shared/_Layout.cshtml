@{
    var isAdmin = User?.Identity?.IsAuthenticated == true && User.IsInRole("Admin");
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    // Điều kiện hiển thị sidebar cho Admin (bao gồm các controller quản trị như Admin, Movie, User)
    var showAdminSidebar = isAdmin && new[] { "Admin", "Movie", "User", "AdminShowtime", "AdminRoom", "AdminPromotion" }.Contains(currentController);

    // Điều kiện hiển thị sidebar cho người dùng, chỉ khi ở trang "Profile"
    var showUserSidebar = User?.Identity?.IsAuthenticated == true
                          && currentController == "Account"
                          && currentAction == "Profile";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

    <style>
        :root {
            --primary-red: #DC2626;
            --primary-gold: #F59E0B;
            --dark-bg: #0F172A;
            --dark-card: #1E293B;
            --dark-accent: #334155;
            --text-primary: #F8FAFC;
            --text-secondary: #CBD5E1;
            --accent-blue: #3B82F6;
            --accent-purple: #8B5CF6;
            --gradient-primary: linear-gradient(135deg, var(--primary-red), var(--primary-gold));
            --gradient-dark: linear-gradient(135deg, var(--dark-bg), var(--dark-card));
            --shadow-glow: 0 20px 40px rgba(220, 38, 38, 0.3);
        }

        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif !important;
            background: linear-gradient(135deg, #2193b0 0%, #6dd5ed 100%);
            color: var(--text-primary);
            line-height: 1.6;
            overflow: auto;
        }

        .wrapper {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Enhanced Header Navbar */
        .website-navbar {
            background: var(--gradient-dark) !important;
            border-bottom: 1px solid rgba(220, 38, 38, 0.2);
            backdrop-filter: blur(20px);
            padding: 0.3rem 0;
            transition: all 0.3s ease;
        }

        .navbar-brand {
            font-size: 1.8rem;
            font-weight: 800;
            background: var(--gradient-primary);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-decoration: none;
        }

            .navbar-brand img {
                filter: drop-shadow(0 0 10px rgba(220, 38, 38, 0.3));
                transition: all 0.3s ease;
            }

            .navbar-brand:hover img {
                transform: scale(1.05);
                filter: drop-shadow(0 0 15px rgba(220, 38, 38, 0.5));
            }

        .nav-link {
            color: var(--text-secondary) !important;
            font-weight: 500;
            transition: all 0.3s ease;
            position: relative;
            padding: 0.5rem 1rem !important;
            border-radius: 8px;
        }

            .nav-link::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 50%;
                width: 0;
                height: 2px;
                background: var(--gradient-primary);
                transition: all 0.3s ease;
                transform: translateX(-50%);
            }

            .nav-link:hover::after {
                width: 80%;
            }

        /* Enhanced Search Form */
        .form-control {
            background: rgba(30, 41, 59, 0.8) !important;
            border: 1px solid rgba(220, 38, 38, 0.3) !important;
            border-radius: 25px !important;
            color: var(--text-primary) !important;
            padding: 8px 16px !important;
        }

            .form-control:focus {
                border-color: var(--primary-red) !important;
                box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.1) !important;
                background: rgba(30, 41, 59, 0.9) !important;
            }

            .form-control::placeholder {
                color: var(--text-secondary) !important;
            }

        .btn-outline-light {
            border: 1px solid var(--primary-red) !important;
            color: var(--primary-red) !important;
            border-radius: 25px !important;
            padding: 8px 16px !important;
            font-weight: 600;
            transition: all 0.3s ease;
        }

            .btn-outline-light:hover {
                background: var(--gradient-primary) !important;
                border-color: var(--primary-red) !important;
                color: white !important;
                transform: translateY(-1px);
                box-shadow: 0 4px 15px rgba(220, 38, 38, 0.3);
            }

        .btn-light {
            background: var(--gradient-primary) !important;
            border: none !important;
            color: white !important;
            border-radius: 25px !important;
            padding: 8px 16px !important;
            font-weight: 600;
            transition: all 0.3s ease;
        }

            .btn-light:hover {
                transform: translateY(-1px);
                box-shadow: 0 4px 15px rgba(220, 38, 38, 0.4);
                color: white !important;
            }

        /* Enhanced Dropdown */
        .dropdown-toggle {
            display: flex;
            align-items: center;
            color: var(--text-primary) !important;
            text-decoration: none;
            padding: 8px 12px;
            border-radius: 50px;
            transition: all 0.3s ease;
        }

            .dropdown-toggle:hover {
                background: rgba(220, 38, 38, 0.1);
                color: var(--text-primary) !important;
            }

            .dropdown-toggle::after {
                display: none;
            }

        #dropdownAvatar {
            border: 2px solid transparent;
            background: linear-gradient(white, white) padding-box, var(--gradient-primary) border-box;
            transition: all 0.3s ease;
        }

        .dropdown-toggle:hover #dropdownAvatar {
            transform: scale(1.1);
            box-shadow: 0 0 20px rgba(220, 38, 38, 0.3);
        }

        .dropdown-menu {
            background: var(--dark-card) !important;
            border: 1px solid rgba(220, 38, 38, 0.2) !important;
            border-radius: 15px !important;
            backdrop-filter: blur(20px);
            padding: 0.3rem 0;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
            position: absolute;
        }

        .dropdown-item {
            color: var(--text-secondary) !important;
            padding: 8px 15px !important;
            transition: all 0.3s ease;
            border-radius: 8px;
        }

            .dropdown-item:hover {
                background: rgba(220, 38, 38, 0.1) !important;
                color: var(--text-primary) !important;
            }

        .header, .navbar, .container {
            overflow: visible !important;
            position: relative !important;
            z-index: 1000;
        }

        .text-danger {
            font-size: 1rem;
        }

        .dropdown-item.text-danger {
            color: #EF4444 !important;
        }

            .dropdown-item.text-danger:hover {
                background: rgba(239, 68, 68, 0.1) !important;
                color: #EF4444 !important;
            }

        .dropdown-divider {
            border-color: rgba(220, 38, 38, 0.2) !important;
            margin: 2px 16px !important;
        }

        /* Enhanced Sidebar */
        .sidebar {
            background: var(--dark-card) !important;
            border-right: 1px solid rgba(220, 38, 38, 0.2) !important;
            width: 300px;
            min-height: calc(100vh - 80px);
            padding: 2rem 1.5rem;
            box-shadow: 4px 0 15px rgba(0, 0, 0, 0.1);
        }

            .sidebar h5 {
                color: var(--text-primary) !important;
                font-weight: 700;
                margin-bottom: 2rem;
                padding-bottom: 1rem;
                border-bottom: 2px solid rgba(220, 38, 38, 0.2);
                background: var(--gradient-primary);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

        .nav-link.sidebar-link {
            color: var(--text-secondary) !important;
            padding: 12px 16px !important;
            border-radius: 12px !important;
            margin-bottom: 8px;
            transition: all 0.3s ease;
            border: 1px solid transparent;
            font-weight: 500;
        }

            .nav-link.sidebar-link:hover {
                background: rgba(220, 38, 38, 0.1) !important;
                color: var(--text-primary) !important;
                border-color: rgba(220, 38, 38, 0.3);
                transform: translateX(5px);
            }

            .nav-link.sidebar-link.active {
                background: var(--gradient-primary) !important;
                color: white !important;
                box-shadow: 0 4px 15px rgba(220, 38, 38, 0.3);
                transform: translateX(5px);
            }

            .nav-link.sidebar-link i {
                width: 20px;
                text-align: center;
                font-size: 1.1rem;
            }

        /* Main Content Area */
        .main-content {
            flex: 1;
            background: linear-gradient(135deg, #2193b0 0%, #6dd5ed 100%);
            min-height: calc(100vh - 80px);
        }

        /* Enhanced Footer */
        .footer {
            background: var(--dark-card) !important;
            border-top: 1px solid rgba(220, 38, 38, 0.2);
            padding: 1.5rem 0 1rem 0;
            margin-top: auto;
        }

            .footer h5 {
                color: var(--text-primary) !important;
                font-weight: 700;
                background: var(--gradient-primary);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

        .footer-link {
            color: var(--text-secondary) !important;
            text-decoration: none;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 4px 0;
        }

            .footer-link:hover {
                color: var(--primary-red) !important;
                transform: translateX(5px);
            }

            .footer-link i {
                font-size: 0.7rem;
                opacity: 0.7;
                transition: all 0.3s ease;
            }

            .footer-link:hover i {
                opacity: 1;
                transform: translateX(2px);
            }

        .list-inline-item a {
            color: var(--text-secondary) !important;
            font-size: 1.5rem;
            transition: all 0.3s ease;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 50px;
            height: 50px;
            text-decoration: none !important;
        }

        .list-inline-item:not(:last-child) {
            margin-right: 0;
        }

        .footer hr {
            border-color: white !important;
            margin: 1rem 0 1rem 0 !important;
        }

        .footer .text-center p {
            color: white !important;
            font-size: 0.9rem;
        }

        /* Animation and Effects */
        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .sidebar, .main-content {
            animation: fadeInUp 0.6s ease-out;
        }

        /* Scrollbar Styling */
        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: var(--dark-bg);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--gradient-primary);
            border-radius: 4px;
        }

            ::-webkit-scrollbar-thumb:hover {
                background: linear-gradient(135deg, #B91C1C, #D97706);
            }

        /* Loading States */
        .loading {
            opacity: 0;
            transform: translateY(20px);
            animation: fadeInUp 0.6s ease-out forwards;
        }
    </style>

    @RenderSection("Styles", required: false)
</head>

<body>
    <div class="wrapper d-flex flex-column min-vh-100">
        <header>
            <nav class="navbar navbar-expand-lg website-navbar px-3">
                <div class="container-fluid h-100">
                    <div class="d-flex align-items-center">
                        <a class="navbar-brand text-white d-flex align-items-center" href="/">
                            <img src="~/images/Logo.png" alt="CineMax Logo" style="height: 50px;" />

                        </a>
                    </div>
                    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                        <i class="fas fa-bars text-white"></i>
                    </button>

                    <div class="collapse navbar-collapse" id="mainNavbar">
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-1">
                            <li class="nav-item mx-2">
                                <a class="nav-link" href="/">
                                    Trang chủ
                                </a>
                            </li>
                            <li>
                                <a class="nav-link text-white"
                                   asp-area="Booking"
                                   asp-controller="Booking"
                                   asp-action="MoviesByDate">
                                    Lịch chiếu
                                </a>
                            </li>
                            @* <li class="nav-item mx-2">
                                <a class="nav-link" href="#">
                                    Phim
                                </a>
                            </li> *@
                            <li class="nav-item mx-2">
                                <a class="nav-link" href="#">
                                    Khuyến mãi
                                </a>
                            </li>
                        </ul>
                    </div>

                    <div class="d-flex align-items-center">
                        <form class="d-flex me-3" role="search">
                            <div class="position-relative">
                                <input class="form-control form-control-sm me-2" type="search" aria-label="Search" style="padding-left: 35px;">
                            </div>
                            <button class="btn btn-outline-light btn-sm" type="submit" style="margin-left: 10px;">
                                <i class="fas fa-search me-1"></i>Tìm
                            </button>
                        </form>

                        @if (User?.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <div class="dropdown" style="position: relative;">
                                <a class="d-flex align-items-center text-decoration-none dropdown-toggle" href="#" id="accountDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                    <img src="/images/default-avatar.jpg" alt="Avatar" id="dropdownAvatar" class="rounded-circle me-2" style="width: 36px; height: 36px; object-fit: cover;">
                                    <span class="fw-semibold" id="dropdown-username">@User.Identity.Name</span>
                                    <i class="fas fa-chevron-down ms-2 opacity-75" style="font-size: 0.8rem;"></i>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" aria-labelledby="accountDropdown" style="min-width: 240px;">
                                    <li>
                                        <div class="px-3 pb-2 border-bottom" style="border-color: rgba(220, 38, 38, 0.2) !important;">
                                            <small style="color: white;">Xin chào</small><br />
                                            <strong style="color: var(--text-primary);">@User.Identity.Name</strong>
                                        </div>
                                    </li>
                                    <li>
                                        <a asp-area="User" asp-controller="Account" asp-action="Profile" class="dropdown-item">
                                            <i class="bi bi-person me-2"></i> Thông tin tài khoản
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="User" asp-controller="Account" asp-action="ChangePassword">
                                            <i class="bi bi-key me-2"></i> Đổi mật khẩu
                                        </a>
                                    </li>

                                    @if (User.IsInRole("User"))
                                    {
                                        <li>
                                            <a class="dropdown-item" href="#">
                                                <i class="fas fa-ticket-alt me-2"></i> Lịch sử đặt vé
                                            </a>
                                        </li>
                                    }
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a class="dropdown-item" asp-area="Movie" asp-controller="Movie" asp-action="ViewMovie">
                                                <i class="bi bi-person-gear me-2"></i> Trang quản trị
                                            </a>
                                        </li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form method="post" asp-area="User" asp-controller="Account" asp-action="Logout" class="mb-0">
                                            <button class="dropdown-item text-danger" type="submit">
                                                <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a asp-area="User" asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-sm me-2">
                                <i class="fas fa-sign-in-alt me-1"></i>Đăng nhập
                            </a>
                            <a asp-area="User" asp-controller="Account" asp-action="Register" class="btn btn-light btn-sm">
                                <i class="fas fa-user-plus me-1"></i>Đăng ký
                            </a>
                        }
                    </div>
                </div>
            </nav>
        </header>

        @if (showAdminSidebar)
        {
            <div class="d-flex flex-grow-1">
                <aside class="sidebar">
                    <nav class="nav flex-column">
                        <h5 class="mb-3">
                            <i class="fas fa-crown me-2"></i>Trang quản trị
                        </h5>
                        <a class="nav-link sidebar-link d-flex align-items-center gap-2 @(currentController == "Admin" && currentAction == "ViewMovie" ? "active" : "")"
                           asp-area="Movie" asp-controller="Movie" asp-action="ViewMovie">
                            <i class="fas fa-film"></i>
                            <span>Danh sách phim</span>
                        </a>
                        <a class="nav-link sidebar-link d-flex align-items-center gap-2 @(currentController == "AdminShowtime" && currentAction == "Index" ? "active" : "")"
                           asp-area="Booking" asp-controller="AdminShowtime" asp-action="Index">
                            <i class="fas fa-clock"></i> <span>Quản lý suất chiếu</span>
                        </a>
                        <a class="nav-link sidebar-link d-flex align-items-center gap-2 @(currentController == "AdminRoom" && currentAction == "Index" ? "active" : "")"
                           asp-area="Booking" asp-controller="AdminRoom" asp-action="Index">
                            <i class="fas fa-door-open"></i> <span>Danh sách phòng chiếu</span>
                        </a>
                        <a class="nav-link sidebar-link d-flex align-items-center gap-2 @(currentController == "AdminPromotion" && currentAction == "ListPromotions" ? "active" : "")"
                           asp-area="Booking" asp-controller="AdminPromotion" asp-action="ListPromotions">
                            <i class="fas fa-gift"></i>
                            <span>Danh sách khuyến mãi</span>
                        </a>
                        <a class="nav-link sidebar-link d-flex align-items-center gap-2 @(currentController == "Admin" && currentAction == "ViewAccounts" ? "active" : "")"
                           asp-area="User" asp-controller="Admin" asp-action="ViewAccounts">
                            <i class="fas fa-users"></i>
                            <span>Danh sách thành viên</span>
                        </a>

                        <a class="nav-link sidebar-link d-flex align-items-center gap-2" href="#">
                            <i class="fas fa-chart-bar"></i>
                            <span>Thống kê & Báo cáo</span>
                        </a>
                    </nav>
                </aside>
                <main role="main" class="main-content">
                    @RenderBody()
                </main>
            </div>
        }
        else if (showUserSidebar)
        {
            <div class="d-flex flex-grow-1">
                <aside class="sidebar">
                    <nav class="nav flex-column">
                        <h5 class="mb-3">
                            <i class="fas fa-user-circle me-2"></i>Tài khoản cá nhân
                        </h5>
                        <a class="nav-link sidebar-link d-flex align-items-center gap-2 @(currentController == "Account" && currentAction == "Profile" ? "active" : "")"
                           href="/Account/Profile">
                            <i class="fa-solid fa-user"></i>
                            <span>Thông tin cá nhân</span>
                        </a>

                        @if (User!.IsInRole("User"))
                        {
                            <a class="nav-link sidebar-link d-flex align-items-center gap-2 @(currentController == "Account" && currentAction == "BookingHistory" ? "active" : "")"
                               href="#">
                                <i class="fas fa-history"></i>
                                <span>Lịch sử đặt vé</span>
                            </a>

                            <a class="nav-link sidebar-link d-flex align-items-center gap-2" href="#">
                                <i class="fas fa-gift"></i>
                                <span>Ưu đãi & Điểm thưởng</span>
                            </a>
                        }
                    </nav>
                </aside>
                <main role="main" class="main-content">
                    @RenderBody()
                </main>
            </div>
        }
        else
        {
            <main role="main" class="main-content">
                @RenderBody()
            </main>
        }

        <footer class="footer">
            <div class="container-fluid" style="width: 1200px;">
                <div class="row">
                    <div class="col-md-3 mb-4">
                        <h5 class="text-uppercase">
                            <i class="fas fa-film me-2"></i>Movie Booking Web
                        </h5>
                        <ul class="list-unstyled">
                            <li><a href="/about" class="footer-link"><span>Về chúng tôi</span> <i class="fas fa-external-link-alt"></i></a></li>
                            <li><a href="/contact" class="footer-link"><span>Liên hệ</span> <i class="fas fa-external-link-alt"></i></a></li>
                            <li><a href="/careers" class="footer-link"><span>Cơ hội nghề nghiệp</span> <i class="fas fa-external-link-alt"></i></a></li>
                            <li><a href="/news" class="footer-link"><span>Tin tức</span> <i class="fas fa-external-link-alt"></i></a></li>
                        </ul>
                    </div>

                    <div class="col-md-3 mb-4">
                        <h5 class="text-uppercase">
                            <i class="fas fa-concierge-bell me-2"></i>Dịch vụ
                        </h5>
                        <ul class="list-unstyled">
                            <li><a href="/movies" class="footer-link"><span>Phim đang chiếu</span> <i class="fas fa-external-link-alt"></i></a></li>
                            <li><a href="/showtimes" class="footer-link"><span>Lịch chiếu</span> <i class="fas fa-external-link-alt"></i></a></li>
                            <li><a href="/booking" class="footer-link"><span>Đặt vé online</span> <i class="fas fa-external-link-alt"></i></a></li>
                            <li><a href="/promotions" class="footer-link"><span>Khuyến mãi</span> <i class="fas fa-external-link-alt"></i></a></li>
                            <li><a href="/membership" class="footer-link"><span>Thành viên VIP</span> <i class="fas fa-external-link-alt"></i></a></li>
                        </ul>
                    </div>

                    <div class="col-md-3 mb-4">
                        <h5 class="text-uppercase">
                            <i class="fas fa-shield-alt me-2"></i>Chính sách
                        </h5>
                        <ul class="list-unstyled">
                            <li><a href="/terms-conditions" class="footer-link"><span>Điều khoản chung</span> <i class="fas fa-external-link-alt"></i></a></li>
