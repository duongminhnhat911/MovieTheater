@{
    var isAdmin = User?.Identity?.IsAuthenticated == true && User.IsInRole("Admin");
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    // Điều kiện hiển thị sidebar cho Admin (bao gồm các controller quản trị như Admin, Movie, User)
    var showAdminSidebar = isAdmin && new[] { "Admin", "Movie", "User" }.Contains(currentController);

    // Điều kiện hiển thị sidebar cho người dùng, chỉ khi ở trang "Profile"
    var showUserSidebar = User?.Identity?.IsAuthenticated == true
                          && currentController == "Account"
                          && currentAction == "Profile";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    @RenderSection("Styles", required: false)
</head>

<style>
    body {
        font-family: 'Inter', sans-serif !important;
    }

    main {
        padding-bottom: 2rem;
    }

    footer {
        margin: 0 !important;
    }
</style>

<body>
    <div class="wrapper d-flex flex-column min-vh-100">
        <header>
            <nav class="navbar navbar-expand-lg website-navbar px-3">
                <div class="container-fluid h-100">
                    <div class="d-flex align-items-center">
                        <a class="navbar-brand text-white d-flex align-items-center" href="/">
                            <img src="~/images/Logo.png" alt="Logo" style="height: 50px;" />
                        </a>
                    </div>

                    <div class="collapse navbar-collapse" id="mainNavbar">
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-1">
                            <li class="nav-item mx-2"><a class="nav-link text-white" href="/">Trang chủ</a></li>
                            <li class="nav-item mx-2">
                                <a class="nav-link text-white"
                                   asp-area="Booking"
                                   asp-controller="Booking"
                                   asp-action="MoviesByDate">
                                    Lịch chiếu
                                </a>
                            </li>
                            <li class="nav-item mx-2"><a class="nav-link text-white" href="#">Phim</a></li>
                        </ul>
                    </div>

                    <div class="d-flex align-items-center">
                        <form class="d-flex me-3" role="search">
                            <input class="form-control form-control-sm me-2" type="search" placeholder="Tìm phim..." aria-label="Search">
                            <button class="btn btn-outline-light btn-sm" type="submit">Tìm</button>
                        </form>

                        @if (User?.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <div class="dropdown">
                                <a class="d-flex align-items-center text-decoration-none dropdown-toggle" href="#" id="accountDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                    <img src="/images/default-avatar.jpg" alt="Avatar" id="dropdownAvatar" class="rounded-circle me-2 shadow-sm" style="width: 36px; height: 36px; object-fit: cover;">
                                    <span class="fw-semibold text-white" id="dropdown-username">@User.Identity.Name</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2" aria-labelledby="avatarDropdown" style="min-width: 210px;">
                                    <li>
                                        <div class="px-3 py-2">
                                            <small class="text-muted">Tài khoản của bạn</small><br />
                                            <strong>@User.Identity.Name</strong>
                                        </div>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a asp-area="User" asp-controller="Account" asp-action="Profile" class="dropdown-item">
                                            <i class="bi bi-person"></i> Thông tin tài khoản
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item"
                                           asp-area="User"
                                           asp-controller="Account"
                                           asp-action="ChangePassword">
                                            <i class="bi bi-key"></i> Đổi mật khẩu
                                        </a>
                                    </li>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li>
                                            <a class="dropdown-item"
                                               asp-area="Movie"
                                               asp-controller="Movie"
                                               asp-action="ViewMovie">
                                                <i class="bi bi-person-gear"></i> Trang quản trị
                                            </a>
                                        </li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                    <li>
                                        <form method="post" asp-area="User" asp-controller="Account" asp-action="Logout" class="mb-0">
                                            <button class="dropdown-item text-danger" type="submit"><i class="bi bi-box-arrow-right"></i> Đăng xuất</button>
                                        </form>
                                    </li>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a asp-area="User" asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-sm me-2">Đăng nhập</a>
                            <a asp-area="User" asp-controller="Account" asp-action="Register" class="btn btn-light btn-sm text-dark">Đăng ký</a>
                        }
                    </div>
                </div>
            </nav>
        </header>

        @if (showAdminSidebar)
        {
            <div class="d-flex flex-grow-1">
                <aside class="bg-light border-end p-3" style="width: 300px;">
                    <nav class="nav flex-column">
                        <h5 class="text-secondary mb-3 ms-1">Trang quản trị (Admin)</h5>
                        <a class="nav-link d-flex align-items-center gap-2 text-dark ms-1 hover-effect
         @(currentController == "Admin" && currentAction == "ViewMovie" ? "active" : "")"
                           asp-area="Movie" asp-controller="Movie" asp-action="ViewMovie">
                            <i class="fas fa-film"></i> Danh sách phim
                        </a>

                        <a class="nav-link d-flex align-items-center gap-2 text-dark ms-1 hover-effect
        @(currentController == "AdminRoom" && currentAction == "Index" ? "active" : "")"
                           asp-area="Booking" asp-controller="AdminRoom" asp-action="Index">
                            <i class="fas fa-door-open"></i> Danh sách phòng chiếu
                        </a>

                        <a class="nav-link d-flex align-items-center gap-2 text-dark ms-1 hover-effect
                                @(currentController == "Admin" && currentAction == "ViewPromotions" ? "active" : "")"
                           href="#">
                            <i class="fas fa-gift"></i> Danh sách khuyến mãi
                        </a>
                        <a class="nav-link d-flex align-items-center gap-2 text-dark ms-1 hover-effect
                                @(currentController == "Admin" && currentAction == "ViewEmployee" ? "active" : "")"
                           href="#">
                            <i class="fas fa-user-tie"></i> Danh sách nhân viên
                        </a>
                        <a class="nav-link d-flex align-items-center gap-2 text-dark ms-1 hover-effect
        @(currentController == "Admin" && currentAction == "ViewAccounts" ? "active" : "")"
                           asp-area="User"
                           asp-controller="Admin"
                           asp-action="ViewAccounts">
                            <i class="fas fa-user"></i> Danh sách thành viên
                        </a>

                    </nav>
                </aside>
                <main role="main" class="flex-grow-1">
                    @RenderBody()
                </main>
            </div>
        }
        else if (showUserSidebar)
        {
            <div class="d-flex flex-grow-1">
                <aside class="bg-light border-end p-3" style="width: 300px;">
                    <nav class="nav flex-column">
                        <h5 class="text-secondary mb-3 ms-1">Tài khoản cá nhân</h5>
                        <a class="nav-link d-flex align-items-center gap-2 text-dark ms-1 hover-effect @(currentController == "Account" && currentAction == "Profile" ? "active" : "")" href="/Account/Profile">
                            <i class="fa-solid fa-user"></i> <span>Thông tin cá nhân</span>
                        </a>
                        @if (User!.IsInRole("User"))
                        {
                            <a class="nav-link d-flex align-items-center gap-2 text-dark ms-1 hover-effect @(currentController == "Account" && currentAction == "BookingHistory" ? "active" : "")" href="#">
                                <i class="fas fa-clock-rotate-left"></i> <span>Lịch sử đặt vé</span>
                            </a>
                            <a class="nav-link d-flex align-items-center gap-2 text-dark ms-1 hover-effect @(currentController == "Account" && currentAction == "BookingTickets" ? "active" : "")" href="#">
                                <i class="fas fa-ticket-alt"></i> <span>Vé đã đặt</span>
                            </a>
                            <a class="nav-link d-flex align-items-center gap-2 text-dark ms-1 hover-effect @(currentController == "Account" && currentAction == "CancelledTickets" ? "active" : "")" href="#">
                                <i class="fas fa-times-circle"></i> <span>Vé đã hủy</span>
                            </a>
                        }
                    </nav>
                </aside>
                <main role="main" class="flex-grow-1">
                    @RenderBody()
                </main>
            </div>
        }
        else
        {
            <main role="main" class="flex-grow-1">
                @RenderBody()
            </main>
        }

        <footer class="bg-dark text-white">
            <div class="container">
                <div class="row">
                    <div class="col-md-3">
                        <h5 class="text-uppercase">Movie Booking App</h5>
                        <ul class="list-unstyled">
                            <li><a href="/about" class="footer-link text-light"><span>Về chúng tôi</span> <i class="fas fa-up-right-from-square fa-xs"></i></a></li>
                            <li><a href="/contact" class="footer-link text-light"><span>Liên hệ</span> <i class="fas fa-up-right-from-square fa-xs"></i></a></li>
                            <li><a href="/careers" class="footer-link text-light"><span>Cơ hội nghề nghiệp</span> <i class="fas fa-up-right-from-square fa-xs"></i></a></li>
                            <li><a href="/news" class="footer-link text-light"><span>Tin tức</span> <i class="fas fa-up-right-from-square fa-xs"></i></a></li>
                        </ul>
                    </div>

                    <div class="col-md-3">
                        <h5 class="text-uppercase">Dịch vụ</h5>
                        <ul class="list-unstyled">
                            <li><a href="/movies" class="footer-link text-light"><span>Phim</span> <i class="fas fa-up-right-from-square fa-xs"></i></a></li>
                            <li><a href="/showtimes" class="footer-link text-light"><span>Lịch chiếu</span> <i class="fas fa-up-right-from-square fa-xs"></i></a></li>
                            <li><a href="/booking" class="footer-link text-light"><span>Đặt vé</span> <i class="fas fa-up-right-from-square fa-xs"></i></a></li>
                            <li><a href="/promotions" class="footer-link text-light"><span>Khuyến mãi</span> <i class="fas fa-up-right-from-square fa-xs"></i></a></li>
                        </ul>
                    </div>

                    <div class="col-md-3">
                        <h5 class="text-uppercase">Điều khoản sử dụng</h5>
                        <ul class="list-unstyled">
                            <li><a href="/terms-conditions" class="footer-link text-light"><span>Điều khoản chung</span> <i class="fas fa-up-right-from-square fa-xs"></i></a></li>
                            <li><a href="/terms-use" class="footer-link text-light"><span>Điều khoản giao dịch</span> <i class="fas fa-up-right-from-square fa-xs"></i></a></li>
                            <li><a href="/payment-policy" class="footer-link text-light"><span>Chính sách thanh toán</span> <i class="fas fa-up-right-from-square fa-xs"></i></a></li>
                            <li><a href="/privacy-policy" class="footer-link text-light"><span>Chính sách bảo mật</span> <i class="fas fa-up-right-from-square fa-xs"></i></a></li>
                            <li><a href="/faq" class="footer-link text-light"><span>Câu hỏi thường gặp</span> <i class="fas fa-up-right-from-square fa-xs"></i></a></li>
                        </ul>
                    </div>

                    <div class="col-md-3">
                        <h5 class="text-uppercase">Kết nối với chúng tôi</h5>
                        <ul class="list-inline">
                            <li class="list-inline-item">
                                <a href="https://facebook.com" class="text-light">
                                    <i class="fab fa-facebook fa-lg"></i>
                                </a>
                            </li>
                            <li class="list-inline-item">
                                <a href="https://twitter.com" class="text-light">
                                    <i class="fab fa-twitter fa-lg"></i>
                                </a>
                            </li>
                            <li class="list-inline-item">
                                <a href="https://instagram.com" class="text-light">
                                    <i class="fab fa-instagram fa-lg"></i>
                                </a>
                            </li>
                            <li class="list-inline-item">
                                <a href="https://youtube.com" class="text-light">
                                    <i class="fab fa-youtube fa-lg"></i>
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>

                <hr class="bg-light" />

                <div class="text-center">
                    <p class="mb-0 pt-1">&copy; 2025 Movie Booking App.</p>
                </div>
            </div>
        </footer>
    </div>
    @RenderSection("Scripts", required: false)
    <script src="~/js/site.js"></script>
    <script src="~/js/alerts.js"></script>
</body>

</html>
