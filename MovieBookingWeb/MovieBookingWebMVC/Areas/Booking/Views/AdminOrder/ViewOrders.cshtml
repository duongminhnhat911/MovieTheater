@using MovieBookingWebMVC.Areas.Booking.Models.ViewModel
@model List<OrderSummaryViewModel>

@{
    ViewData["Title"] = "Lịch sử đơn hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --primary-black: #000000;
        --mint-light: #CCFFE4;
        --teal-green: #9FCBC0;
        --light-gray: #F5F5F5;
        --white: #ffffff;
        --success-green: #28a745;
        --danger-red: #dc3545;
        --shadow-light: rgba(0, 0, 0, 0.1);
    }

    body {
        background: linear-gradient(135deg, #2193b0 0%, #6dd5ed 100%);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        min-height: 100vh;
    }

    .main-container {
        background: var(--white);
        border-radius: 20px;
        box-shadow: 0 10px 30px var(--shadow-light);
        margin: 2rem 1rem;
        max-width: 1400px;
        overflow: hidden;
    }

    .header-section {
        background: linear-gradient(135deg, var(--primary-black) 0%, #333333 100%);
        color: var(--white);
        padding: 2rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .header-section::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(204, 255, 228, 0.1) 0%, transparent 70%);
            animation: rotate 20s linear infinite;
        }

    @@keyframes rotate {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    .header-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin: 0;
        position: relative;
        z-index: 1;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    }

    .content-section {
        padding: 2rem;
        background: var(--mint-light);
        background-image: radial-gradient(circle at 20% 20%, rgba(159, 203, 192, 0.1) 0%, transparent 50%), radial-gradient(circle at 80% 80%, rgba(245, 245, 245, 0.2) 0%, transparent 50%);
    }

    .order-table {
        background: var(--white);
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 10px 30px var(--shadow-light);
        margin-top: 2rem;
    }

    .table-header th {
        background: var(--primary-black);
        color: var(--white);
        padding: 1.2rem 1rem;
        font-weight: 600;
        text-align: center;
        border: none;
        position: relative;
    }

        .table-header th::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            width: 0;
            height: 2px;
            background: var(--teal-green);
            transition: all 0.3s ease;
            transform: translateX(-50%);
        }

        .table-header th:hover::after {
            width: 80%;
        }

    .table tbody tr {
        transition: all 0.3s ease;
        border-bottom: 1px solid rgba(159, 203, 192, 0.2);
    }

        .table tbody tr:hover {
            background: linear-gradient(135deg, var(--mint-light) 0%, rgba(159, 203, 192, 0.1) 100%);
            transform: translateX(5px);
        }

    .table tbody td {
        padding: 1rem;
        vertical-align: middle;
        border: none;
        text-align: center;
    }

    .badge-status {
        padding: 0.3rem 0.8rem;
        border-radius: 15px;
        font-weight: 600;
        display: inline-block;
        font-size: 0.85rem;
    }

    .badge-active {
        background: linear-gradient(135deg, var(--success-green) 0%, #20c997 100%);
        color: var(--white);
    }

    .badge-inactive {
        background: linear-gradient(135deg, var(--danger-red) 0%, #e55353 100%);
        color: var(--white);
    }

    .showtime-id {
        background: linear-gradient(135deg, var(--primary-black) 0%, #333333 100%);
        color: var(--white);
        padding: 0.3rem 0.8rem;
        border-radius: 15px;
        font-weight: 700;
        font-size: 0.9rem;
        display: inline-block;
        min-width: 40px;
        text-align: center;
    }

    .movie-id-badge {
        background: linear-gradient(135deg, var(--teal-green) 0%, #7fb3d3 100%);
        color: var(--white);
        padding: 0.3rem 0.8rem;
        border-radius: 15px;
        font-weight: 600;
        font-size: 0.9rem;
        display: inline-block;
        min-width: 40px;
        text-align: center;
    }

    .movie-title {
        font-weight: 600;
        color: var(--primary-black);
        line-height: 1.4;
    }

    .room-badge {
        background: var(--light-gray);
        padding: 0.3rem 0.8rem;
        border-radius: 15px;
        font-weight: 600;
        color: var(--primary-black);
        display: inline-block;
        border: 2px solid var(--teal-green);
    }

    .show-date {
        font-family: 'Courier New', monospace;
        font-weight: 600;
        color: var(--primary-black);
        padding: 0.3rem 0.8rem;
        border-radius: 10px;
        display: inline-block;
    }

    .time-badge {
        background: linear-gradient(135deg, var(--success-green) 0%, #20c997 100%);
        color: var(--white);
        padding: 0.3rem 0.8rem;
        border-radius: 15px;
        font-weight: 600;
        font-size: 0.85rem;
        display: inline-block;
        min-width: 70px;
        text-align: center;
    }

    .status-badge-paid {
        background: linear-gradient(135deg, var(--success-green) 0%, #20c997 100%);
        color: var(--white);
        padding: 0.3rem 0.8rem;
        border-radius: 15px;
        font-weight: 600;
        font-size: 0.85rem;
        display: inline-block;
        min-width: 70px;
        text-align: center;
    }

    .status-badge-cancel {
        background: linear-gradient(135deg, var(--danger-red) 0%, #e74c3c 100%);
        color: var(--white);
        padding: 0.3rem 0.8rem;
        border-radius: 15px;
        font-weight: 600;
        font-size: 0.85rem;
        display: inline-block;
        min-width: 70px;
        text-align: center;
    }

    .btn-details {
        background: linear-gradient(135deg, var(--teal-green) 0%, #7fb3d3 100%);
        color: var(--white);
        border: none;
        border-radius: 20px;
        padding: 0.5rem 1rem;
        font-weight: 600;
        transition: all 0.3s;
    }

        .btn-details:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(159, 203, 192, 0.5);
            color: var(--white);
        }

    @@media (max-width: 768px) {
        .header-title {
            font-size: 2rem;
        }

        .table-responsive {
            font-size: 0.85rem;
        }
    }
</style>

<div class="main-container">
    <div class="header-section">
        <h1 class="header-title">
            <i class="fas fa-history me-2"></i>
            Lịch sử đơn hàng
        </h1>
    </div>

    <div class="content-section">
        @if (Model != null && Model.Count > 0)
        {
            <div class="order-table">
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead class="table-header">
                            <tr>
                                <th>ID</th>
                                <th>ID Người dùng</th>
                                <th>Ngày đặt</th>
                                <th>Thành tiền</th>
                                <th>Trạng thái</th>
                                <th>ID Khuyến mãi</th>
                                <th>Tác vụ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model)
                            {
                                <tr>
                                    <td class="text-center">
                                        <span class="showtime-id">@order.Id</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="movie-id-badge">@order.UserId</span>
                                    </td>
                                    <td>
                                        <div class="movie-title">@order.BookingDate.ToString("dd/MM/yyyy")</div>
                                    </td>
                                    <td class="text-center">
                                        <span class="room-badge">@order.TotalPrice.ToString("N0") đ</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="@(order.Status ? "status-badge-paid" : "status-badge-cancel")">
                                            @(order.Status ? "Có hiệu lực" : "Đã hủy")
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <span class="show-date">@(order.PromotionId.HasValue? order.PromotionId.ToString() : "Không có")</span>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn-details btn-sm" data-bs-toggle="modal" data-bs-target="#orderDetailModal" data-id="@order.Id">
                                            <i class="fas fa-eye"></i> Chi tiết
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-warning text-center fw-bold">
                <i class="fas fa-exclamation-circle me-2"></i>
                Không có đơn hàng nào được tìm thấy.
            </div>
        }
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="orderDetailModal" tabindex="-1" aria-labelledby="orderDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-dark">
                <h5 class="modal-title">Chi tiết đơn hàng</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body" id="orderDetailContent">
                <p>Đang tải...</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $('#orderDetailModal').on('show.bs.modal', function (e) {
            var button = $(e.relatedTarget);
            var orderId = button.data('id');
            $('#orderDetailContent').html("<p>Đang tải...</p>");
            $.ajax({
                url: `/Booking/AdminOrder/OrderDetailsPartial/${orderId}`,
                type: 'GET',
                success: function (data) {
                    $('#orderDetailContent').html(data);
                },
                error: function (xhr) {
                    $('#orderDetailContent').html(`<p class="text-danger">Lỗi: ${xhr.status} - ${xhr.statusText}</p>`);
                }
            });
        });
    </script>
}
