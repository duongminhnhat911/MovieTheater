@using MovieBookingWebMVC.Areas.Booking.Models.DTOs
@model List<RoomDto>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Danh sách phòng chiếu";
}

<h2 class="text-center fw-bold mb-4">@ViewData["Title"]</h2>

<a href="/Booking/AdminRoom/CreateRoom" class="btn btn-success mb-3">
    <i class="fas fa-plus-circle"></i> Thêm phòng mới
</a>

@if (Model != null && Model.Count > 0)
{
    <table class="table table-bordered table-hover text-center align-middle">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Tên phòng</th>
                <th>Số ghế</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var room in Model)
            {
                <tr>
                    <td>@room.Id</td>
                    <td class="text-start">@room.RoomName</td>
                    <td>@room.RoomQuantity</td>
                    <td>
                        @if (room.Status.ToString().ToLower() == "true")
                        {
                            <span class="badge bg-success">Đang hoạt động</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Đang bảo trì</span>
                        }
                    </td>
                    <td>
                        <a href="/Booking/AdminRoom/DetailsRoom/@room.Id" class="btn btn-info btn-sm me-1">
                            <i class="fas fa-eye"></i> Chi tiết
                        </a>

                        <a href="/Booking/AdminRoom/EditRoom/@room.Id" class="btn btn-warning btn-sm me-1">
                            <i class="fas fa-edit"></i> Sửa
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-warning text-center">Không có phòng chiếu nào được tìm thấy.</div>
}
