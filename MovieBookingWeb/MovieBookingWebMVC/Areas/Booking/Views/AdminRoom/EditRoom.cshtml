@model MovieBookingWebMVC.Areas.Booking.Models.ViewModel.UpdateRoomViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Chỉnh sửa phòng chiếu";
}

<div class="container mt-5 mb-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h2 class="mb-4 text-center"><i class="fas fa-edit me-2"></i>Chỉnh sửa phòng chiếu</h2>

            <form asp-action="EditRoom" method="post">
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.Id)

                <div class="mb-3">
                    <label asp-for="RoomName" class="form-label">Tên phòng</label>
                    @Html.TextBoxFor(m => m.RoomName, new { @class = "form-control", placeholder = "Nhập tên phòng" })
                    <span asp-validation-for="RoomName" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Rows" class="form-label">Số hàng</label>
                        @Html.TextBoxFor(m => m.Rows, new { @class = "form-control", type = "number", min = "1", placeholder = "Số hàng" })
                        <span asp-validation-for="Rows" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Columns" class="form-label">Số cột</label>
                        @Html.TextBoxFor(m => m.Columns, new { @class = "form-control", type = "number", min = "1", placeholder = "Số cột" })
                        <span asp-validation-for="Columns" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Status" class="form-label">Trạng thái</label>
                    @Html.DropDownListFor(m => m.Status, new SelectList(new[]
                             {
                    new { Value = "true", Text = "Đang hoạt động" },
                    new { Value = "false", Text = "Tạm ngưng" }
                    }, "Value", "Text", Model.Status.ToString().ToLower()),
                             new { @class = "form-select" })
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a href="/Booking/AdminRoom" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i> Quay lại
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i> Lưu thay đổi
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
