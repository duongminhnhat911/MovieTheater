@model MovieBookingWebMVC.Areas.Booking.Models.ViewModel.RoomDetailsViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Chi tiết phòng";
}

<div class="container mt-5 mb-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="fas fa-door-open me-2"></i>Chi tiết phòng chiếu</h4>
                </div>

                <div class="card-body">
                    <div class="row mb-3">
                        <label class="col-sm-4 fw-semibold">ID:</label>
                        <div class="col-sm-8">@Model.Id</div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 fw-semibold">Tên phòng:</label>
                        <div class="col-sm-8">@Model.RoomName</div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 fw-semibold">Số lượng ghế:</label>
                        <div class="col-sm-8">@Model.RoomQuantity</div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 fw-semibold">Trạng thái:</label>
                        <div class="col-sm-8">
                            @if (Model.Status)
                            {
                                <span class="badge bg-success">Đang hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Tạm ngưng</span>
                            }
                        </div>
                    </div>

                    <div class="row mb-2">
                        <label class="col-sm-4 fw-semibold">Danh sách ghế:</label>
                        <div class="col-sm-8">
                            @if (Model.Seats != null && Model.Seats.Any())
                            {
                                <div class="d-flex flex-wrap">
                                    @foreach (var seat in Model.Seats.Distinct())
                                    {
                                        <span class="badge bg-info text-dark m-1 px-3 py-2">@seat</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="text-muted">Không có ghế nào.</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="card-footer text-end">
                    <a href="/Booking/AdminRoom" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i> Quay lại danh sách
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
