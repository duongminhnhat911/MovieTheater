@model MovieBookingWebMVC.Areas.Booking.Models.DTOs.CreateRoomDto

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Tạo phòng chiếu mới";
}

<div class="main-container">
    <div class="header-section">
        <h1 class="header-title">
            <i class="fas fa-plus-circle me-2"></i>
            Tạo phòng chiếu mới
        </h1>
    </div>

    <div class="content-section">
        <form asp-action="CreateRoom" method="post">
            @Html.AntiForgeryToken()

            <div class="section-title">
                <i class="fas fa-couch"></i>
                Thông tin phòng chiếu
            </div>

            <div class="row g-3">
                <div class="col-md-12">
                    <h6 class="field-label">
                        <i class="fas fa-door-open"></i>Tên phòng
                    </h6>
                    <div class="form-floating">
                        <input asp-for="RoomName" name="RoomName" class="form-control" placeholder="Nhập tên phòng..." />
                    </div>
                    <span asp-validation-for="RoomName" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <h6 class="field-label">
                        <i class="fas fa-grip-lines"></i> Số hàng
                    </h6>
                    <div class="form-floating">
                        <input asp-for="Rows" name="Rows" type="number" class="form-control" min="1" placeholder="Số hàng" />
                    </div>
                    <span asp-validation-for="Rows" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <h6 class="field-label">
                        <i class="fas fa-grip-vertical"></i> Số cột
                    </h6>
                    <div class="form-floating">
                        <input asp-for="Columns" name="Columns" type="number" class="form-control" min="1" placeholder="Số cột" />
                    </div>
                    <span asp-validation-for="Columns" class="text-danger"></span>
                </div>

                <div class="col-md-12">
                    <h6 class="field-label">
                        <i class="fas fa-toggle-on"></i>Trạng thái
                    </h6>
                    <select name="Status" asp-for="Status" class="custom-select" required>
                        <option value="">-- Chọn trạng thái --</option>
                        <option value="true">Đang hoạt động</option>
                        <option value="false">Đang bảo trì</option>
                    </select>
                </div>
            </div>

            <button type="submit" class="btn btn-create-showtime mt-4">
                <i class="fas fa-plus me-2"></i>
                Tạo phòng
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
<style>
    :root {
        --primary-black: #000000;
        --mint-light: #CCFFE4;
        --teal-green: #9FCBC0;
        --light-gray: #F5F5F5;
        --white: #ffffff;
        --success-green: #28a745;
        --warning-orange: #ffc107;
        --danger-red: #dc3545;
        --shadow-light: rgba(0, 0, 0, 0.1);
        --shadow-medium: rgba(0, 0, 0, 0.15);
    }

    body {
        background: linear-gradient(135deg, #2193b0 0%, #6dd5ed 100%);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        min-height: 100vh;
    }

    .main-container {
        background: var(--white);
        border-radius: 20px;
        box-shadow: 0 10px 30px var(--shadow-light);
        margin: 3rem auto;
        max-width: 800px;
        overflow: hidden;
    }

    .header-section {
        background: linear-gradient(135deg, var(--primary-black) 0%, #333333 100%);
        color: var(--white);
        padding: 2rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .header-section::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(204, 255, 228, 0.1) 0%, transparent 70%);
            animation: rotate 20s linear infinite;
        }

    @@keyframes rotate {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    .header-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin: 0;
        position: relative;
        z-index: 1;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    }

    .content-section {
        padding: 2rem;
        background: var(--mint-light);
        background-image: radial-gradient(circle at 20% 20%, rgba(159, 203, 192, 0.1) 0%, transparent 50%), radial-gradient(circle at 80% 80%, rgba(245, 245, 245, 0.2) 0%, transparent 50%);
    }

    .form-floating {
        margin-bottom: 1.5rem;
    }

        .form-floating > .form-control,
        .form-floating > .form-select {
            border: 2px solid var(--teal-green);
            border-radius: 12px;
            padding: 0.625rem;
            font-size: 1rem;
            transition: all 0.3s ease;
            background: rgba(255, 255, 255, 0.9);
            min-height: calc(3.5rem + 2px);
            color: var(--primary-black);
        }

            .form-floating > .form-control:focus,
            .form-floating > .form-select:focus {
                border-color: var(--primary-black);
                box-shadow: 0 0 0 0.2rem rgba(159, 203, 192, 0.25);
                background: rgba(255, 255, 255, 1);
            }

        .form-floating > label {
            color: var(--primary-black);
            font-weight: 500;
            padding-left: 1.25rem;
        }

    .field-label {
        color: var(--primary-black) !important;
        font-weight: 600 !important;
        margin-bottom: 0.75rem !important;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .section-title {
        font-size: 1.3rem;
        font-weight: 600;
        color: var(--primary-black);
        margin-bottom: 1.5rem;
        margin-top: 2rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid var(--teal-green);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .section-title:first-of-type {
            margin-top: 0;
        }

    .custom-select {
        border: 2px solid var(--teal-green);
        border-radius: 12px;
        padding: 0.875rem 1rem;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: rgba(255, 255, 255, 0.9);
        color: var(--primary-black);
        width: 100%;
        margin-bottom: 1.5rem;
    }

        .custom-select:focus {
            border-color: var(--primary-black);
            box-shadow: 0 0 0 0.2rem rgba(159, 203, 192, 0.25);
            background: rgba(255, 255, 255, 1);
            outline: none;
        }

    .btn-create-showtime {
        background: linear-gradient(135deg, var(--teal-green) 0%, #7fb3d3 100%);
        border: none;
        border-radius: 12px;
        padding: 1rem 2rem;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--white);
        width: 100%;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(159, 203, 192, 0.3);
        position: relative;
        overflow: hidden;
    }

        .btn-create-showtime::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            transition: left 0.5s;
        }

        .btn-create-showtime:hover::before {
            left: 100%;
        }

        .btn-create-showtime:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(159, 203, 192, 0.5);
            background: linear-gradient(135deg, #8BC1B8 0%, #6fa8c8 100%);
            color: var(--white);
        }

        .btn-create-showtime:active {
            transform: translateY(0);
        }

    .btn-back {
        background: linear-gradient(135deg, #6c757d 0%, #5a6268 100%);
        border: none;
        border-radius: 12px;
        padding: 0.75rem 1.5rem;
        font-size: 1rem;
        font-weight: 600;
        color: var(--white);
        text-decoration: none;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(108, 117, 125, 0.3);
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 1rem;
    }

        .btn-back:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(108, 117, 125, 0.5);
            background: linear-gradient(135deg, #5a6268 0%, #495057 100%);
            color: var(--white);
            text-decoration: none;
        }

    .alert-custom {
        background: rgba(248, 113, 113, 0.1);
        border: 1px solid rgba(248, 113, 113, 0.3);
        color: #dc2626;
        border-radius: 12px;
        padding: 1rem;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
    }

        .alert-custom i {
            margin-right: 0.5rem;
        }

    .text-danger {
        color: var(--danger-red) !important;
    }

    @@media (max-width: 768px) {
        .main-container {
            margin: 1rem;
            border-radius: 15px;
        }

        .header-title {
            font-size: 2rem;
        }

        .content-section {
            padding: 1rem;
        }
    }
</style>