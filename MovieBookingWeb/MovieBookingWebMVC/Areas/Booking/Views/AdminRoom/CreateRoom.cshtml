@model MovieBookingWebMVC.Areas.Booking.Models.DTOs.CreateRoomDto

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Tạo phòng chiếu mới";
}

<div class="container mt-5 mb-4">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <h2 class="text-center fw-bold mb-4 text-primary">@ViewData["Title"]</h2>

            <form asp-action="CreateRoom" method="post" class="bg-light p-4 rounded shadow-sm border">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="RoomName" class="form-label">Tên phòng</label>
                    <input asp-for="RoomName" name="RoomName" class="form-control" placeholder="Nhập tên phòng..." />
                    <span asp-validation-for="RoomName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Rows" class="form-label">Số hàng ghế</label>
                    <input asp-for="Rows" name="Rows" class="form-control" type="number" min="1" placeholder="Ví dụ: 5" />
                    <span asp-validation-for="Rows" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Columns" class="form-label">Số cột ghế</label>
                    <input asp-for="Columns" name="Columns" class="form-control" type="number" min="1" placeholder="Ví dụ: 8" />
                    <span asp-validation-for="Columns" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Status" class="form-label">Trạng thái</label>
                    <select asp-for="Status" name="Status" class="form-select" required>
                        <option value="">-- Chọn trạng thái --</option>
                        <option value="true">Đang hoạt động</option>
                        <option value="false">Đang bảo trì</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-check-circle me-1"></i> Tạo phòng
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
