@model MovieBookingWebMVC.Areas.Booking.Models.DTOs.CreateRoomDto

@{
    ViewData["Title"] = "Tạo phòng chiếu mới";
}

<h2>@ViewData["Title"]</h2>

<form asp-action="CreateRoom" method="post">
    @Html.AntiForgeryToken() <!-- ✅ BẮT BUỘC -->
    <div class="mb-3">
        <label asp-for="RoomName" class="form-label">Tên phòng</label>
        <input name="RoomName" asp-for="RoomName" class="form-control" placeholder="Nhập tên phòng..." />
        <span asp-validation-for="RoomName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Rows" class="form-label">Số hàng ghế</label>
        <input name="Rows" asp-for="Rows" class="form-control" type="number" min="1" placeholder="Ví dụ: 5" />
        <span asp-validation-for="Rows" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Columns" class="form-label">Số cột ghế</label>
        <input name="Columns" asp-for="Columns" class="form-control" type="number" min="1" placeholder="Ví dụ: 8" />
        <span asp-validation-for="Columns" class="text-danger"></span>
    </div>

    <select name="Status" asp-for="Status" class="form-select" required>
        <option value="">-- Chọn trạng thái --</option>
        <option value="true">Đang hoạt động</option>
        <option value="false">Đang bảo trì</option>
    </select>

    <button type="submit" class="btn btn-primary">Tạo phòng</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
