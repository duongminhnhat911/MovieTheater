@model MovieBookingWebMVC.Areas.Booking.Models.DTOs.CreateShowtimeDto

@{
    ViewData["Title"] = "Create";
}

<h1>Create Showtime</h1>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <select name="MovieId" class="form-control">
                <option value="">-- Chọn phim --</option>
                @foreach (var movie in (List<SelectListItem>)ViewBag.Movies)
                {
                    <option value="@movie.Value">@movie.Text</option>
                }
            </select>

            <select name="RoomId" class="form-control">
                <option value="">-- Chọn phòng --</option>
                @foreach (var room in (List<SelectListItem>)ViewBag.Rooms)
                {
                    <option value="@room.Value">@room.Text</option>
                }
            </select>

            <!-- Date -->
            <div class="form-group">
                <label asp-for="ShowDate" class="control-label"></label>
                <input asp-for="ShowDate" name="ShowDate" type="date" class="form-control" />
                <span asp-validation-for="ShowDate" class="text-danger"></span>
            </div>

            <!-- Time -->
            <div class="form-group">
                <label asp-for="StartTime" class="control-label"></label>
                <input asp-for="StartTime" name="StartTime" type="time" class="form-control" />
                <span asp-validation-for="StartTime" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
