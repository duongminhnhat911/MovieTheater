@model MovieBookingWebMVC.Areas.Booking.Models.DTOs.CreateShowtimeDto
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Thêm suất chiếu";
}

<h2 class="text-center fw-bold mb-4">Thêm suất chiếu mới</h2>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- Chọn phim -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Chọn phim</label>
                        <select name="MovieId" class="form-select" required>
                            <option value="">-- Chọn phim --</option>
                            @foreach (var movie in (List<SelectListItem>)ViewBag.Movies)
                            {
                                <option value="@movie.Value">@movie.Text</option>
                            }
                        </select>
                    </div>

                    <!-- Chọn phòng -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Chọn phòng</label>
                        <select name="RoomId" class="form-select" required>
                            <option value="">-- Chọn phòng --</option>
                            @foreach (var room in (List<SelectListItem>)ViewBag.Rooms)
                            {
                                <option value="@room.Value">@room.Text</option>
                            }
                        </select>
                    </div>

                    <!-- Ngày chiếu -->
                    <div class="mb-3">
                        <label asp-for="ShowDate" class="form-label fw-semibold">Ngày chiếu</label>
                        <input asp-for="ShowDate" type="date" class="form-control" />
                        <span asp-validation-for="ShowDate" class="text-danger small"></span>
                    </div>

                    <!-- Giờ bắt đầu -->
                    <div class="mb-3">
                        <label asp-for="StartTime" class="form-label fw-semibold">Giờ bắt đầu</label>
                        <input asp-for="StartTime" type="time" class="form-control" />
                        <span asp-validation-for="StartTime" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Quay lại
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> Lưu suất chiếu
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
