@model MovieBookingWebMVC.Areas.Booking.Models.DTOs.CreateShowtimeDto

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Create";
}

<style>
/* Create Showtime Form Styling */
body {
    background-color: #F5F5F5;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    margin: 0;
    padding: 20px;
}

.container {
    max-width: 1200px;
    margin: 0 auto;
    background-color: #CCFFE4;
    border-radius: 15px;
    padding: 30px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
}

h1 {
    color: #000000;
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 10px;
    text-align: center;
    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.1);
}

hr {
    border: none;
    height: 3px;
    background: linear-gradient(to right, #9FCBC0, #CCFFE4);
    margin: 20px 0 30px 0;
    border-radius: 2px;
}

.row {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    margin: 0;
}

.col-md-4 {
    background-color: #ffffff;
    padding: 40px;
    border-radius: 15px;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
    border: 2px solid #9FCBC0;
    width: 100%;
    max-width: 500px;
}

/* Form Styling */
form {
    display: flex;
    flex-direction: column;
    gap: 25px;
}

.form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

label.control-label {
    color: #000000;
    font-weight: 600;
    font-size: 1.1rem;
    margin-bottom: 5px;
}

/* Select Dropdown Styling */
select.form-control {
    padding: 15px;
    border: 2px solid #9FCBC0;
    border-radius: 10px;
    font-size: 1rem;
    background-color: #ffffff;
    color: #000000;
    transition: all 0.3s ease;
    margin-bottom: 20px;
}

select.form-control:focus {
    outline: none;
    border-color: #9FCBC0;
    box-shadow: 0 0 0 3px rgba(159, 203, 192, 0.2);
    background-color: #CCFFE4;
}

select.form-control:hover {
    background-color: #F5F5F5;
    border-color: #9FCBC0;
}

/* Input Styling */
input.form-control {
    padding: 15px;
    border: 2px solid #9FCBC0;
    border-radius: 10px;
    font-size: 1rem;
    background-color: #ffffff;
    color: #000000;
    transition: all 0.3s ease;
}

input.form-control:focus {
    outline: none;
    border-color: #9FCBC0;
    box-shadow: 0 0 0 3px rgba(159, 203, 192, 0.2);
    background-color: #CCFFE4;
}

input.form-control:hover {
    background-color: #F5F5F5;
    border-color: #9FCBC0;
}

/* Submit Button Styling */
input[type="submit"].btn.btn-primary {
    background: linear-gradient(135deg, #9FCBC0, #7FB3A5);
    border: none;
    color: #000000;
    padding: 15px 30px;
    font-size: 1.2rem;
    font-weight: 600;
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(159, 203, 192, 0.3);
    text-transform: uppercase;
    letter-spacing: 1px;
}

input[type="submit"].btn.btn-primary:hover {
    background: linear-gradient(135deg, #7FB3A5, #9FCBC0);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(159, 203, 192, 0.4);
}

input[type="submit"].btn.btn-primary:active {
    transform: translateY(0);
    box-shadow: 0 2px 10px rgba(159, 203, 192, 0.3);
}

/* Validation Messages */
.text-danger {
    color: #dc3545;
    font-size: 0.9rem;
    font-weight: 500;
    margin-top: 5px;
}

.validation-summary-errors {
    background-color: #f8d7da;
    border: 1px solid #f5c6cb;
    border-radius: 8px;
    padding: 15px;
    margin-bottom: 20px;
    color: #721c24;
}

/* Back to List Link */
div a[asp-action="Index"] {
    display: inline-block;
    margin-top: 20px;
    padding: 12px 25px;
    background-color: #F5F5F5;
    color: #000000;
    text-decoration: none;
    border-radius: 8px;
    border: 2px solid #9FCBC0;
    font-weight: 600;
    transition: all 0.3s ease;
    text-align: center;
}

div a[asp-action="Index"]:hover {
    background-color: #9FCBC0;
    color: #000000;
    transform: translateY(-1px);
    box-shadow: 0 3px 10px rgba(159, 203, 192, 0.3);
}

/* Responsive Design */
@@media (max-width: 768px) {
    .container {
        padding: 20px;
        margin: 10px;
    }

    .col-md-4 {
        padding: 25px;
        margin: 0;
    }

    h1 {
        font-size: 2rem;
    }

    select.form-control,
    input.form-control {
        padding: 12px;
        font-size: 0.9rem;
    }

    input[type="submit"].btn.btn-primary {
        padding: 12px 25px;
        font-size: 1rem;
    }
}

@@media (max-width: 480px) {
    .container {
        padding: 15px;
        margin: 5px;
    }

    .col-md-4 {
        padding: 20px;
    }

    h1 {
        font-size: 1.8rem;
    }

    form {
        gap: 20px;
    }
}

/* Animation for form elements */
@@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.col-md-4 {
    animation: fadeInUp 0.6s ease-out;
}

/* Focus states for accessibility */
select.form-control:focus,
input.form-control:focus {
    outline: 3px solid rgba(159, 203, 192, 0.5);
    outline-offset: 2px;
}

/* Placeholder styling */
input::placeholder {
    color: #999999;
    opacity: 1;
}

/* Select option styling */
select.form-control option {
    padding: 10px;
    background-color: #ffffff;
    color: #000000;
}

select.form-control option:hover {
    background-color: #CCFFE4;
}

</style>

<h1>Create Showtime</h1>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <select name="MovieId" class="form-control">
                <option value="">-- Chọn phim --</option>
                @foreach (var movie in (List<SelectListItem>)ViewBag.Movies)
                {
                    <option value="@movie.Value">@movie.Text</option>
                }
            </select>

            <select name="RoomId" class="form-control">
                <option value="">-- Chọn phòng --</option>
                @foreach (var room in (List<SelectListItem>)ViewBag.Rooms)
                {
                    <option value="@room.Value">@room.Text</option>
                }
            </select>

            <!-- Date -->
            <div class="form-group">
                <label asp-for="ShowDate" class="control-label"></label>
                <input asp-for="ShowDate" name="ShowDate" type="date" class="form-control" />
                <span asp-validation-for="ShowDate" class="text-danger"></span>
            </div>

            <!-- Time -->
            <div class="form-group">
                <label asp-for="StartTime" class="control-label"></label>
                <input asp-for="StartTime" name="StartTime" type="time" class="form-control" />
                <span asp-validation-for="StartTime" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a href="/Booking/AdminShowtime/Index" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-1"></i> Trở về
    </a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
