@model IEnumerable<MovieBookingWebMVC.Areas.Booking.Models.ViewModel.ShowtimeViewModel>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Id)</th>
            <th>@Html.DisplayNameFor(model => model.MovieId)</th>
            <th>@Html.DisplayNameFor(model => model.MovieName)</th>
            <th>@Html.DisplayNameFor(model => model.Room)</th>
            <th>@Html.DisplayNameFor(model => model.ShowDate)</th>
            <th>@Html.DisplayNameFor(model => model.FromTime)</th>
            <th>@Html.DisplayNameFor(model => model.ToTime)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Id)</td>
                <td>@Html.DisplayFor(modelItem => item.MovieId)</td>
                <td>@Html.DisplayFor(modelItem => item.MovieName)</td>
                <td>@Html.DisplayFor(modelItem => item.Room)</td>
                <td>@Html.DisplayFor(modelItem => item.ShowDate)</td>
                <td>@Html.DisplayFor(modelItem => item.FromTime)</td>
                <td>@Html.DisplayFor(modelItem => item.ToTime)</td>
                <td>
                    @Html.ActionLink("Edit", "Edit", new { id = item.Id }) |
                    @Html.ActionLink("Details", "Details", new { id = item.Id }) |
                    @Html.ActionLink("Delete", "Delete", new { id = item.Id })
                </td>
            </tr>
        }
    </tbody>
</table>

