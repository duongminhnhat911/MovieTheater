@using MovieBookingWebMVC.Areas.Booking.Models.ViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Xem Danh Sách Khuyến Mãi";
}
@model List<MovieBookingWebMVC.Areas.Booking.Models.ViewModel.PromotionListViewModel>

<style>
    :root {
        --primary-black: #000000;
        --mint-light: #CCFFE4;
        --teal-green: #9FCBC0;
        --light-gray: #F5F5F5;
        --white: #ffffff;
        --success-green: #28a745;
        --warning-orange: #ffc107;
        --danger-red: #dc3545;
        --shadow-light: rgba(0, 0, 0, 0.1);
        --shadow-medium: rgba(0, 0, 0, 0.15);
        --shadow-heavy: rgba(0, 0, 0, 0.25);
    }

    .main-container {
        background: var(--white);
        border-radius: 20px;
        box-shadow: 0 10px 30px var(--shadow-light);
        margin: 2rem auto;
        max-width: 1400px;
        overflow: hidden;
    }

    .header-section {
        background: linear-gradient(135deg, var(--primary-black) 0%, #333333 100%);
        color: var(--white);
        padding: 2rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .header-section::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(204, 255, 228, 0.1) 0%, transparent 70%);
            animation: rotate 20s linear infinite;
        }

    @@keyframes rotate {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    .header-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin: 0;
        position: relative;
        z-index: 1;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    }

    .info-subtitle {
        display: flex;
        justify-content: center;
        align-items: center;
        color: #666;
        font-size: 1rem;
        margin-bottom: 1rem;
        font-weight: 500;
        text-align: center;
        width: 100%;
    }

    .icon {
        margin-right: 0.5rem;
        opacity: 0.8;
    }

    .content-section {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-start;
        gap: 1.5rem;
        box-sizing: border-box;
        padding: 2rem;
        background: var(--mint-light);
    }

    .coupon-wrapper {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        margin: 0 auto;
    }

    .coupon {
        flex: 0 0 calc(50%);
        max-width: 620px;
        height: 200px;
        border-radius: 15px;
        overflow: hidden;
        display: flex;
        align-items: stretch;
        position: relative;
        text-transform: uppercase;
        background: linear-gradient(135deg, #ffea00 0%, #ffc107 50%, #ff9800 100%);
        color: black;
        transition: all 0.3s ease;
        animation: shimmer 3s ease-in-out infinite alternate;
        box-sizing: border-box;
    }

    .coupon::before,
    .coupon::after {
        content: "";
        position: absolute;
        top: 0;
        width: 50%;
        height: 100%;
        z-index: -1;
    }

    .coupon::before {
        left: 0;
        background-image: radial-gradient(circle at 0 50%, transparent 25px, #FFD700 26px);
    }

    .coupon::after {
        right: 0;
        background-image: radial-gradient(circle at 100% 50%, transparent 25px, #FFD700 26px);
    }

    .coupon > div {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .left {
        width: 22.5%;
        background: linear-gradient(135deg, #343a40 0%, #212529 100%);
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .left-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        transform-origin: center;
        gap: 4px;
    }

        .left::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient( 45deg, transparent 25%, rgba(255, 255, 255, 0.08) 45%, rgba(255, 255, 255, 0.15) 50%, rgba(255, 255, 255, 0.08) 55%, transparent 75% );
        }

    .promo-desc {
        font-size: 0.75rem;
        font-weight: 600;
        color: #f1f1f1;
    }

    .remaining-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 4.5px;
        padding: 4px 6px;
        min-width: 110px;
        background: rgba(255, 193, 7, 0.1);
        border: 1px solid rgba(255, 193, 7, 0.25);
        border-radius: 999px;
        font-size: 0.75rem;
        color: #f8f9fa;
        font-weight: 500;
        text-shadow: none;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
        backdrop-filter: blur(2px);
        transition: all 0.3s ease;
    }

        .remaining-badge i {
            color: #ffd54f;
            font-size: 0.85rem;
        }

        .remaining-badge strong {
            color: #ffa000;
            font-weight: 600;
        }

    .center {
        flex-grow: 1;
        text-align: center;
        padding: 10px;
        position: relative;
    }

        .center h2 {
            background: linear-gradient(135deg, #000 0%, #333 100%);
            color: #FFD700;
            padding: 8px 15px;
            font-size: 1.5rem;
            white-space: nowrap;
            display: inline-block;
            border-radius: 8px;
            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.1);
            position: relative;
            z-index: 1;
            animation: pulse 2s ease-in-out infinite alternate;
        }

    .center h3 {
        font-size: 1.2rem;
        margin-top: 10px;
        text-shadow: 0 1px 3px rgba(0, 0, 0, 0.3);
        position: relative;
        z-index: 1;
    }

    .center small {
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 1px;
        display: block;
        margin-top: 8px;
        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
        position: relative;
        z-index: 1;
    }

    .right {
        width: 120px;
        background-color: var(--mint-light);
        background-image: radial-gradient(circle at 20% 20%, rgba(159, 203, 192, 0.1) 0%, transparent 50%), radial-gradient(circle at 80% 80%, rgba(245, 245, 245, 0.2) 0%, transparent 50%), radial-gradient(circle at 100% 50%, transparent 20px, #f8f9fa 21px);
        background-blend-mode: overlay;
        border-left: 2px dashed rgba(0, 0, 0, 0.2);
        position: relative;
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.5rem 0;
    }

    .rotated-group {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 0.5rem;
        transform: rotate(-90deg);
        transform-origin: center;
    }

    .barcode-text {
        font-family: "Libre Barcode 128 Text", cursive;
        font-size: 2.5rem;
        font-weight: 400;
        color: #000;
        text-shadow: 0 2px 4px rgba(255, 215, 0, 0.4);
        white-space: nowrap;
    }

    .copy-btn {
        background-color: #ffffffcc;
        border: 1px solid #ccc;
        border-radius: 5px;
        padding: 0.4rem;
        cursor: pointer;
        font-size: 1rem;
        transition: background-color 0.2s ease;
    }

        .copy-btn:hover {
            background-color: #d1f0e7;
        }

    @@media screen and (max-width: 500px) {
        .coupon {
            display: grid;
            grid-template-columns: 1fr;
            height: auto;
            width: 90%;
            max-width: 400px;
        }

        .left div,
        .right div {
            transform: rotate(0deg);
        }

        .right {
            width: 100%;
            background-image: none;
        }

        .coupon:hover {
            transform: scale(1.02);
        }
    }

    .alert-warning {
        background: linear-gradient(135deg, rgba(204, 255, 228, 0.8) 0%, rgba(159, 203, 192, 0.3) 100%);
        border: 1px solid var(--teal-green);
        color: var(--primary-black);
        border-radius: 15px;
        padding: 1.5rem;
        text-align: center;
        font-weight: 600;
        box-shadow: 0 5px 15px rgba(159, 203, 192, 0.2);
    }
</style>

<div class="main-container">
    <div class="header-section">
        <h1 class="header-title">
            <i class="fas fa-gift me-2"></i>
            Danh sách khuyến mãi
        </h1>
    </div>

    <div class="content-section">
        @if (Model != null && Model.Count > 0)
        {
            <div class="info-subtitle">
                <i class="fas fa-database icon"></i>
                Danh sách các khuyến mãi có thể áp dụng (@Model.Count khuyến mãi)
            </div>
        }

        @if (Model != null && Model.Any())
        {
            <div class="coupon-wrapper">
                @foreach (var promo in Model)
                {
                    <div class="coupon">
                        <div class="left">
                            <div class="left-content">
                                <div class="promo-desc">@promo.Description</div>
                                <div class="remaining-badge">
                                    <i class="fas fa-layer-group"></i>
                                    Còn lại: <strong>@promo.Quantity</strong>
                                </div>
                            </div>
                        </div>
                        <div class="center">
                            <div>
                                @if (promo.DiscountPercent.HasValue && promo.DiscountPercent > 0)
                                {
                                    <h2>GIẢM @promo.DiscountPercent%</h2>
                                }
                                else if (promo.DiscountAmount.HasValue && promo.DiscountAmount > 0)
                                {
                                    <h2>GIẢM @String.Format(new System.Globalization.CultureInfo("vi-VN"), "{0:c0}", promo.DiscountAmount)</h2>
                                }
                                else
                                {
                                    <h2>COUPON</h2>
                                }
                                <small>
                                    <i class="fas fa-calendar-alt me-1"></i> Thời gian áp dụng
                                    <br />
                                    Từ: @promo.StartDate.ToString("dd/MM/yyyy")
                                    <br />
                                    Đến: @promo.EndDate.ToString("dd/MM/yyyy")
                                </small>
                            </div>
                        </div>
                        <div class="right">
                            <div class="rotated-group">
                                <div class="barcode-text" id="promoCode_@promo.Id">@promo.PromotionCode</div>
                                <button class="copy-btn" onclick="copyPromoCode('@promo.Id')">
                                    <i class="fas fa-copy"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="alert alert-warning">
                <i class="fas fa-exclamation-triangle me-1"></i>
                Hiện tại không có khuyến mãi nào có sẵn. Vui lòng quay lại sau!
            </div>
        }
    </div>
</div>

<script>
    function copyPromoCode(id) {
        const textElement = document.getElementById(`promoCode_${id}`);
        const text = textElement.innerText;

        navigator.clipboard.writeText(text).then(() => {
            alert("Đã sao chép mã: " + text);
        }).catch(err => {
            console.error('Lỗi khi sao chép: ', err);
        });
    }
</script>