@using MovieBookingWebMVC.Areas.Booking.Models.ViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Xem Danh Sách Khuyến Mãi";
}
@model List<MovieBookingWebMVC.Areas.Booking.Models.ViewModel.PromotionListViewModel>

<style>
    :root {
        --primary-black: #000000;
        --mint-light: #CCFFE4;
        --teal-green: #9FCBC0;
        --light-gray: #F5F5F5;
        --white: #ffffff;
        --success-green: #28a745;
        --warning-orange: #ffc107;
        --danger-red: #dc3545;
        --shadow-light: rgba(0, 0, 0, 0.1);
        --shadow-medium: rgba(0, 0, 0, 0.15);
        --shadow-heavy: rgba(0, 0, 0, 0.25);
    }

    body {
        background: linear-gradient(135deg, #2193b0 0%, #6dd5ed 100%);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        min-height: 100vh;
    }

    .main-container {
        background: var(--white);
        border-radius: 20px;
        box-shadow: 0 10px 30px var(--shadow-light);
        margin: 2rem auto;
        max-width: 1400px;
        overflow: hidden;
    }

    .header-section {
        background: linear-gradient(135deg, var(--primary-black) 0%, #333333 100%);
        color: var(--white);
        padding: 2rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .header-section::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(204, 255, 228, 0.1) 0%, transparent 70%);
            animation: rotate 20s linear infinite;
        }

    @@keyframes rotate {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    .header-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin: 0;
        position: relative;
        z-index: 1;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    }

    .content-section {
        padding: 2rem;
        background: var(--mint-light);
        background-image: radial-gradient(circle at 20% 20%, rgba(159, 203, 192, 0.1) 0%, transparent 50%), radial-gradient(circle at 80% 80%, rgba(245, 245, 245, 0.2) 0%, transparent 50%);
    }

    .promotion-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
        gap: 2rem;
        margin-top: 2rem;
    }

    .promotion-card {
        background: var(--white);
        border-radius: 20px;
        box-shadow: 0 8px 25px var(--shadow-light);
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        border: 1px solid rgba(159, 203, 192, 0.2);
    }

        .promotion-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(135deg, var(--teal-green) 0%, #7fb3d3 100%);
            transform: scaleX(0);
            transition: transform 0.3s ease;
        }

        .promotion-card:hover::before {
            transform: scaleX(1);
        }

        .promotion-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px var(--shadow-medium);
            border-color: var(--teal-green);
        }

    .card-header {
        background: linear-gradient(135deg, var(--primary-black) 0%, #333333 100%);
        color: var(--white);
        padding: 1.5rem;
        position: relative;
        overflow: hidden;
    }

        .card-header::after {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 100px;
            height: 100px;
            background: radial-gradient(circle, rgba(204, 255, 228, 0.2) 0%, transparent 60%);
            transform: translate(30px, -30px);
        }

    .promotion-code-badge {
        background: linear-gradient(135deg, var(--teal-green) 0%, #7fb3d3 100%);
        color: var(--white);
        padding: 0.5rem 1.2rem;
        border-radius: 25px;
        font-weight: 700;
        font-size: 0.9rem;
        letter-spacing: 1px;
        display: inline-block;
        margin-bottom: 1rem;
        position: relative;
        z-index: 1;
        box-shadow: 0 4px 15px rgba(127, 179, 211, 0.3);
    }

    .card-description {
        font-weight: 600;
        color: var(--white);
        margin: 0;
        font-size: 0.95rem;
        line-height: 1.4;
        position: relative;
        z-index: 1;
    }

    .card-body {
        padding: 1.5rem;
        background: var(--white);
    }

    .discount-section {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        padding: 1rem;
        background: linear-gradient(135deg, var(--mint-light) 0%, rgba(159, 203, 192, 0.1) 100%);
        border-radius: 15px;
        border: 1px solid rgba(159, 203, 192, 0.3);
    }

    .discount-item {
        text-align: center;
        flex: 1;
    }

    .discount-label {
        font-size: 0.8rem;
        font-weight: 500;
        color: #666;
        margin-bottom: 0.3rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .discount-value {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--primary-black);
        background: var(--white);
        padding: 0.3rem 0.8rem;
        border-radius: 10px;
        display: inline-block;
        min-width: 60px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

        .discount-value.highlight {
            background: linear-gradient(135deg, var(--success-green) 0%, #20c997 100%);
            color: var(--white);
        }

    .info-section {
        position: absolute;
        top: 15px; /* Dịch xuống dưới 40px (hoặc giá trị bạn muốn) */
        right: 10px;
        padding: 10px;
    }

    .quantity-badge {
        background: linear-gradient(135deg, var(--warning-orange) 0%, #fd7e14 100%);
        color: var(--white);
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 0.3rem;
        box-shadow: 0 3px 10px rgba(255, 193, 7, 0.3);
    }

    .date-section {
        background: var(--light-gray);
        padding: 1rem;
        border-radius: 15px;
        text-align: center;
        border: 1px solid rgba(159, 203, 192, 0.2);
    }

    .date-label {
        font-size: 0.75rem;
        font-weight: 500;
        color: #666;
        margin-bottom: 0.3rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .date-value {
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--primary-black);
        margin: 0.2rem 0;
    }

    .date-range {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
    }

    .date-item {
        flex: 1;
        text-align: center;
    }

    .date-separator {
        color: var(--teal-green);
        font-weight: 700;
        font-size: 1rem;
    }

    .status-badge {
        position: absolute;
        top: 1rem;
        right: 1rem;
        padding: 0.3rem 0.8rem;
        border-radius: 15px;
        font-weight: 600;
        font-size: 0.8rem;
        z-index: 2;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    }

        .status-badge.active {
            background: linear-gradient(135deg, var(--success-green) 0%, #20c997 100%);
            color: var(--white);
        }

        .status-badge.inactive {
            background: linear-gradient(135deg, var(--danger-red) 0%, #fd1744 100%);
            color: var(--white);
        }

    .alert-warning {
        background: linear-gradient(135deg, rgba(204, 255, 228, 0.8) 0%, rgba(159, 203, 192, 0.3) 100%);
        border: 1px solid var(--teal-green);
        color: var(--primary-black);
        border-radius: 15px;
        padding: 1.5rem;
        text-align: center;
        font-weight: 600;
        box-shadow: 0 5px 15px rgba(159, 203, 192, 0.2);
    }

    .info-subtitle {
        text-align: center;
        color: #666;
        font-size: 1rem;
        margin-bottom: 1rem;
        font-weight: 500;
    }

    .icon {
        margin-right: 0.5rem;
        opacity: 0.8;
    }

    @@media (max-width: 768px) {
        .main-container {
            margin: 1rem;
            border-radius: 15px;
        }

        .header-title {
            font-size: 2rem;
        }

        .content-section {
            padding: 1rem;
        }

        .promotion-grid {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }

        .discount-section {
            flex-direction: column;
            gap: 1rem;
        }

        .discount-item {
            width: 100%;
        }

        .date-range {
            flex-direction: column;
            gap: 0.5rem;
        }

        .info-section {
            flex-direction: column;
            gap: 1rem;
            align-items: stretch;
        }
    }

    @@media (max-width: 480px) {
        .card-header {
            padding: 1rem;
        }

        .card-body {
            padding: 1rem;
        }

        .promotion-code-badge {
            font-size: 1rem;
            padding: 0.4rem 1rem;
        }

        .discount-value {
            font-size: 1.1rem;
        }
    }
</style>

<div class="main-container">
    <div class="header-section">
        <h1 class="header-title">
            <i class="fas fa-tags me-2"></i>
            Danh sách khuyến mãi
        </h1>
    </div>

    <div class="content-section">
        @if (Model != null && Model.Count > 0)
        {
            <div class="info-subtitle">
                <i class="fas fa-database icon"></i>
                Danh sách các khuyến mãi có thể sử dụng (@Model.Count khuyến mãi)
            </div>
        }

        @if (Model != null && Model.Any())
        {
            <div class="promotion-grid">
                @foreach (var promo in Model)
                {
                    <div class="promotion-card">
                        <div class="card-header">
                            <div class="promotion-code-badge">
                                <i class="fas fa-ticket-alt icon me-0"></i>
                                @promo.PromotionCode
                            </div>
                            <p class="card-description">@promo.Description</p>
                            <div class="info-section">
                                <div class="quantity-badge">
                                    <i class="fas fa-layer-group"></i>
                                    Còn lại: @promo.Quantity
                                </div>
                            </div>
                        </div>

                        <div class="card-body">
                            @if ((promo.DiscountPercent.HasValue && promo.DiscountPercent > 0) ||
                           (promo.DiscountAmount.HasValue && promo.DiscountAmount > 0))
                            {
                                <div class="discount-section">
                                    @if (promo.DiscountPercent.HasValue && promo.DiscountPercent > 0)
                                    {
                                        <div class="discount-item">
                                            <div class="discount-label">Giảm %</div>
                                            <div class="discount-value highlight">@promo.DiscountPercent%</div>
                                        </div>
                                    }

                                    @if (promo.DiscountAmount.HasValue && promo.DiscountAmount > 0)
                                    {
                                        <div class="discount-item">
                                            <div class="discount-label">Giảm VNĐ</div>
                                            <div class="discount-value highlight">@promo.DiscountAmount.Value.ToString("N0")</div>
                                        </div>
                                    }
                                </div>
                            }

                            <div class="date-section">
                                <div class="date-label">Thời gian áp dụng</div>
                                <div class="date-range">
                                    <div class="date-item">
                                        <div class="date-label">Từ ngày</div>
                                        <div class="date-value">
                                            <i class="far fa-calendar-alt icon"></i>
                                            @promo.StartDate.ToString("dd/MM/yyyy")
                                        </div>
                                    </div>
                                    <div class="date-separator">→</div>
                                    <div class="date-item">
                                        <div class="date-label">Đến ngày</div>
                                        <div class="date-value">
                                            <i class="far fa-calendar-alt icon"></i>
                                            @promo.EndDate.ToString("dd/MM/yyyy")
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="alert alert-warning">
                <i class="fas fa-exclamation-triangle me-2"></i>
                Hiện tại không có khuyến mãi nào có sẵn. Vui lòng quay lại sau!
            </div>
        }
    </div>
</div>