@model List<MovieBookingWebMVC.Areas.Booking.Models.ViewModel.PromotionListViewModel>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Danh sách khuyến mãi";
}

<h2>Danh sách khuyến mãi</h2>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Mã</th>
            <th>Mô tả</th>
            <th>Giảm (%)</th>
            <th>Giảm (VNĐ)</th>
            <th>Số lượng</th>
            <th>Bắt đầu</th>
            <th>Kết thúc</th>
            <th>Trạng thái</th>
            <th>Tác vụ</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Any())
        {
            int i = 1;
            foreach (var promo in Model)
            {
                <tr>
                    <td>@i</td>
                    <td>@promo.PromotionCode</td>
                    <td>@promo.Description</td>
                    <td>@(promo.DiscountPercent ?? 0)%</td>
                    <td>@(promo.DiscountAmount?.ToString("N0") ?? "-")</td>
                    <td>@promo.Quantity</td>
                    <td>@promo.StartDate.ToString("dd/MM/yyyy")</td>
                    <td>@promo.EndDate.ToString("dd/MM/yyyy")</td>
                    <td>
                        @if (promo.IsActive && promo.EndDate >= DateTime.Now)
                        {
                            <span class="badge bg-success">Còn hiệu lực</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Hết hạn</span>
                        }
                    </td>
                    <td>
                        <a class="btn btn-sm btn-warning" href="/Booking/AdminPromotion/Edit/@promo.Id">
                            <i class="fas fa-edit"></i> Sửa
                        </a>
                    </td>
                </tr>
                i++;
            }
        }
        else
        {
            <tr>
                <td colspan="9" class="text-center text-muted">Không có khuyến mãi nào.</td>
            </tr>
        }
    </tbody>
</table>