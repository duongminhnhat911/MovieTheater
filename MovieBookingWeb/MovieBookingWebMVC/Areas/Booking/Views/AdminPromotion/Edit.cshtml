@model MovieBookingWebMVC.Areas.Booking.Models.ViewModel.PromotionListViewModel

@{
    ViewData["Title"] = "Cập nhật khuyến mãi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --primary-black: #000000;
        --mint-light: #CCFFE4;
        --teal-green: #9FCBC0;
        --light-gray: #F5F5F5;
        --white: #ffffff;
        --success-green: #28a745;
        --warning-orange: #ffc107;
        --danger-red: #dc3545;
        --shadow-light: rgba(0, 0, 0, 0.1);
        --shadow-medium: rgba(0, 0, 0, 0.15);
        --blue-accent: #007bff;
        --purple-accent: #6f42c1;
    }

    body {
        background: linear-gradient(135deg, #2193b0 0%, #6dd5ed 100%);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        min-height: 100vh;
    }

    .main-container {
        background: var(--white);
        border-radius: 20px;
        box-shadow: 0 10px 30px var(--shadow-light);
        margin: 3rem 2rem;
        max-width: 1200px;
        overflow: hidden;
    }

    .header-section {
        background: linear-gradient(135deg, var(--primary-black) 0%, #333333 100%);
        color: var(--white);
        padding: 2rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .header-section::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(204, 255, 228, 0.1) 0%, transparent 70%);
            animation: rotate 20s linear infinite;
        }

    @@keyframes rotate {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    .header-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin: 0;
        position: relative;
        z-index: 1;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    }

    .content-section {
        padding: 2rem;
        background: var(--mint-light);
        background-image: radial-gradient(circle at 20% 20%, rgba(159, 203, 192, 0.1) 0%, transparent 50%), radial-gradient(circle at 80% 80%, rgba(245, 245, 245, 0.2) 0%, transparent 50%);
    }

    .form-floating {
        margin-bottom: 0.5rem;
    }

        .form-floating > .form-control,
        .form-floating > .form-select {
            border: 2px solid var(--teal-green);
            border-radius: 12px;
            padding: 0.625rem;
            font-size: 1rem;
            transition: all 0.3s ease;
            background: rgba(255, 255, 255, 0.9);
            min-height: calc(3.5rem + 2px);
            color: var(--primary-black);
        }

            .form-floating > .form-control:focus,
            .form-floating > .form-select:focus {
                border-color: var(--primary-black);
                box-shadow: 0 0 0 0.2rem rgba(159, 203, 192, 0.25);
                background: rgba(255, 255, 255, 1);
            }

            .form-floating > .form-control-plaintext:focus,
            .form-floating > .form-control-plaintext:not(:placeholder-shown),
            .form-floating > .form-control:focus,
            .form-floating > .form-control:not(:placeholder-shown) {
                padding-top: 0.625rem;
                padding-bottom: 0.625rem;
            }

        .form-floating > label {
            color: var(--primary-black);
            font-weight: 500;
            padding-left: 1.25rem;
        }

        .form-floating textarea.form-control {
            min-height: 120px;
            resize: vertical;
        }

    .section-title {
        font-size: 1.3rem;
        font-weight: 600;
        color: var(--primary-black);
        margin-bottom: 1.5rem;
        margin-top: 2rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid var(--teal-green);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .section-title:first-of-type {
            margin-top: 0;
        }

    .field-label {
        color: var(--primary-black) !important;
        font-weight: 600 !important;
        margin-bottom: 0.75rem !important;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-update-promotion {
        background: linear-gradient(135deg, var(--teal-green) 0%, #7fb3d3 100%);
        border: none;
        border-radius: 12px;
        padding: 1rem 2rem;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--white);
        width: 100%;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(159, 203, 192, 0.3);
        position: relative;
        overflow: hidden;
        margin-right: 1rem;
    }

        .btn-update-promotion::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            transition: left 0.5s;
        }

        .btn-update-promotion:hover::before {
            left: 100%;
        }

        .btn-update-promotion:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(159, 203, 192, 0.5);
            background: linear-gradient(135deg, #8BC1B8 0%, #6fa8c8 100%);
            color: var(--white);
        }

        .btn-update-promotion:active {
            transform: translateY(0);
        }

    .btn-cancel {
        background: linear-gradient(135deg, #6c757d 0%, #5a6268 100%);
        border: none;
        border-radius: 12px;
        padding: 1rem 2rem;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--white);
        width: 100%;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(108, 117, 125, 0.3);
        position: relative;
        overflow: hidden;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

        .btn-cancel::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            transition: left 0.5s;
        }

        .btn-cancel:hover::before {
            left: 100%;
        }

        .btn-cancel:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(108, 117, 125, 0.5);
            background: linear-gradient(135deg, #5a6268 0%, #495057 100%);
            color: var(--white);
            text-decoration: none;
        }

        .btn-cancel:active {
            transform: translateY(0);
        }

    .alert-custom {
        background: rgba(248, 113, 113, 0.1);
        border: 1px solid rgba(248, 113, 113, 0.3);
        color: #dc2626;
        border-radius: 12px;
        padding: 1rem;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
    }

        .alert-custom i {
            margin-right: 0.5rem;
        }

    .success-alert {
        background: linear-gradient(135deg, var(--success-green) 0%, #20c997 100%);
        color: var(--white);
        border: none;
        border-radius: 15px;
        padding: 1rem 2rem;
        font-weight: 600;
        box-shadow: 0 5px 15px rgba(40, 167, 69, 0.3);
        animation: slideInDown 0.5s ease-out;
    }

    @@keyframes slideInDown {
        from {
            transform: translateY(-20px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    .input-group {
        position: relative;
    }

    .input-group-text {
        background: var(--teal-green);
        border: 2px solid var(--teal-green);
        border-right: none;
        border-radius: 12px 0 0 12px;
        color: var(--primary-black);
        font-weight: 600;
    }

    .input-group .form-control {
        border: 2px solid var(--teal-green);
        border-left: none;
        border-radius: 0 12px 12px 0;
        background: rgba(255, 255, 255, 0.9);
        color: var(--primary-black);
        font-size: 1rem;
        transition: all 0.3s ease;
        min-height: calc(3.5rem + 2px);
    }

        .input-group .form-control:focus {
            border-color: var(--primary-black);
            box-shadow: 0 0 0 0.2rem rgba(159, 203, 192, 0.25);
            background: rgba(255, 255, 255, 1);
        }

    .button-group {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
    }

        .button-group .btn {
            flex: 1;
            margin: 0;
        }

    /* Styling for discount cards */
    .discount-card {
        background: var(--white);
        border-radius: 15px;
        padding: 1.5rem;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        border: 2px solid var(--teal-green);
        margin-bottom: 1.5rem;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

        .discount-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, var(--teal-green) 0%, var(--blue-accent) 100%);
        }

        .discount-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        }

    .discount-card-title {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--primary-black);
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .discount-card-title i {
            color: var(--teal-green);
            font-size: 1.3rem;
        }

    .status-card {
        background: var(--white);
        border-radius: 15px;
        padding: 1.5rem;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        border: 2px solid var(--teal-green);
        margin-bottom: 1.5rem;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

        .status-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, var(--success-green) 0%, var(--warning-orange) 100%);
        }

        .status-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        }

    .status-card-title {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--primary-black);
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .status-card-title i {
            color: var(--success-green);
            font-size: 1.3rem;
        }

    .form-check {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.5rem 0;
    }

    .form-check-input {
        width: 1.5rem;
        height: 1.5rem;
        margin: 0;
        accent-color: var(--teal-green);
        cursor: pointer;
    }

    .form-check-label {
        font-size: 1rem;
        font-weight: 500;
        color: var(--primary-black);
        cursor: pointer;
        margin: 0;
    }

    @@media (max-width: 768px) {
        .main-container {
            margin: 1rem;
            border-radius: 15px;
        }

        .header-title {
            font-size: 2rem;
        }

        .content-section {
            padding: 1rem;
        }

        .button-group {
            flex-direction: column;
        }

            .button-group .btn {
                width: 100%;
                margin-bottom: 0.5rem;
            }
    }
</style>

<div class="main-container">
    <div class="header-section">
        <h1 class="header-title">
            <i class="fas fa-edit me-2"></i>
            Cập nhật khuyến mãi
        </h1>
    </div>

    <div class="content-section">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert success-alert text-center mb-4" id="alertSuccess">
                <i class="fas fa-check-circle me-1"></i>
                @TempData["SuccessMessage"]
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert-danger-custom justify-content-center">
                <i class="fas fa-exclamation-triangle me-2"></i>
                @TempData["ErrorMessage"]
            </div>
        }

        <form href="/Booking/AdminPromotion/Edit/@Model.Id" method="post" novalidate>
            <input type="hidden" asp-for="Id" />

            <div class="section-title">
                <i class="fas fa-info-circle"></i>
                Thông tin khuyến mãi
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <h6 class="field-label">
                        <i class="fas fa-tag"></i>Mã khuyến mãi
                    </h6>
                    <div class="form-floating">
                        <input asp-for="PromotionCode" class="form-control"
                               id="promotionCode" placeholder="Mã khuyến mãi" />
                    </div>
                    <span asp-validation-for="PromotionCode" class="text-danger" />
                </div>

                <div class="col-md-6">
                    <h6 class="field-label">
                        <i class="fas fa-sort-numeric-up"></i>Số lượng
                    </h6>
                    <div class="form-floating">
                        <input asp-for="Quantity" type="number" class="form-control"
                               id="quantity" placeholder="Số lượng" min="1" />
                    </div>
                    <span asp-validation-for="Quantity" class="text-danger" />
                </div>

                <div class="col-md-12">
                    <h6 class="field-label">
                        <i class="fas fa-align-left"></i>Mô tả
                    </h6>
                    <div class="form-floating">
                        <textarea asp-for="Description" class="form-control"
                                  id="description" placeholder="Mô tả khuyến mãi" rows="3"></textarea>
                    </div>
                    <span asp-validation-for="Description" class="text-danger" />
                </div>
            </div>

            <div class="section-title">
                <i class="fas fa-calculator"></i>
                Thông tin giảm giá
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <div class="discount-card">
                        <div class="discount-card-title">
                            <i class="fas fa-money-bill-wave"></i>
                            Giảm theo số tiền (VNĐ)
                        </div>
                        <div class="input-group">
                            <input asp-for="DiscountAmount" type="number" class="form-control"
                                   id="discountAmount" placeholder="Nhập số tiền giảm" min="0" />
                        </div>
                        <span asp-validation-for="DiscountAmount" class="text-danger" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="discount-card">
                        <div class="discount-card-title">
                            <i class="fas fa-percentage"></i>
                            Giảm theo phần trăm
                        </div>
                        <div class="input-group">
                            <input asp-for="DiscountPercent" type="number" class="form-control"
                                   id="discountPercent" placeholder="Nhập phần trăm giảm" min="0" max="100" />
                        </div>
                        <span asp-validation-for="DiscountPercent" class="text-danger" />
                    </div>
                </div>
            </div>

            <div class="section-title">
                <i class="fas fa-calendar-alt"></i>
                Thời gian áp dụng
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <h6 class="field-label">
                        <i class="fas fa-calendar-check"></i>Ngày bắt đầu
                    </h6>
                    <div class="form-floating">
                        <input asp-for="StartDate" type="date" class="form-control"
                               id="startDate" placeholder="Ngày bắt đầu" />
                    </div>
                    <span asp-validation-for="StartDate" class="text-danger" />
                </div>

                <div class="col-md-6">
                    <h6 class="field-label">
                        <i class="fas fa-calendar-times"></i>Ngày kết thúc
                    </h6>
                    <div class="form-floating">
                        <input asp-for="EndDate" type="date" class="form-control"
                               id="endDate" placeholder="Ngày kết thúc" />
                    </div>
                    <span asp-validation-for="EndDate" class="text-danger" />
                </div>
            </div>

            <div class="section-title">
                <i class="fas fa-toggle-on"></i>
                Trạng thái
            </div>

            <div class="status-card">
                <div class="status-card-title">
                    <i class="fas fa-power-off"></i>
                    Trạng thái kích hoạt
                </div>
                <div class="form-check" style="margin-left: 22px;">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" id="isActive" />
                    <label asp-for="IsActive" class="form-check-label" for="isActive">
                        Kích hoạt khuyến mãi
                    </label>
                </div>
            </div>

            <div class="button-group">
                <button type="submit" class="btn btn-update-promotion">
                    <i class="fas fa-save me-1"></i>
                    Lưu thay đổi
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Initialize form on page load
        document.addEventListener('DOMContentLoaded', function() {
            // Set minimum date to today
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('startDate').min = today;
            document.getElementById('endDate').min = today;

            // Update end date minimum when start date changes
            document.getElementById('startDate').addEventListener('change', function() {
                document.getElementById('endDate').min = this.value;
            });
        });

        // Auto-hide alerts
        document.addEventListener("DOMContentLoaded", function () {
            function fadeOutAndRemove(element) {
                setTimeout(() => {
                    element.style.transition = "opacity 0.5s ease";
                    element.style.opacity = "0";
                    setTimeout(() => {
                        element.remove();
                    }, 500);
                }, 5000);
            }

            const successAlert = document.getElementById("alertSuccess");
            const dangerAlert = document.getElementById("alertDanger");
            if (successAlert) {
                fadeOutAndRemove(successAlert);
            }
            if (dangerAlert) {
                fadeOutAndRemove(dangerAlert);
            }
        });
    </script>
}