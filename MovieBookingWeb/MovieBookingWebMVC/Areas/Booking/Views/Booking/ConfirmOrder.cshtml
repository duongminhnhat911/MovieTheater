@model MovieBookingWebMVC.Areas.Booking.Models.ViewModels.ConfirmBookingViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@{
    ViewData["Title"] = "Xác nhận đơn đặt vé";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.10.0/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --primary-black: #000000;
            --mint-light: #CCFFE4;
            --teal-primary: #9FCBC0;
            --gray-light: #F5F5F5;
            --white: #ffffff;
            --shadow-color: rgba(0, 0, 0, 0.1);
            --border-radius: 12px;
        }

        body {
            background: linear-gradient(135deg, var(--mint-light) 0%, var(--gray-light) 100%);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            padding: 2rem 0;
            color: var(--primary-black);
        }

        .confirm-container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 0 1rem;
        }

        .page-header {
            text-align: center;
            margin-bottom: 3rem;
            position: relative;
        }

        .page-title {
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--primary-black);
            margin-bottom: 0.5rem;
            text-shadow: 2px 2px 4px var(--shadow-color);
        }

        .page-subtitle {
            color: var(--primary-black);
            font-size: 1.1rem;
            opacity: 0.7;
            font-weight: 500;
        }

        .booking-card {
            background: var(--white);
            border-radius: var(--border-radius);
            box-shadow: 0 8px 32px var(--shadow-color);
            overflow: hidden;
            border: 2px solid var(--teal-primary);
            position: relative;
        }

            .booking-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 4px;
                background: var(--teal-primary);
            }

        .movie-section {
            padding: 2.5rem;
            background: var(--mint-light);
            border-bottom: 1px solid var(--teal-primary);
        }

        .movie-poster {
            border-radius: var(--border-radius);
            box-shadow: 0 8px 24px var(--shadow-color);
            transition: transform 0.3s ease;
            width: 100%;
            max-height: 300px;
            object-fit: cover;
            border: 2px solid var(--teal-primary);
        }

            .movie-poster:hover {
                transform: scale(1.02);
            }

        .movie-info {
            padding-left: 2rem;
        }

        .movie-title {
            font-size: 2.2rem;
            font-weight: 700;
            color: var(--primary-black);
            margin-bottom: 0.8rem;
            line-height: 1.2;
        }

        .movie-subtitle {
            color: var(--primary-black);
            font-size: 1.1rem;
            line-height: 1.4;
            margin-bottom: 1rem;
            opacity: 0.8;
        }

        .booking-details {
            padding: 2.5rem;
            background: var(--white);
        }

        .details-table {
            background: var(--white);
            border-radius: var(--border-radius);
            overflow: hidden;
            box-shadow: 0 4px 16px var(--shadow-color);
            border: 1px solid var(--teal-primary);
        }

            .details-table th {
                background: var(--teal-primary);
                color: var(--primary-black);
                font-weight: 600;
                padding: 1.2rem 1.5rem;
                border: none;
                font-size: 1rem;
                position: relative;
            }

                .details-table th::before {
                    content: '';
                    position: absolute;
                    left: 0;
                    top: 0;
                    bottom: 0;
                    width: 4px;
                    background: var(--primary-black);
                }

            .details-table td {
                padding: 1.2rem 1.5rem;
                border: none;
                border-bottom: 1px solid var(--gray-light);
                font-size: 1rem;
                color: var(--primary-black);
                position: relative;
            }

            .details-table tr:last-child td {
                border-bottom: none;
            }

            .details-table tr:nth-child(even) {
                background: var(--gray-light);
            }

            .details-table tr:hover {
                background: var(--mint-light) !important;
                transition: background-color 0.3s ease;
            }

        .order-id {
            font-family: 'Courier New', monospace;
            font-weight: 600;
            color: var(--primary-black);
            background: var(--gray-light);
            padding: 0.5rem 1rem;
            border-radius: var(--border-radius);
            font-size: 0.95rem;
            border: 1px solid var(--teal-primary);
        }

        .seat-badges {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .seat-badge {
            background: var(--teal-primary);
            color: var(--primary-black);
            padding: 0.5rem 1rem;
            border-radius: 20px;
            font-weight: 600;
            font-size: 0.9rem;
            box-shadow: 0 2px 8px var(--shadow-color);
            transition: all 0.3s ease;
            border: 1px solid var(--primary-black);
        }

            .seat-badge:hover {
                transform: translateY(-2px);
                background: var(--primary-black);
                color: var(--white);
            }

        .total-price {
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--primary-black);
            background: var(--mint-light);
            padding: 0.8rem 1.2rem;
            border-radius: var(--border-radius);
            border: 2px solid var(--teal-primary);
        }

        .status-badge {
            padding: 0.6rem 1.2rem;
            border-radius: 25px;
            font-weight: 600;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border: 2px solid;
        }

        .status-paid {
            background: var(--teal-primary);
            color: var(--primary-black);
            border-color: var(--primary-black);
        }

        .status-unpaid {
            background: var(--gray-light);
            color: var(--primary-black);
            border-color: var(--primary-black);
        }

        .action-section {
            padding: 2.5rem;
            background: var(--mint-light);
            border-top: 1px solid var(--teal-primary);
        }

        .action-buttons {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            align-items: center;
        }

        .btn-back {
            background: var(--gray-light);
            border: 2px solid var(--teal-primary);
            color: var(--primary-black);
            padding: 1rem 2rem;
            border-radius: var(--border-radius);
            font-size: 1rem;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 4px 12px var(--shadow-color);
        }

            .btn-back:hover {
                background: var(--teal-primary);
                color: var(--primary-black);
                transform: translateY(-2px);
                box-shadow: 0 6px 20px var(--shadow-color);
            }

        .btn-confirm {
            background: var(--teal-primary);
            border: 2px solid var(--primary-black);
            color: var(--primary-black);
            padding: 1rem 2.5rem;
            border-radius: var(--border-radius);
            font-size: 1.1rem;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 4px 12px var(--shadow-color);
            position: relative;
            overflow: hidden;
        }

            .btn-confirm:disabled {
                background: var(--gray-light);
                border-color: var(--gray-light);
                color: var(--primary-black);
                cursor: not-allowed;
                opacity: 0.6;
            }

            .btn-confirm:not(:disabled):hover {
                background: var(--primary-black);
                color: var(--white);
                transform: translateY(-2px);
                box-shadow: 0 6px 20px var(--shadow-color);
            }

        .info-icon {
            color: var(--primary-black);
            margin-right: 0.5rem;
            font-size: 1.1rem;
        }

        .coming-soon {
            display: inline-block;
            background: var(--gray-light);
            color: var(--primary-black);
            padding: 0.3rem 0.8rem;
            border-radius: 15px;
            font-size: 0.75rem;
            font-weight: 600;
            margin-left: 0.5rem;
            border: 1px solid var(--teal-primary);
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.05);
            }

            100% {
                transform: scale(1);
            }
        }

        .booking-summary {
            background: var(--white);
            border: 2px solid var(--teal-primary);
            border-radius: var(--border-radius);
            padding: 1.5rem;
            margin-bottom: 2rem;
            box-shadow: 0 4px 16px var(--shadow-color);
        }

        .summary-title {
            color: var(--primary-black);
            font-weight: 600;
            margin-bottom: 1rem;
            font-size: 1.2rem;
        }

        .summary-item {
            display: flex;
            justify-content: space-between;
            margin-bottom: 0.5rem;
            padding: 0.5rem 0;
            border-bottom: 1px solid var(--gray-light);
        }

            .summary-item:last-child {
                border-bottom: none;
                font-weight: 700;
                font-size: 1.1rem;
                color: var(--primary-black);
                background: var(--mint-light);
                padding: 0.8rem 1rem;
                border-radius: var(--border-radius);
                margin: 0.5rem -0.5rem 0;
            }

        .text-success {
            color: var(--teal-primary) !important;
        }

        .text-muted {
            color: var(--primary-black) !important;
            opacity: 0.7;
        }

        @@media (max-width: 768px) {
            .page-title {
                font-size: 2rem;
            }

            .movie-section {
                padding: 1.5rem;
            }

            .movie-info {
                padding-left: 0;
                margin-top: 1.5rem;
            }

            .movie-title {
                font-size: 1.8rem;
            }

            .booking-details {
                padding: 1.5rem;
            }

            .details-table th,
            .details-table td {
                padding: 1rem;
            }

            .action-buttons {
                flex-direction: column;
                gap: 1rem;
            }

            .btn-back,
            .btn-confirm {
                width: 100%;
            }

            .seat-badges {
                justify-content: center;
            }
        }
    </style>
</head>
<body>
    <div class="confirm-container">
        <!-- Page Header -->
        <div class="page-header">
            <h1 class="page-title">
                <i class="fas fa-check-circle text-success me-2"></i>
                Xác nhận đơn đặt vé
            </h1>
            <p class="page-subtitle">Vui lòng kiểm tra thông tin trước khi xác nhận thanh toán</p>
        </div>

        <!-- Booking Card -->
        <div class="booking-card">
            <!-- Movie Section -->
            <div class="movie-section">
                <div class="row align-items-center">
                    <div class="col-md-4">
                        <img src="@Model.Movie.Image" alt="@Model.Movie.Title" class="movie-poster" />
                    </div>
                    <div class="col-md-8">
                        <div class="movie-info">
                            <h2 class="movie-title">@Model.Movie.Title</h2>
                            <p class="movie-subtitle">@Model.Movie.Subtitle</p>

                            <!-- Booking Summary -->
                            <div class="booking-summary">
                                <h5 class="summary-title">
                                    <i class="fas fa-clipboard-list me-2"></i>
                                    Tóm tắt đặt vé
                                </h5>
                                <div class="summary-item">
                                    <span>Số ghế:</span>
                                    <span>@Model.SelectedSeats.Count() ghế</span>
                                </div>
                                <div class="summary-item">
                                    <span>Giá mỗi ghế:</span>
                                    <span>@((@Model.TotalPrice / @Model.SelectedSeats.Count()).ToString("N0")) VND</span>
                                </div>
                                <div class="summary-item">
                                    <span>Tổng tiền:</span>
                                    <span>@Model.TotalPrice.ToString("N0") VND</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Booking Details -->
            <div class="booking-details">
                <table class="table details-table">
                    <tr>
                        <th>
                            <i class="fas fa-barcode info-icon"></i>
                            Mã đơn hàng
                        </th>
                        <td>
                            <span class="order-id">@Model.OrderId</span>
                        </td>
                    </tr>
                    <tr>
                        <th>
                            <i class="fas fa-user info-icon"></i>
                            Người đặt
                        </th>
                        <td>
                            <span class="order-id">
                                @User.Identity.Name
                            </span>
                        </td>
                    </tr>

                    <tr>
                        <th>
                            <i class="fas fa-door-open info-icon"></i>
                            Phòng chiếu
                        </th>
                        <td>@Model.Showtime.RoomName</td>
                    </tr>
                    <tr>
                        <th>
                            <i class="fas fa-calendar-alt info-icon"></i>
                            Ngày chiếu
                        </th>
                        <td>@Model.Showtime.ShowDate.ToString("dd/MM/yyyy")</td>
                    </tr>
                    <tr>
                        <th>
                            <i class="fas fa-clock info-icon"></i>
                            Giờ chiếu
                        </th>
                        <td>@Model.Showtime.FromTime.ToString(@"hh\:mm")</td>
                    </tr>
                    <tr>
                        <th>
                            <i class="fas fa-calendar-check info-icon"></i>
                            Ngày đặt vé
                        </th>
                        <td>@Model.BookingDate.ToString("dd/MM/yyyy")</td>
                    </tr>
                    <tr>
                        <th>
                            <i class="fas fa-couch info-icon"></i>
                            Ghế đã chọn
                        </th>
                        <td>
                            <div class="seat-badges">
                                @foreach (var seat in Model.SelectedSeats)
                                {
                                    <span class="seat-badge">@seat.Row@seat.Column</span>
                                }
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <th>
                            <i class="fas fa-money-bill-wave info-icon"></i>
                            Tổng tiền
                        </th>
                        <td>
                            <span class="total-price">@Model.TotalPrice.ToString("N0") VND</span>
                        </td>
                    </tr>
                    <tr>
                        <th>
                            <i class="fas fa-info-circle info-icon"></i>
                            Trạng thái
                        </th>
                        <td>
                            <span class="status-badge @(Model.Status ? "status-paid" : "status-unpaid")">
                                @if (Model.Status)
                                {
                                    <i class="fas fa-check-circle me-1"></i>
                                    <text>Đã thanh toán</text>
                                }
                                else
                                {
                                    <i class="fas fa-exclamation-triangle me-1"></i>
                                    <text>Chưa thanh toán</text>
                                }
                            </span>
                        </td>
                    </tr>
                </table>
            </div>

            <!-- Action Section -->
            <div class="action-section">
                <div class="action-buttons">
                    <button type="button" class="btn btn-back" onclick="history.back()">
                        <i class="fas fa-arrow-left me-2"></i>
                        Quay lại chọn ghế
                    </button>
                    <form method="post" asp-action="ConfirmBooking" asp-controller="Booking">
                        <input type="hidden" name="orderId" value="@Model.OrderId" />
                        <button type="submit" class="btn btn-confirm">
                            <i class="fas fa-credit-card me-2"></i>
                            Xác nhận thanh toán
                        </button>
                    </form>
                </div>
                <div class="mt-3 text-center">
                    <small class="text-muted">
                        <i class="fas fa-shield-alt me-1"></i>
                        Thông tin thanh toán của bạn được bảo mật tuyệt đối
                    </small>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    <script>
        // Add some interactive effects
        document.addEventListener('DOMContentLoaded', function() {
            // Animate seat badges on load
            const seatBadges = document.querySelectorAll('.seat-badge');
            seatBadges.forEach((badge, index) => {
                setTimeout(() => {
                    badge.style.opacity = '0';
                    badge.style.transform = 'translateY(20px)';
                    badge.style.transition = 'all 0.5s ease';
                    setTimeout(() => {
                        badge.style.opacity = '1';
                        badge.style.transform = 'translateY(0)';
                    }, 100);
                }, index * 100);
            });

            // Add hover effect to table rows
            const tableRows = document.querySelectorAll('.details-table tr');
            tableRows.forEach(row => {
                row.addEventListener('mouseenter', function() {
                    this.style.backgroundColor = 'rgba(204, 255, 228, 0.5)';
                });
                row.addEventListener('mouseleave', function() {
                    this.style.backgroundColor = '';
                });
            });
        });
    </script>
</body>
</html>