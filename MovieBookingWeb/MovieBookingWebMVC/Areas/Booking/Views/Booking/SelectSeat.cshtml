@model MovieBookingWebMVC.Areas.Booking.Models.ViewModels.SeatBookingViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@{
    ViewData["Title"] = "Chọn ghế";
    var movie = Model.Movie;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.10.0/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --primary-dark: #4a4e69;
            --primary-medium: #9a8c98;
            --primary-light: #c9ada7;
            --background-light: #f2f3f4;
            --accent-gold: #ffd700;
            --success-green: #28a745;
            --danger-red: #dc3545;
        }

        body {
            background: linear-gradient(135deg, var(--background-light) 0%, #e8e9ea 100%);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
        }

        .booking-container {
            background: white;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(74, 78, 105, 0.1);
            overflow: hidden;
            margin: 2rem auto;
            max-width: 1200px;
        }

        .booking-header {
            background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary-medium) 100%);
            color: white;
            padding: 2rem;
            position: relative;
            overflow: hidden;
        }

            .booking-header::before {
                content: '';
                position: absolute;
                top: -50%;
                right: -50%;
                width: 200%;
                height: 200%;
                background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
                animation: shimmer 3s ease-in-out infinite;
            }

        @@keyframes shimmer {
            0%, 100%

        {
            transform: rotate(0deg);
        }

        50% {
            transform: rotate(180deg);
        }

        }

        .movie-poster {
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
            transition: transform 0.3s ease;
        }

            .movie-poster:hover {
                transform: scale(1.05);
            }

        .movie-details {
            position: relative;
            z-index: 2;
        }

        .movie-title {
            font-size: 2.5rem;
            font-weight: 700;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
            margin-bottom: 0.5rem;
        }

        .movie-subtitle {
            font-size: 1.1rem;
            opacity: 0.9;
            margin-bottom: 1.5rem;
        }

        .info-card {
            background: rgba(255, 255, 255, 0.15);
            border-radius: 12px;
            padding: 1rem;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .info-item {
            display: flex;
            align-items: center;
            margin-bottom: 0.8rem;
        }

            .info-item i {
                color: var(--accent-gold);
                margin-right: 0.8rem;
                font-size: 1.2rem;
            }

        .booking-content {
            padding: 2rem;
        }

        .cinema-screen {
            background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary-medium) 100%);
            color: white;
            text-align: center;
            padding: 1rem;
            margin: 2rem 0;
            border-radius: 15px;
            position: relative;
            overflow: hidden;
        }

            .cinema-screen::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: linear-gradient(180deg, transparent 0%, rgba(255, 255, 255, 0.1) 100%);
            }

        .screen-text {
            font-size: 1.5rem;
            font-weight: 600;
            position: relative;
            z-index: 2;
        }

        .seat-section {
            margin: 2rem 0;
        }

        .seat-row {
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1rem;
            padding: 0.5rem;
            background: rgba(154, 140, 152, 0.05);
            border-radius: 10px;
        }

        .row-label {
            font-weight: 600;
            color: var(--primary-dark);
            width: 80px;
            text-align: center;
            font-size: 1.1rem;
        }

        .seat-container {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            justify-content: center;
            flex: 1;
        }

        .seat-item {
            position: relative;
            margin: 0.2rem;
        }

        .seat-checkbox {
            display: none;
        }

        .seat-label {
            display: block;
            width: 45px;
            height: 45px;
            border-radius: 10px;
            background: linear-gradient(145deg, #f0f0f0, #e0e0e0);
            border: 2px solid var(--primary-light);
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--primary-dark);
            box-shadow: 0 3px 10px rgba(0, 0, 0, 0.1);
        }

            .seat-label:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
            }

        .seat-checkbox:checked + .seat-label {
            background: linear-gradient(145deg, var(--success-green), #20a038);
            border-color: var(--success-green);
            color: white;
            transform: scale(1.1);
        }

        .seat-checkbox:disabled + .seat-label {
            background: linear-gradient(145deg, #ff6b6b, #ff5252);
            border-color: var(--danger-red);
            color: white;
            cursor: not-allowed;
            opacity: 0.8;
        }

            .seat-checkbox:disabled + .seat-label::after {
                content: '✕';
                position: absolute;
                font-size: 1.2rem;
                font-weight: bold;
            }

        .seat-legend {
            display: flex;
            justify-content: center;
            gap: 2rem;
            margin: 2rem 0;
            padding: 1rem;
            background: rgba(242, 243, 244, 0.5);
            border-radius: 15px;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .legend-seat {
            width: 25px;
            height: 25px;
            border-radius: 5px;
            border: 2px solid;
        }

        .legend-available {
            background: linear-gradient(145deg, #f0f0f0, #e0e0e0);
            border-color: var(--primary-light);
        }

        .legend-selected {
            background: linear-gradient(145deg, var(--success-green), #20a038);
            border-color: var(--success-green);
        }

        .legend-occupied {
            background: linear-gradient(145deg, #ff6b6b, #ff5252);
            border-color: var(--danger-red);
        }

        .booking-actions {
            text-align: center;
            padding: 2rem;
            background: rgba(154, 140, 152, 0.05);
            border-radius: 0 0 20px 20px;
        }

        .btn-book {
            background: linear-gradient(135deg, var(--success-green) 0%, #20a038 100%);
            border: none;
            color: white;
            padding: 1rem 3rem;
            border-radius: 25px;
            font-size: 1.2rem;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 8px 20px rgba(40, 167, 69, 0.3);
        }

            .btn-book:hover {
                transform: translateY(-2px);
                box-shadow: 0 12px 30px rgba(40, 167, 69, 0.4);
                background: linear-gradient(135deg, #20a038 0%, var(--success-green) 100%);
            }

        .no-seats-message {
            text-align: center;
            padding: 3rem;
            color: var(--danger-red);
            font-size: 1.2rem;
        }

            .no-seats-message i {
                font-size: 3rem;
                margin-bottom: 1rem;
                display: block;
            }

        @@media (max-width: 768px) {
            .movie-title

        {
            font-size: 2rem;
        }

        .booking-header {
            padding: 1.5rem;
        }

        .booking-content {
            padding: 1rem;
        }

        .seat-label {
            width: 35px;
            height: 35px;
            font-size: 0.8rem;
        }

        .seat-legend {
            flex-direction: column;
            gap: 1rem;
        }

        }
    </style>
</head>
<body>
    <div class="booking-container">
        <!-- Header Section -->
        <div class="booking-header">
            <div class="row align-items-center">
                <div class="col-md-3">
                    <img src="@movie.Image" alt="@movie.Title" class="movie-poster img-fluid" />
                </div>
                <div class="col-md-9 movie-details">
                    <h1 class="movie-title">@movie.Title</h1>
                    <p class="movie-subtitle">@movie.Subtitle</p>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <div class="info-card">
                                <div class="info-item">
                                    <i class="fas fa-calendar-alt"></i>
                                    <div>
                                        <strong>Ngày chiếu:</strong><br>
                                        @Model.ShowDate.ToString("dddd, dd/MM/yyyy")
                                    </div>
                                </div>
                                <div class="info-item">
                                    <i class="fas fa-clock"></i>
                                    <div>
                                        <strong>Giờ chiếu:</strong><br>
                                        @Model.FromTime
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="info-card">
                                <div class="info-item">
                                    <i class="fas fa-tv"></i>
                                    <div>
                                        <strong>Phòng:</strong><br>
                                        @Model.RoomName
                                    </div>
                                </div>
                                <div class="info-item">
                                    <i class="fas fa-coins"></i>
                                    <div>
                                        <strong>Giá vé:</strong><br>
                                        80.000 VND
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Booking Content -->
        <div class="booking-content">
            <!-- Cinema Screen -->
            <div class="cinema-screen">
                <div class="screen-text">
                    <i class="fas fa-film"></i> MÀN HÌNH CHIẾU
                </div>
            </div>

            <!-- Seat Legend -->
            <div class="seat-legend">
                <div class="legend-item">
                    <div class="legend-seat legend-available"></div>
                    <span>Có thể chọn</span>
                </div>
                <div class="legend-item">
                    <div class="legend-seat legend-selected"></div>
                    <span>Đã chọn</span>
                </div>
                <div class="legend-item">
                    <div class="legend-seat legend-occupied"></div>
                    <span>Đã có người</span>
                </div>
            </div>

            <!-- Seat Selection Form -->
            <form asp-action="SelectSeat" asp-controller="Booking" asp-area="Booking" method="post">
                <input type="hidden" name="showtimeId" value="@Model.ShowtimeId" />

                <div class="seat-section">
                    @if (Model.Seats.Any(s => s.Status == "Available"))
                    {
                        @foreach (var row in Model.Seats.GroupBy(s => s.Row))
                        {
                            <div class="seat-row">
                                <div class="row-label">Hàng @row.Key</div>
                                <div class="seat-container">
                                    @foreach (var seat in row.OrderBy(s => s.Column))
                                    {
                                        var isDisabled = seat.Status != "Available";
                                        <div class="seat-item">
                                            <input type="checkbox"
                                                   class="seat-checkbox"
                                                   name="seatIds"
                                                   value="@seat.SeatId"
                                                   id="seat-@seat.SeatId"
                                            @(isDisabled ? "disabled" : "") />
                                            <label class="seat-label" for="seat-@seat.SeatId">
                                                @seat.Column
                                            </label>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="no-seats-message">
                            <i class="fas fa-exclamation-triangle"></i>
                            <p>Hiện tại không còn ghế nào trống cho suất chiếu này.</p>
                        </div>
                    }
                </div>

                @if (Model.Seats.Any(s => s.Status == "Available"))
                {
                    <div class="booking-actions">
                        <button type="submit" class="btn btn-book">
                            <i class="fas fa-ticket-alt me-2"></i>
                            Đặt vé ngay
                        </button>
                    </div>
                }
            </form>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    <script>
        document.querySelector("form").addEventListener("submit", function (e) {
            const checkedSeats = Array.from(document.querySelectorAll("input[name='seatIds']:checked"))
                                      .map(cb => cb.value);
            if (checkedSeats.length === 0) {
                e.preventDefault();
                alert("Vui lòng chọn ít nhất một ghế để tiếp tục.");
            }
        });

        // Add seat selection animation
        document.querySelectorAll('.seat-checkbox').forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                const label = this.nextElementSibling;
                if (this.checked) {
                    label.style.transform = 'scale(1.1)';
                    setTimeout(() => {
                        label.style.transform = 'scale(1.1)';
                    }, 150);
                }
            });
        });
    </script>
</body>
</html>