@model MovieBookingWebMVC.Areas.Booking.Models.ViewModels.SeatBookingViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@{
    ViewData["Title"] = "Chọn ghế";
    var movie = Model.Movie;
    var userId = ViewBag.UserId ?? 0;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.10.0/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <style>
        :root {
            --primary-black: #000000;
            --mint-light: #CCFFE4;
            --teal-primary: #9FCBC0;
            --gray-light: #F5F5F5;
            --accent-gold: #ffd700;
            --success-green: #28a745;
            --danger-red: #dc3545;
            --held: #facc15;
        }

        body {
            background: linear-gradient(135deg, var(--mint-light) 0%, var(--gray-light) 100%);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            color: var(--primary-black);
        }

        .booking-container {
            background: white;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            margin: 2rem auto;
            max-width: 1200px;
            border: 2px solid var(--teal-primary);
        }

        .booking-header {
            background: linear-gradient(135deg, var(--primary-black) 0%, #333333 100%);
            color: white;
            padding: 2rem;
            position: relative;
            overflow: hidden;
        }

            .booking-header::before {
                content: '';
                position: absolute;
                top: -50%;
                right: -50%;
                width: 200%;
                height: 200%;
                background: radial-gradient(circle, rgba(204, 255, 228, 0.1) 0%, transparent 70%);
                animation: shimmer 3s ease-in-out infinite;
            }

        @@keyframes shimmer {
            0%, 100% {
                transform: rotate(0deg);
            }
            50% {
                transform: rotate(180deg);
            }
        }

        .movie-poster {
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
            transition: transform 0.3s ease;
            border: 3px solid var(--teal-primary);
        }

            .movie-poster:hover {
                transform: scale(1.05);
                border-color: var(--mint-light);
            }

        .movie-details {
            position: relative;
            z-index: 2;
        }

        .movie-title {
            font-size: 2.5rem;
            font-weight: 700;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
            margin-bottom: 0.5rem;
            color: white;
        }

        .movie-subtitle {
            font-size: 1.1rem;
            opacity: 0.9;
            margin-bottom: 1.5rem;
            color: var(--mint-light);
        }

        .info-card {
            background: linear-gradient(135deg, var(--mint-light) 0%, rgba(255, 255, 255, 0.9) 100%);
            border-radius: 12px;
            padding: 1rem;
            backdrop-filter: blur(10px);
            border: 2px solid var(--teal-primary);
            color: var(--primary-black);
        }

        .info-item {
            display: flex;
            align-items: center;
        }

            .info-item i {
                color: var(--teal-primary);
                margin-right: 0.8rem;
                font-size: 1.2rem;
            }

            .info-item strong {
                color: var(--primary-black);
            }

        .booking-content {
            padding: 2rem;
            background: linear-gradient(135deg, var(--mint-light) 0%, white 100%);
        }

        .cinema-screen {
            background: linear-gradient(135deg, var(--primary-black) 0%, #333333 100%);
            color: white;
            text-align: center;
            padding: 1rem;
            margin: 2rem 0;
            border-radius: 15px;
            position: relative;
            overflow: hidden;
            border: 2px solid var(--teal-primary);
        }

            .cinema-screen::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: linear-gradient(180deg, transparent 0%, rgba(204, 255, 228, 0.1) 100%);
            }

        .screen-text {
            font-size: 1.5rem;
            font-weight: 600;
            position: relative;
            z-index: 2;
        }

        .seat-section {
            margin: 2rem 0;
        }

        .seat-row {
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1rem;
            padding: 0.5rem;
            background: rgba(204, 255, 228, 0.3);
            border-radius: 10px;
            border: 1px solid var(--teal-primary);
        }

        .row-label {
            font-weight: 600;
            color: var(--primary-black);
            width: 80px;
            text-align: center;
            font-size: 1.1rem;
        }

        .seat-container {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            justify-content: center;
            flex: 1;
        }

        .seat-item {
            position: relative;
            margin: 0.2rem;
        }

        .seat-checkbox {
            display: none;
        }

        .seat-label {
            display: block;
            width: 45px;
            height: 45px;
            border-radius: 10px;
            background: linear-gradient(145deg, var(--gray-light), #e8e8e8);
            border: 2px solid var(--teal-primary);
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--primary-black);
            box-shadow: 0 3px 10px rgba(0, 0, 0, 0.1);
        }

            .seat-label:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(159, 203, 192, 0.4);
                background: linear-gradient(145deg, var(--mint-light), #b3f0d1);
                border-color: var(--primary-black);
            }

        .seat-checkbox:checked + .seat-label {
            background: linear-gradient(145deg, var(--teal-primary), #7db8ab);
            border-color: var(--primary-black);
            color: white;
            transform: scale(1.1);
        }

        .seat-checkbox:disabled + .seat-label {
            background: linear-gradient(145deg, #ff6b6b, #ff5252);
            border-color: var(--danger-red);
            color: white;
            cursor: not-allowed;
            opacity: 0.8;
        }

            .seat-checkbox:disabled + .seat-label::after {
                content: '✕';
                position: absolute;
                font-size: 1.2rem;
                font-weight: bold;
            }

        .seat-legend {
            display: flex;
            justify-content: center;
            gap: 2rem;
            margin: 2rem 0;
            padding: 1rem;
            background: var(--mint-light);
            border-radius: 15px;
            border: 2px solid var(--teal-primary);
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            color: var(--primary-black);
            font-weight: 500;
        }

        .legend-seat {
            width: 25px;
            height: 25px;
            border-radius: 5px;
            border: 2px solid;
        }

        .legend-available {
            background: linear-gradient(145deg, var(--gray-light), #e8e8e8);
            border-color: var(--teal-primary);
        }

        .legend-selected {
            background: linear-gradient(145deg, var(--teal-primary), #7db8ab);
            border-color: var(--primary-black);
        }

        .legend-occupied {
            background: linear-gradient(145deg, #ff6b6b, #ff5252);
            border-color: var(--danger-red);
        }

        .booking-actions {
            text-align: center;
            padding: 2rem;
            background: linear-gradient(135deg, var(--mint-light) 0%, var(--gray-light) 100%);
            border-radius: 0 0 20px 20px;
            border-top: 2px solid var(--teal-primary);
        }

        .btn-book {
            background: linear-gradient(135deg, var(--teal-primary) 0%, #7db8ab 100%);
            border: 2px solid var(--primary-black);
            color: var(--primary-black);
            padding: 1rem 3rem;
            border-radius: 25px;
            font-size: 1.2rem;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 8px 20px rgba(159, 203, 192, 0.3);
        }

            .btn-book:hover {
                transform: translateY(-2px);
                box-shadow: 0 12px 30px rgba(159, 203, 192, 0.5);
                background: linear-gradient(135deg, var(--primary-black) 0%, #333333 100%);
                color: white;
                border-color: var(--teal-primary);
            }

        .no-seats-message {
            text-align: center;
            padding: 3rem;
            color: var(--primary-black);
            font-size: 1.2rem;
            background: var(--mint-light);
            border-radius: 15px;
            border: 2px solid var(--teal-primary);
        }

            .no-seats-message i {
                font-size: 3rem;
                margin-bottom: 1rem;
                display: block;
                color: var(--teal-primary);
            }

        @@media (max-width: 768px) {
            .movie-title {
                font-size: 2rem;
            }

            .booking-header {
                padding: 1.5rem;
            }

            .booking-content {
                padding: 1rem;
            }

            .seat-label {
                width: 35px;
                height: 35px;
                font-size: 0.8rem;
            }

            .seat-legend {
                flex-direction: column;
                gap: 1rem;
            }

            .booking-container {
                margin: 1rem;
            }
        }

        .seat-checkbox:disabled.held + .seat-label {
            background: var(--held);
            border-color: #eab308;
            color: #000;
            opacity: 0.8;
            cursor: not-allowed;
        }

        .seat-checkbox:disabled.booked + .seat-label,
        .seat-checkbox.booked + .seat-label {
            background: var(--danger-red);
            border-color: var(--danger-red);
            color: white;
            cursor: not-allowed;
            opacity: 0.9;
        }

        .countdown-timer {
            font-weight: bold;
            font-size: 1.1rem;
            color: var(--danger-red);
            text-align: center;
            display: none;
        }
    </style>
</head>
<body>
    <div class="booking-container">
        <div class="booking-header">
            <div class="row align-items-center">
                <div class="col-md-3">
                    <img src="@movie.Image" alt="@movie.Title" class="movie-poster img-fluid" />
                </div>
                <div class="col-md-9 movie-details">
                    <h1 class="movie-title">@movie.Title</h1>
                    <p class="movie-subtitle">@movie.Subtitle</p>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="info-card">
                                <div class="info-item mb-3">
                                    <i class="fas fa-calendar-alt"></i>
                                    <div>
                                        <strong>Ngày chiếu:</strong><br>
                                        @Model.ShowDate.ToString("dddd, dd/MM/yyyy")
                                    </div>
                                </div>
                                <div class="info-item">
                                    <i class="fas fa-clock"></i>
                                    <div>
                                        <strong>Giờ chiếu:</strong><br>
                                        @Model.FromTime
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-card">
                                <div class="info-item mb-3">
                                    <i class="fas fa-tv"></i>
                                    <div>
                                        <strong>Phòng:</strong><br>
                                        @Model.RoomName
                                    </div>
                                </div>
                                <div class="info-item">
                                    <i class="fas fa-coins"></i>
                                    <div>
                                        <strong>Giá vé:</strong><br>
                                        80.000 VND
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="booking-content">
            <div class="cinema-screen">
                <div class="screen-text">
                    <i class="fas fa-film"></i> MÀN HÌNH CHIẾU
                </div>
            </div>

            <div class="seat-legend">
                <div class="legend-item">
                    <div class="legend-seat legend-available"></div>
                    <span>Có thể chọn</span>
                </div>
                <div class="legend-item">
                    <div class="legend-seat legend-selected"></div>
                    <span>Đã chọn</span>
                </div>
                <div class="legend-item">
                    <div class="legend-seat legend-occupied"></div>
                    <span>Đã có người</span>
                </div>
                <div class="legend-item">
                    <div class="legend-seat" style="background: var(--held); border-color: #eab308;"></div>
                    <span>Đang giữ</span>
                </div>
            </div>

            <div class="countdown-timer" id="countdown">Thời gian giữ ghế: 03:00</div>

            <form id="seatForm" asp-action="SelectSeat" asp-controller="Booking" asp-area="Booking" method="post">
                <input type="hidden" name="showtimeId" value="@Model.ShowtimeId" />

                <div class="seat-section">
                    @if (Model.Seats.Any(s => s.Status == "Available"))
                    {
                        @foreach (var row in Model.Seats.GroupBy(s => s.Row))
                        {
                            <div class="seat-row">
                                <div class="row-label">Hàng @row.Key</div>
                                <div class="seat-container">
                                    @foreach (var seat in row.OrderBy(s => s.Column))
                                    {
                                        var isHeld = seat.Status == "Held";
                                        var isOccupied = seat.Status == "Occupied";
                                        var isDisabled = isHeld || isOccupied;
                                        <div class="seat-item">
                                            <input type="checkbox"
                                                   class="seat-checkbox @(isHeld ? "held" : "")"
                                                   name="seatIds"
                                                   value="@seat.SeatId"
                                                   id="seat-@seat.SeatId"
                                                   data-status="@seat.Status"
                                            @(isDisabled ? "disabled" : "") />
                                            <label class="seat-label" for="seat-@seat.SeatId">
                                                @seat.Column
                                            </label>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="no-seats-message">
                            <i class="fas fa-exclamation-triangle"></i>
                            <p>Hiện tại không còn ghế nào trống cho suất chiếu này.</p>
                        </div>
                    }
                </div>

                @if (Model.Seats.Any(s => s.Status == "Available"))
                {
                    <div class="booking-actions">
                        <button type="submit" class="btn btn-book">
                            <i class="fas fa-ticket-alt me-2"></i>
                            Đặt vé ngay
                        </button>
                    </div>
                }
            </form>
        </div>
    </div>

    <script>
        const userId = @userId;
        const showtimeId = @Model.ShowtimeId;
        const connection = new signalR.HubConnectionBuilder().withUrl("https://localhost:7116/seatHub").build();

        connection.on("SeatLocked", (seatId, uid) => {
            if (uid !== userId) {
                const input = document.getElementById(`seat-${seatId}`);
                if (input) {
                    input.disabled = true;
                    input.classList.add("held");
                }
            }
        });

        connection.on("SeatUnlocked", (seatId) => {
            const input = document.getElementById(`seat-${seatId}`);
            if (input) {
                input.disabled = false;
                input.classList.remove("held");
                input.checked = false;
            }

            if (document.querySelectorAll("input[name='seatIds']:checked").length === 0) {
                clearInterval(interval);
                countdownStarted = false;
                countdown = 180;
                document.getElementById('countdown').style.display = 'none';
            }
        });

        connection.start().then(() => {
            connection.invoke("JoinShowtimeGroup", showtimeId);
        });

        let countdownStarted = false;
        let countdown = 180;
        let interval;

        function startCountdown() {
            if (countdownStarted) return;
            countdownStarted = true;
            document.getElementById('countdown').style.display = 'block';
            interval = setInterval(async () => {
                countdown--;
                const minutes = Math.floor(countdown / 60);
                const seconds = countdown % 60;
                countdownElement.textContent = `Thời gian giữ ghế: ${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
                if (countdown <= 0) {
                    clearInterval(interval);
                    countdownStarted = false;
                    countdown = 180;
                    document.getElementById('countdown').style.display = 'none';
                    alert('Thời gian giữ ghế đã hết. Hệ thống sẽ bỏ giữ các ghế đã chọn.');
                    const checkedSeats = Array.from(document.querySelectorAll("input[name='seatIds']:checked"));
                    for (let cb of checkedSeats) {
                        const seatId = parseInt(cb.value);
                        await fetch("https://localhost:7116/api/realtime/seatshowtime/unlock", {
                            method: "POST",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({ showtimeId, seatId, userId })
                        });
                        cb.checked = false;
                    }
                }
            }, 1000);
        }

        document.querySelectorAll(".seat-checkbox").forEach(cb => {
            const seatStatus = cb.getAttribute("data-status");
            if (seatStatus === "Booked") {
                cb.disabled = true;
                cb.classList.add("booked");
            }
        });

        document.querySelectorAll(".seat-checkbox:not(:disabled)").forEach(cb => {
            cb.addEventListener("change", async function () {
                const seatId = parseInt(this.value);
                if (this.checked) {
                    const response = await fetch("https://localhost:7116/api/realtime/seatshowtime/lock", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        },
                        body: JSON.stringify({ showtimeId, seatId, userId })
                    });
                    if (!response.ok) {
                        this.checked = false;
                        alert("Không thể giữ ghế. Ghế có thể đã bị người khác chọn.");
                    } else {
                        startCountdown();
                    }
                } else {
                    await fetch("https://localhost:7116/api/realtime/seatshowtime/unlock", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        },
                        body: JSON.stringify({ showtimeId, seatId, userId })
                    });
                }
            });
        });

        const countdownElement = document.getElementById('countdown');

        document.getElementById("seatForm").addEventListener("submit", function (e) {
            const checkedSeats = Array.from(document.querySelectorAll("input[name='seatIds']:checked"));
            if (checkedSeats.length === 0) {
                e.preventDefault();
                alert("Vui lòng chọn ít nhất một ghế để tiếp tục.");
            } else if (checkedSeats.length > 10) {
                e.preventDefault();
                alert("Chỉ được chọn tối đa 10 ghế.");
            }
        });
    </script>
</body>
</html>