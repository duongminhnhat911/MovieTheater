@model List<MovieBookingWebMVC.Areas.Booking.Models.DTOs.ShowtimeDTOUser>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = $"Lịch chiếu";
    var today = DateOnly.FromDateTime(DateTime.Today);
    var availableDates = Model.Select(s => s.ShowDate).Distinct().OrderBy(d => d).ToList();
    var selectedDate = availableDates.Contains(today) ? today : (availableDates.FirstOrDefault() != default ? availableDates.FirstOrDefault() : today);
    var selectedDateStr = Context.Request.Query["date"];
    if (!string.IsNullOrEmpty(selectedDateStr) &&
        DateOnly.TryParseExact(selectedDateStr, "dd-MM-yyyy", null, System.Globalization.DateTimeStyles.None, out var parsedDate))
    {
        selectedDate = parsedDate;
    }
    var movieId = Context.Request.Query["movieId"].ToString();
    var schedules = Model.Where(s => s.ShowDate == selectedDate).OrderBy(s => s.FromTime).ToList();
    var selectedMovie = new MovieBookingWebMVC.Areas.Booking.Models.DTOs.MovieWithShowtimeDTO
    {
        MovieId = 1,
        Title = "Lật Mặt 7: Một Điều Ước",
        Subtitle = "Bản điện ảnh 2025",
        Image = "/images/movies/latmat7.jpg",
        Duration = 120,
        Genres = new List<string> { "Hành động", "Tâm lý", "Hài" },
        Format = new List<string> { "2D", "IMAX" },
        Director = "Lý Hải",
    };
}

<style>
    .movie-card {
        width: 100%;
        background: #f8f9fa;
        overflow: hidden;
        transition: all 0.3s ease;
        position: relative;
        margin-bottom: 30px;
    }

        .movie-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #FF6B6B, #4ECDC4, #45B7D1, #96CEB4);
            opacity: 0;
            transition: opacity 0.3s ease;
        }

    .movie-header {
        display: flex;
        padding: 25px;
        gap: 20px;
        align-items: flex-start;
    }

    .movie-poster {
        width: 120px;
        height: 180px;
        object-fit: cover;
        border-radius: 10px;
        box-shadow: 0 8px 16px rgba(0,0,0,0.2);
        transition: transform 0.3s ease;
    }

    .movie-card:hover .movie-poster {
        transform: scale(1.05);
    }

    .movie-info {
        flex: 1;
    }

    .movie-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 10px;
        line-height: 1.3;
        margin-top: -6px;
    }

    .movie-subtitle {
        font-size: 1rem;
        color: #7f8c8d;
        margin-bottom: 10px;
        font-style: italic;
    }

    .movie-details {
        display: grid;
        gap: 8px;
        margin-bottom: 20px;
    }

    .movie-detail-item {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.9rem;
        color: #6c757d;
    }

    .movie-detail-icon {
        font-size: 1rem;
        width: 20px;
        text-align: center;
    }

    .movie-detail-text {
        flex: 1;
    }

    .movie-detail-label {
        font-weight: 600;
        color: #495057;
    }

    .showtime-container {
        background: linear-gradient(135deg, #2193b0 0%, #6dd5ed 100%);
        min-height: 100vh;
        padding: 40px 0;
    }

    .showtime-card {
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        overflow: hidden;
        margin: 0 auto;
        max-width: 1000px;
    }

    .showtime-header {
        background: linear-gradient(135deg, #000000 0%, #333333 100%);
        color: white;
        padding: 30px;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .showtime-header::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
            animation: shimmer 3s infinite;
        }

    @@keyframes shimmer {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    .showtime-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin: 0;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        position: relative;
        z-index: 1;
    }

    .date-buttons {
        display: flex;
        gap: 15px;
        margin-top: 30px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .date-btn {
        background: #f8f9fa;
        border: 2px solid #e9ecef;
        color: #6c757d;
        padding: 10px 20px;
        border-radius: 15px;
        cursor: pointer;
        transition: all 0.3s ease;
        font-weight: 600;
        text-align: center;
        min-width: 80px;
        position: relative;
        overflow: hidden;
        text-decoration: none;
    }

        .date-btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
            transition: left 0.5s;
        }

        .date-btn:hover::before {
            left: 100%;
        }

        .date-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 16px rgba(0,0,0,0.15);
            border-color: #FF6B6B;
            color: #495057;
        }

        .date-btn.active {
            background: linear-gradient(45deg, #FF6B6B, #4ECDC4);
            color: white;
            border-color: transparent;
            box-shadow: 0 8px 16px rgba(255,107,107,0.3);
        }

    .schedule-content {
        padding: 30px;
    }

    .schedule-grid {
        display: grid;
        gap: 20px;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    }

    .schedule-item {
        background: #ffffff;
        border: 2px solid #e9ecef;
        border-radius: 15px;
        padding: 20px;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

        .schedule-item::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #FF6B6B, #4ECDC4, #45B7D1, #96CEB4);
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .schedule-item:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1);
            border-color: #FF6B6B;
        }

            .schedule-item:hover::before {
                opacity: 1;
            }

    .schedule-time {
        font-size: 2rem;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 5px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .schedule-time::before {
            content: '🎬';
            font-size: 1.5rem;
        }

    .schedule-info {
        color: #6c757d;
        font-size: 1.1rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .schedule-info::before {
            content: '🪑';
            font-size: 1rem;
        }

    .book-btn {
        background: linear-gradient(45deg, #FF6B6B, #4ECDC4);
        color: white;
        border: none;
        padding: 10px 25px;
        border-radius: 25px;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        transition: all 0.3s ease;
        box-shadow: 0 4px 8px rgba(255,107,107,0.3);
        position: relative;
        overflow: hidden;
    }

        .book-btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            transition: left 0.5s;
        }

        .book-btn:hover::before {
            left: 100%;
        }

        .book-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 16px rgba(255,107,107,0.4);
            color: white;
            text-decoration: none;
        }

    .no-schedule {
        text-align: center;
        padding: 60px;
        color: #6c757d;
    }

    .no-schedule-icon {
        margin-top: -15px;
        font-size: 4rem;
        margin-bottom: 5px;
        opacity: 0.5;
    }

    .no-schedule-text {
        font-size: 1.1rem;
        font-weight: 500;
    }

    .schedule-actions {
        display: flex;
        justify-content: flex-end;
        margin-top: 15px;
    }

    @@media (max-width: 768px) {
        .showtime-title {
            font-size: 2rem;
        }

        .date-buttons {
            gap: 10px;
        }

        .date-btn {
            padding: 12px 20px;
            font-size: 0.9rem;
        }

        .schedule-grid {
            grid-template-columns: 1fr;
        }

        .schedule-time {
            font-size: 1.5rem;
        }
    }
</style>

<div class="showtime-container">
    <div class="showtime-card">
        <div class="showtime-header">
            <h2 class="showtime-title">@ViewData["Title"]</h2>
        </div>
        <div class="movie-card">
            <div class="movie-header">
                <img src="@selectedMovie.Image" class="movie-poster" />
                <div class="movie-info">
                    <h3 class="movie-title">@selectedMovie.Title</h3>
                    <p class="movie-subtitle">@selectedMovie.Subtitle</p>
                    <div class="movie-details">
                        <div class="movie-detail-item">
                            <span class="movie-detail-icon">🎬</span>
                            <span class="movie-detail-text">
                                <span class="movie-detail-label">Đạo diễn:</span> @selectedMovie.Director
                            </span>
                        </div>
                        <div class="movie-detail-item">
                            <span class="movie-detail-icon">🎭</span>
                            <span class="movie-detail-text">
                                <span class="movie-detail-label">Thể loại:</span> @string.Join(", ", selectedMovie.Genres)
                            </span>
                        </div>
                        <div class="movie-detail-item">
                            <span class="movie-detail-icon">📺</span>
                            <span class="movie-detail-text">
                                <span class="movie-detail-label">Định dạng:</span> @string.Join(", ", selectedMovie.Format)
                            </span>
                        </div>
                        <div class="movie-detail-item">
                            <span class="movie-detail-icon">⏱️</span>
                            <span class="movie-detail-text">
                                <span class="movie-detail-label">Thời lượng:</span> @selectedMovie.Duration phút
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="date-buttons">
            @foreach (var date in availableDates)
            {
                <a class="date-btn @(date == selectedDate ? "active" : "")"
                   href="?movieId=@movieId&date=@date.ToString("dd-MM-yyyy")">
                    @date.ToString("dd/MM")
                </a>
            }
        </div>

        <div class="schedule-content">
            @if (schedules.Any())
            {
                <div class="schedule-grid">
                    @foreach (var s in schedules)
                    {
                        <div class="schedule-item">
                            <div class="schedule-time">
                                @s.FromTime.ToString(@"hh\:mm")
                            </div>
                            <div class="schedule-info">
                                Còn trống: @s.AvailableSeats ghế
                            </div>
                            <div class="schedule-actions">
                                <a class="book-btn"
                                   href="/Booking/Booking/SelectSeat?scheduleId=@s.Id">
                                    Đặt vé
                                </a>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="no-schedule">
                    <div class="no-schedule-icon">📅</div>
                    <div class="no-schedule-text">Không có suất chiếu trong ngày này.</div>
                </div>
            }
        </div>
    </div>
</div>
