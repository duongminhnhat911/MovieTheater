@model MovieBookingWebMVC.Areas.Booking.Models.ViewModels.ConfirmBookingViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@{
    ViewData["Title"] = "Đặt vé thành công";
}

<style>
    .confirm-page {
        background: linear-gradient(135deg, var(--mint-light) 0%, var(--gray-light) 100%);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        padding: 20px;
        line-height: 1.6;
    }

        .confirm-page .container {
            max-width: 1000px;
            margin: 0 auto;
            background-color: #CCFFE4;
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
            border: 3px solid #9FCBC0;
        }

        .confirm-page .alert.alert-success {
            background: linear-gradient(135deg, #9FCBC0, #7FB3A5);
            border: none;
            border-radius: 15px;
            padding: 30px;
            margin-bottom: 30px;
            box-shadow: 0 6px 20px rgba(159, 203, 192, 0.3);
            animation: successPulse 2s ease-in-out;
            position: relative;
            overflow: visible;
        }

    @@keyframes successPulse {
        0%

    {
        transform: scale(0.9);
        opacity: 0.7;
    }

    50% {
        transform: scale(1.02);
        opacity: 1;
    }

    100% {
        transform: scale(1);
        opacity: 1;
    }

    }

    @@keyframes bounceIn {
        0%

    {
        transform: scale(0.3);
        opacity: 0;
    }

    50% {
        transform: scale(1.05);
        opacity: 0.8;
    }

    70% {
        transform: scale(0.9);
        opacity: 1;
    }

    100% {
        transform: scale(1);
        opacity: 1;
    }

    }

    .confirm-page .alert.alert-success h2 {
        color: #000;
        font-size: 2.5rem;
        font-weight: 800;
        margin-bottom: 15px;
        animation: bounceIn 1s ease-out;
    }

    .confirm-page .alert.alert-success p {
        font-size: 1.2rem;
        font-weight: 500;
        color: #000;
    }

    .confirm-page hr {
        border: none;
        height: 4px;
        background: linear-gradient(to right, #9FCBC0, #CCFFE4, #9FCBC0);
        margin: 30px 0;
        border-radius: 2px;
    }

    .confirm-page .row.mb-4 {
        background-color: #fff;
        border-radius: 15px;
        padding: 30px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        border: 2px solid #9FCBC0;
        animation: fadeInUp 0.8s ease-out 0.5s both;
    }

    .confirm-page .col-md-4 img {
        width: 100%;
        max-height: 300px;
        object-fit: cover;
        border-radius: 15px;
        border: 3px solid #9FCBC0;
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
        transition: transform 0.3s ease;
    }

        .confirm-page .col-md-4 img:hover {
            transform: scale(1.05);
        }

    .confirm-page .col-md-8 h3 {
        font-size: 2.2rem;
        font-weight: 700;
        color: #000;
    }

    .confirm-page .col-md-8 h5 {
        font-size: 1.3rem;
        color: #666;
        font-style: italic;
    }

    .confirm-page .col-md-8 p {
        font-size: 1.1rem;
        color: #000;
        padding: 10px 0;
        border-bottom: 1px solid #F5F5F5;
    }

        .confirm-page .col-md-8 p:last-child {
            border-bottom: none;
        }

        .confirm-page .col-md-8 p strong {
            display: inline-block;
            min-width: 140px;
            font-weight: 700;
        }

    .confirm-page .badge.bg-success {
        background: linear-gradient(135deg, #9FCBC0, #7FB3A5);
        color: #000;
        font-size: 0.9rem;
        font-weight: 600;
        padding: 8px 12px;
        border-radius: 8px;
        margin: 0 5px 5px 0;
        box-shadow: 0 2px 8px rgba(159, 203, 192, 0.3);
    }

    .confirm-page .text-success.fw-bold {
        color: #9FCBC0;
        font-weight: 800;
        font-size: 1.1rem;
    }

    .confirm-page .col-md-8 p:has(strong:contains("Tổng tiền")) {
        background: linear-gradient(135deg, #9FCBC0, #CCFFE4);
        padding: 15px;
        border-radius: 10px;
        border: 2px solid #9FCBC0;
        font-size: 1.2rem;
        font-weight: 600;
        margin: 20px 0;
    }

    .confirm-page .text-center.mt-4 {
        background-color: #fff;
        padding: 30px;
        border-radius: 15px;
        border: 2px solid #9FCBC0;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        animation: fadeInUp 0.8s ease-out 0.8s both;
    }

    @@keyframes fadeInUp {
        from

    {
        opacity: 0;
        transform: translateY(30px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .confirm-page .alert.alert-success::before {
        content: "✓";
        position: absolute;
        top: -10px;
        right: -10px;
        background: linear-gradient(135deg, #9FCBC0, #7FB3A5);
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-weight: bold;
        color: #000000;
        box-shadow: 0 4px 15px rgba(159, 203, 192, 0.3);
        animation: checkmarkPop 1s ease-out 0.5s both;
    }

    @@keyframes checkmarkPop {
        0%

    {
        transform: scale(0) rotate(180deg);
        opacity: 0;
    }

    80% {
        transform: scale(1.2) rotate(360deg);
        opacity: 1;
    }

    100% {
        transform: scale(1) rotate(360deg);
        opacity: 1;
    }

    }
</style>

<div class="confirm-page">
    <div class="container mt-4">
        <div class="alert alert-success text-center" role="alert">
            <h2 class="mb-3">🎉 ĐẶT VÉ THÀNH CÔNG!</h2>
            <p>Cảm ơn bạn đã sử dụng hệ thống đặt vé của chúng tôi.</p>
        </div>

        <hr />

        <div class="row mb-4">
            <div class="row">
                <div class="col-md-4">
                    <img src="@Model.Movie.Image" alt="@Model.Movie.Title"
                         class="img-fluid rounded shadow-sm mb-3" style="max-height: 250px;" />
                </div>
            </div>
            <div class="col-md-8">
                <h3>@Model.Movie.Title</h3>
                @if (!string.IsNullOrEmpty(Model.Movie.Subtitle))
                {
                    <h5 class="text-muted">@Model.Movie.Subtitle</h5>
                }

                <p><strong>Phòng chiếu:</strong> @Model.Showtime.RoomName</p>
                <p><strong>Ngày chiếu:</strong> @Model.Showtime.ShowDate.ToString("dd/MM/yyyy")</p>
                <p><strong>Giờ chiếu:</strong> @Model.Showtime.FromTime</p>
                <p>
                    <strong>Ghế đã đặt:</strong>
                    @foreach (var seat in Model.SelectedSeats)
                    {
                        <span class="badge bg-success me-1">@seat.Row@seat.Column</span>
                    }
                </p>
                <p><strong>Tổng tiền:</strong> @Model.TotalPrice.ToString("N0") VNĐ</p>
                <p><strong>Mã đơn hàng:</strong> @Model.OrderId</p>
                <p><strong>Ngày đặt vé:</strong> @Model.BookingDate.ToString("dd/MM/yyyy")</p>
                <p><strong>Trạng thái:</strong> <span class="text-success fw-bold">Đã thanh toán</span></p>
            </div>
        </div>

        <div class="text-center mt-4">
            <a href="/" class="btn btn-outline-success px-4">🏠 Về trang chủ</a>
            <a href="/Booking/Booking/MoviesByDate" class="btn btn-primary px-4 ms-3">🎬 Xem thêm phim</a>
        </div>
    </div>
</div>
