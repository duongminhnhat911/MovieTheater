@model MovieBookingWebMVC.Areas.Booking.Models.ViewModel.BookingViewModel
@{
    ViewData["Title"] = "Đặt vé - " + Model.Title;
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>
    /* Modern Movie Booking Page Styles */

    body {
        background: linear-gradient(135deg, #2193b0 0%, #6dd5ed 100%);
        min-height: 100vh;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        font-feature-settings: 'cv05', 'cv11';
    }

    .container-fluid {
        padding: 0;
    }

    .movie-container {
        max-width: 1200px;
        margin: 40px auto;
        background: rgba(255, 255, 255, 0.95);
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        backdrop-filter: blur(10px);
    }

    /* Header Section */
    .movie-header {
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        color: white;
        padding: 30px 40px;
        text-align: center;
    }

        .movie-header h1 {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
            letter-spacing: -0.025em;
            margin-top: 0;
        }

        .movie-header .subtitle {
            font-size: 1.1rem;
            opacity: 0.9;
            font-weight: 400;
            letter-spacing: -0.01em;
        }

    /* Main Content Grid */
    .movie-content {
        display: grid;
        grid-template-columns: 400px 1fr;
        gap: 40px;
        padding: 40px;
    }

    /* Poster Section */
    .poster-section {
        position: relative;
    }

    .poster-wrapper {
        position: relative;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);
        transition: transform 0.3s ease;
    }

        .poster-wrapper:hover {
            transform: translateY(-5px);
        }

        .poster-wrapper img {
            width: 100%;
            height: 600px;
            object-fit: cover;
            display: block;
        }

    /* Format Tags */
    .format-tags {
        position: absolute;
        top: 15px;
        left: 15px;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        z-index: 10;
    }

    .format-tag {
        background: linear-gradient(135deg, #ff6b35, #ff8c42);
        color: white;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: bold;
        text-transform: uppercase;
        box-shadow: 0 4px 8px rgba(255, 107, 53, 0.3);
        backdrop-filter: blur(10px);
    }

    /* Movie Info Section */
    .movie-title {
        font-size: 2.2rem;
        font-weight: 700;
        color: #1e3c72;
        margin-bottom: 30px;
        margin-top: 0;
        line-height: 1.2;
        letter-spacing: -0.025em;
    }

    /* Quick Info Cards */
    .quick-info {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
    }

    .info-card {
        background: linear-gradient(135deg, #f8f9ff 0%, #e8f2ff 100%);
        border: 1px solid #e1e8ff;
        border-radius: 12px;
        padding: 20px;
        text-align: center;
        transition: all 0.3s ease;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
    }

        .info-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
        }

        .info-card i {
            font-size: 2rem;
            color: #667eea;
            margin-bottom: 10px;
        }

        .info-card .label {
            font-size: 0.9rem;
            color: #666;
            margin-bottom: 5px;
            text-transform: uppercase;
            font-weight: 600;
            letter-spacing: 0.05em;
        }

        .info-card .value {
            font-size: 1.1rem;
            font-weight: 700;
            color: #1e3c72;
            letter-spacing: -0.01em;
        }

    /* Detail Sections */
    .detail-section {
        background: white;
        border-radius: 15px;
        padding: 10px 20px;
        margin-bottom: 30px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        border: 1px solid #f0f0f0;
    }

        .detail-section h3 {
            color: #1e3c72;
            font-size: 1.6rem;
            font-weight: 700;
            margin-bottom: 20px;
            margin-top: 15px;
            display: flex;
            align-items: center;
            letter-spacing: -0.02em;
        }

            .detail-section h3 i {
                color: #667eea;
            }

    .detail-list {
        list-style: none;
        padding: 0px;
    }

        .detail-list li {
            display: flex;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid #f0f0f0;
            transition: background-color 0.3s ease;
        }

            .detail-list li:last-child {
                border-bottom: none;
            }

            .detail-list li strong {
                color: #1e3c72;
                font-weight: 600;
                width: 140px;
                flex-shrink: 0;
                letter-spacing: -0.01em;
            }

            .detail-list li span {
                color: #555;
                font-size: 1rem;
                font-weight: 400;
            }

    /* Description Section */
    .description-text {
        color: #444;
        font-size: 1.1rem;
        line-height: 1.8;
        text-align: justify;
        background: linear-gradient(135deg, #f8f9ff 0%, #e8f2ff 100%);
        padding: 10 15px;
        border-radius: 12px;
        margin-bottom: 15px;
        border-left: 4px solid #667eea;
        font-weight: 400;
        letter-spacing: -0.005em;
    }

    /* Responsive Design */
    @@media (max-width: 992px) {
        .movie-content

    {
        grid-template-columns: 1fr;
        gap: 30px;
        padding: 30px;
    }

    .poster-wrapper {
        max-width: 400px;
        margin: 0 auto;
    }

    .movie-title {
        font-size: 2rem;
        text-align: center;
    }

    }

    @@media (max-width: 768px) {
        .movie-container

    {
        margin: 20px;
        border-radius: 15px;
    }

    .movie-header {
        padding: 20px;

    }

        .movie-header h1 {
            font-size: 2rem;
            margin-top: 0;
        }

    .movie-content {
        padding: 20px;
    }

    .quick-info {
        grid-template-columns: 1fr;
    }

    .detail-section {
        padding: 20px;
    }

    .detail-list li strong {
        width: 120px;
    }

    }

    @@media (max-width: 576px) {
        .movie-header h1

    {
        font-size: 1.8rem;
    }

    .movie-title {
        font-size: 1.6rem;
    }

    .detail-section h3 {
        font-size: 1.4rem;
    }

    .detail-list li {
        flex-direction: column;
        align-items: flex-start;
        gap: 5px;
    }

        .detail-list li strong {
            width: 100%;
        }

    }
</style>

<div class="container-fluid">
    <div class="movie-container">
        <!-- Header -->
        <div class="movie-header">
            <h1>@Model.Title</h1>
            <div class="subtitle">Thông tin chi tiết về bộ phim</div>
        </div>

        <!-- Main Content -->
        <div class="movie-content">
            <!-- Poster Section -->
            <div class="poster-section">
                <div class="poster-wrapper">
                    <img src="@Model.Image" alt="@Model.Title" />
                    @if (Model.Format != null && Model.Format.Any())
                    {
                        <div class="format-tags">
                            @foreach (var fmt in Model.Format)
                            {
                                <span class="format-tag">@fmt</span>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Info Section -->
            <div class="info-section">
                <h2 class="movie-title">@Model.Title</h2>

                <!-- Quick Info Cards -->
                <div class="quick-info">
                    <div class="info-card">
                        <i class="fas fa-film"></i>
                        <div class="label">Thể loại</div>
                        <div class="value">@(Model.Genres != null ? string.Join(", ", Model.Genres) : "Chưa có thông tin")</div>
                    </div>
                    <div class="info-card">
                        <i class="far fa-clock"></i>
                        <div class="label">Thời lượng</div>
                        <div class="value">@Model.Duration phút</div>
                    </div>
                    <div class="info-card">
                        <i class="fas fa-certificate"></i>
                        <div class="label">Phân loại</div>
                        <div class="value">@Model.Rating</div>
                    </div>
                    <div class="info-card">
                        <i class="fas fa-language"></i>
                        <div class="label">Phụ đề</div>
                        <div class="value">@Model.Subtitle</div>
                    </div>
                </div>

                <!-- Movie Details -->
                <div class="detail-section">
                    <h3><i class="fas fa-info-circle"></i>Thông tin sản xuất</h3>
                    <ul class="detail-list">
                        <li>
                            <strong>Nhà sản xuất:</strong>
                            <span>@Model.ProductionCompany</span>
                        </li>
                        <li>
                            <strong>Đạo diễn:</strong>
                            <span>@Model.Director</span>
                        </li>
                        <li>
                            <strong>Ngày khởi chiếu:</strong>
                            <span>@Model.ReleaseDate?.ToString("dd/MM/yyyy")</span>
                        </li>
                    </ul>
                </div>

                <!-- Movie Description -->
                <div class="detail-section">
                    <h3><i class="fas fa-book-open"></i>Nội dung phim</h3>
                    <div class="description-text">
                        @Model.Description
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/booking.js"></script>
}