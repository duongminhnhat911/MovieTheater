@model MovieBookingWebMVC.Areas.User.Models.ViewModel.UpdateProfileViewModel
@{
    ViewData["Title"] = "Thông tin tài khoản";
}

<style>
    /* Custom styles for Profile page */
    .profile-container {
        background: linear-gradient(135deg, #2193b0 0%, #6dd5ed 100%);
        border-radius: 15px;
        padding: 2rem;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        max-width: 800px;
        margin: 2rem auto;
    }

    .profile-title {
        color: #000000;
        font-weight: bold;
        text-align: center;
        margin-bottom: 2rem;
        font-size: 2rem;
    }

    .form-label {
        color: #000000;
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    .form-control {
        border: 2px solid #9FCBC0;
        border-radius: 8px;
        padding: 0.75rem;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            border-color: #9FCBC0;
            box-shadow: 0 0 0 0.2rem rgba(159, 203, 192, 0.25);
        }

        .form-control:hover {
            border-color: #9FCBC0;
            background-color: #F5F5F5;
        }

    .btn-update {
        background: linear-gradient(135deg, #2193b0 0%, #6dd5ed 100%);
        border: none;
        border-radius: 8px;
        padding: 0.75rem;
        font-size: 1.1rem;
        font-weight: 600;
        color: #000000;
        transition: all 0.3s ease;
        width: 100%;
    }

        .btn-update:hover {
            background-color: #F5F5F5;
            border: 2px solid #9FCBC0;
            color: #000000;
            transform: translateY(-2px);
        }

    .btn-change-avatar {
        background: linear-gradient(135deg, #2193b0 0%, #6dd5ed 100%);
        border: 2px solid #9FCBC0;
        border-radius: 8px;
        padding: 0.5rem 1rem;
        font-size: 0.9rem;
        font-weight: 600;
        color: #000000;
        transition: all 0.3s ease;
    }

        .btn-change-avatar:hover {
            background-color: #F5F5F5;
            border: 2px solid #9FCBC0;
            color: #000000;
        }

    .alert-success-custom {
        background-color: #9FCBC0;
        border: 2px solid #9FCBC0;
        border-radius: 8px;
        color: #000000;
        padding: 1rem;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
        text-align: center;
    }

    .alert-danger-custom {
        background-color: #F5F5F5;
        border: 2px solid #dc3545;
        border-radius: 8px;
        color: #000000;
        padding: 1rem;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
        text-align: center;
    }

    .avatar-section {
        background-color: #F5F5F5;
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 2rem;
        border: 2px solid #9FCBC0;
    }

    .avatar-preview {
        width: 91px;
        height: 91px;
        object-fit: cover;
        border: 3px solid #9FCBC0;
        transition: transform 0.3s ease;
    }

        .avatar-preview:hover {
            transform: scale(1.05);
        }

    .avatar-info h5 {
        color: #000000;
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    .avatar-info p {
        color: #000000;
        margin-bottom: 1rem;
    }

    .form-check-input {
        border: 2px solid #9FCBC0;
        margin-right: 0.5rem;
    }

        .form-check-input:checked {
            background-color: #9FCBC0;
            border-color: #9FCBC0;
        }

    .form-check-label {
        color: #000000;
        font-weight: 500;
    }

    .page-background {
        background-color: #F5F5F5;
        min-height: 100vh;
        padding: 2rem 0;
    }

    .gender-section {
        background-color: #F5F5F5;
        border-radius: 8px;
        padding: 1rem;
        border: 2px solid #9FCBC0;
    }

    /* Responsive design */
    @@media (max-width: 768px) {
        .profile-container

    {
        margin: 1rem;
        padding: 1.5rem;
        max-width: 95%;
    }

    .profile-title {
        font-size: 1.75rem;
    }

    .avatar-section {
        padding: 1rem;
    }

        .avatar-section .d-flex {
            flex-direction: column;
            align-items: center;
            text-align: center;
        }

    .avatar-info {
        margin-top: 1rem;
    }

    .btn-change-avatar {
        width: 100%;
    }

    }

    @@media (max-width: 576px) {
        .col-md-6

    {
        margin-bottom: 1rem;
    }

    }
</style>

<div class="page-background">
    <div class="flex-grow-1">
        <div class="container">
            <div class="profile-container">
                <h2 class="profile-title">Thông tin tài khoản</h2>

                @if (@TempData["Success"] != null)
                {
                    <div class="alert-success-custom">
                        <i class="fa-solid fa-check" style="color: #000000;"></i> @TempData["Success"]
                    </div>
                }

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert-danger-custom">
                        <i class="fa-solid fa-xmark" style="color: #dc3545;"></i> @Html.Raw(string.Join("<br/>", ViewData.ModelState.Values
                                            .SelectMany(v => v.Errors)
                                            .Select(e => e.ErrorMessage)))
                </div>
                                }

                <div class="avatar-section">
                    <div class="d-flex align-items-center justify-content-center">
                        <img id="avatarPreview"
                             src="/images/default-avatar.jpg"
                             alt="Avatar"
                             class="rounded-circle me-3 avatar-preview">

                        <div class="avatar-info">
                            <h5>@Model.Username</h5>
                            <p>@Model.FullName</p>
                            <button type="button" class="btn btn-change-avatar">
                                <i class="fa-solid fa-camera"></i> Thay ảnh đại diện
                            </button>
                        </div>
                    </div>
                </div>

                <form method="post" enctype="multipart/form-data" novalidate>
                    <input type="hidden" asp-for="Id" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Họ và tên</label>
                            <input asp-for="FullName" class="form-control" placeholder="Nhập họ và tên" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Tên tài khoản</label>
                            <input asp-for="Username" class="form-control" placeholder="Nhập tên tài khoản" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Giới tính</label>
                            <div class="gender-section">
                                <div class="row">
                                    <div class="col-4">
                                        <div class="form-check">
                                            <input asp-for="Gender" class="form-check-input" type="radio" value="Nam" />
                                            <label class="form-check-label">Nam</label>
                                        </div>
                                    </div>
                                    <div class="col-4">
                                        <div class="form-check">
                                            <input asp-for="Gender" class="form-check-input" type="radio" value="Nữ" />
                                            <label class="form-check-label">Nữ</label>
                                        </div>
                                    </div>
                                    <div class="col-4">
                                        <div class="form-check">
                                            <input asp-for="Gender" class="form-check-input" type="radio" value="Khác" />
                                            <label class="form-check-label">Khác</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Ngày sinh</label>
                            <input asp-for="BirthDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="Nhập email" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Số CCCD</label>
                            <input asp-for="IdCard" class="form-control" placeholder="Nhập số căn cước" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Số điện thoại</label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="Nhập số điện thoại" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Địa chỉ</label>
                            <input asp-for="Address" class="form-control" placeholder="Nhập địa chỉ" />
                        </div>
                    </div>

                    <div class="mt-4 d-grid">
                        <button type="submit" class="btn btn-update">Cập nhật thông tin</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}