@model MovieBookingWebMVC.Areas.User.Models.ViewModel.UpdateProfileViewModel
@{
    ViewData["Title"] = "Thông tin tài khoản";
}

<div class="flex-grow-1">
    <div class="container" style="max-width: 600px; margin-top: 2rem;">
        <h2 class="text-center fw-bold">Thông tin tài khoản</h2>

        @if (@TempData["Success"] != null)
        {
            <div id="alertSuccess" class="alert alert-success text-center custom-alert mt-3 mb-3"
                 style="width: 300px; margin: 0 auto; padding: 0.5rem 1rem; font-size: 0.9rem;">
                <i class="fa-solid fa-check" style="color: green;"></i> @TempData["Success"]
            </div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div id="alertDanger" class="alert alert-danger text-center custom-alert mt-3 mb-3"
                 style="width: 300px; margin: 0 auto; padding: 0.5rem 1rem; font-size: 0.9rem;">
                <i class="fa-solid fa-xmark" style="color: red;"></i> @Html.Raw(string.Join("<br/>", ViewData.ModelState.Values
            .SelectMany(v => v.Errors)
            .Select(e => e.ErrorMessage)))
            </div>
        }

        <div class="d-flex align-items-center justify-content-center mt-4 mb-4">
            <img id="avatarPreview"
                 src="/images/default-avatar.jpg"
                 alt="Avatar"
                 class="rounded-circle me-3 border"
                 style="width: 91px; height: 91px; object-fit: cover;">

            <div style="height: 80px; display: flex; flex-direction: column; justify-content: center;">
                <h5 class="mb-1">@Model.Username</h5>
                <p class="text-muted mb-2">@Model.FullName</p>
                <button type="button" class="btn btn-outline-secondary btn-sm" style="width: 160px;">
                    <i class="fa-solid fa-camera"></i> Thay ảnh đại diện
                </button>
            </div>
        </div>

        <form method="post" enctype="multipart/form-data" novalidate>
            <input type="hidden" asp-for="Id" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Họ và tên</label>
                    <input asp-for="FullName" class="form-control" placeholder="Nhập họ và tên" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Tên tài khoản</label>
                    <input asp-for="Username" class="form-control" placeholder="Nhập tên tài khoản" />
                </div>
                <div class="col-md-6">
                    <div class="row h-100">
                        <label class="form-label fw-bold">Giới tính</label><br />
                        <div class="col-4">
                            <div class="form-check">
                                <input asp-for="Gender" class="form-check-input" type="radio" value="Nam" />
                                <label class="form-check-label">Nam</label>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="form-check">
                                <input asp-for="Gender" class="form-check-input" type="radio" value="Nữ" />
                                <label class="form-check-label">Nữ</label>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="form-check">
                                <input asp-for="Gender" class="form-check-input" type="radio" value="Khác" />
                                <label class="form-check-label">Khác</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Ngày sinh</label>
                    <input asp-for="BirthDate" type="date" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Email</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="Nhập email" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Số CCCD</label>
                    <input asp-for="IdCard" class="form-control" placeholder="Nhập số căn cước" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Số điện thoại</label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="Nhập số điện thoại" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Địa chỉ</label>
                    <input asp-for="Address" class="form-control" placeholder="Nhập địa chỉ" />
                </div>
            </div>

            <div class="mt-4 d-grid">
                <button type="submit" class="btn btn-dark btn-lg">Cập nhật thông tin</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}