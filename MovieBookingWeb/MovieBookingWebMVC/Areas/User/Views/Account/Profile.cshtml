@model MovieBookingWebMVC.Areas.User.Models.ViewModel.UpdateProfileViewModel
@{
    ViewData["Title"] = "Thông tin tài khoản";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .box-radio {
        position: relative;
        cursor: pointer;
        border: 2px solid #ccc;
        border-radius: 12px;
        padding: 10px 15px;
        user-select: none;
        transition: all 0.3s ease;
        background-color: #f8f9fa;
        font-weight: 500;
        color: #333;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100px;
        height: 42px;
    }

        .box-radio input[type="radio"] {
            display: none;
        }

            .box-radio input[type="radio"]:checked + span {
                color: #fff;
                font-weight: 600;
                z-index: 1;
            }

                .box-radio input[type="radio"]:checked + span::before {
                    content: "";
                    position: absolute;
                    inset: 0;
                    background-color: rgba(30, 41, 59, 0.8) !important;
                    border-radius: 8px;
                    z-index: -1;
                }

        .box-radio:hover {
            border-color: #0d6efd;
            background-color: #e9f2ff;
        }

    :root {
        --primary-black: #000000;
        --mint-light: #CCFFE4;
        --teal-green: #9FCBC0;
        --light-gray: #F5F5F5;
        --white: #ffffff;
        --success-green: #28a745;
        --warning-orange: #ffc107;
        --danger-red: #dc3545;
        --shadow-light: rgba(0, 0, 0, 0.1);
        --shadow-medium: rgba(0, 0, 0, 0.15);
    }

    body {
        background: linear-gradient(135deg, #2193b0 0%, #6dd5ed 100%);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        min-height: 100vh;
        margin: 0;
        padding: 0;
    }

    .container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        padding: 2rem;
        z-index: 1;
    }

    .profile-container {
        background: var(--white);
        border-radius: 20px;
        box-shadow: 0 10px 30px var(--shadow-light);
        max-width: 800px;
        width: 100%;
        overflow: hidden;
        animation: slideInUp 0.6s ease-out;
    }

    @@keyframes slideInUp {
        from {
            transform: translateY(30px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    .header-section {
        background: linear-gradient(135deg, var(--primary-black) 0%, #333333 100%);
        color: var(--white);
        padding: 2rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .header-section::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(204, 255, 228, 0.1) 0%, transparent 70%);
            animation: rotate 20s linear infinite;
        }

    @@keyframes rotate {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    .profile-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin: 0;
        position: relative;
        z-index: 1;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    }

    .avatar-section {
        position: relative;
        z-index: 1;
        margin-top: 2rem;
    }

    .avatar-preview {
        width: 120px;
        height: 120px;
        border: 4px solid white;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        transition: transform 0.3s ease;
    }

        .avatar-preview:hover {
            transform: scale(1.05);
        }

    .avatar-info h5 {
        font-size: 1.5rem;
        font-weight: 600;
        margin: 0.5rem 0;
    }

    .avatar-info p {
        font-size: 1rem;
        opacity: 0.8;
        margin: 0;
    }

    .btn-change-avatar {
        background: rgba(255, 255, 255, 0.2);
        border: 2px solid rgba(255, 255, 255, 0.3);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 25px;
        font-weight: 500;
        transition: all 0.3s ease;
        margin-top: 1rem;
    }

        .btn-change-avatar:hover {
            background: white;
            color: var(--primary-black);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
        }

    .content-section {
        padding-left: 2rem;
        padding-right: 2rem;
        padding-top: 1.5rem;
        padding-bottom: 2rem;
        background: var(--mint-light);
        background-image: radial-gradient(circle at 20% 20%, rgba(159, 203, 192, 0.1) 0%, transparent 50%), radial-gradient(circle at 80% 80%, rgba(245, 245, 245, 0.2) 0%, transparent 50%);
    }

    .form-label {
        color: var(--primary-black);
        font-weight: 600;
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .profile-page .form-control {
        border: 2px solid var(--teal-green);
        border-radius: 12px;
        padding: 1rem 1.25rem;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: rgba(255, 255, 255, 0.9);
        color: var(--primary-black);
        margin-bottom: 0.5rem;
    }

    .form-control:focus {
        border-color: var(--primary-black);
        box-shadow: 0 0 0 0.2rem rgba(159, 203, 192, 0.25);
        background: rgba(255, 255, 255, 1);
        outline: none;
    }

    .form-control::placeholder {
        color: #888;
        opacity: 1;
    }

    .gender-section {
        display: flex;
        gap: 1rem;
        margin-top: 0.5rem;
    }

    .form-check {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: white;
        padding: 0.75rem;
        border-radius: 8px;
        margin-bottom: 0.5rem;
        border: 2px solid var(--teal-green);
        transition: all 0.3s ease;
    }

        .form-check:hover {
            border-color: var(--primary-black);
            box-shadow: 0 2px 8px rgba(159, 203, 192, 0.2);
        }

    .form-check-input {
        width: 1.25rem;
        height: 1.25rem;
        border: 2px solid var(--teal-green);
        border-radius: 50%;
        background: var(--white);
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .form-check-input:checked {
            background: var(--teal-green);
            border-color: var(--teal-green);
        }

        .form-check-input:focus {
            box-shadow: 0 0 0 0.2rem rgba(159, 203, 192, 0.25);
        }

    .form-check-label {
        color: var(--primary-black);
        font-weight: 500;
        cursor: pointer;
    }

    .profile-page .btn-update {
        background: linear-gradient(135deg, var(--teal-green) 0%, #7fb3d3 100%);
        border: none;
        border-radius: 12px;
        padding: 1rem 2rem;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--white);
        width: 100%;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(159, 203, 192, 0.3);
        position: relative;
        overflow: hidden;
    }

    .btn-update::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
        transition: left 0.5s;
    }

    .btn-update:hover::before {
        left: 100%;
    }

    .btn-update:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(159, 203, 192, 0.5);
        background: linear-gradient(135deg, #8BC1B8 0%, #6fa8c8 100%);
        color: var(--white);
    }

    .btn-update:active {
        transform: translateY(0);
    }

    .alert-success-custom {
        justify-content: center;
        background: rgba(40, 167, 69, 0.1);
        border: 1px solid rgba(40, 167, 69, 0.3);
        color: var(--success-green);
        border-radius: 12px;
        padding: 1rem;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
        animation: slideInDown 0.5s ease-out;
    }

    .alert-danger-custom {
        background: rgba(248, 113, 113, 0.1);
        border: 1px solid rgba(248, 113, 113, 0.3);
        color: #dc2626;
        border-radius: 12px;
        padding: 1rem;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
        animation: slideInDown 0.5s ease-out;
    }

    @@keyframes slideInDown {
        from {
            transform: translateY(-20px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    .text-danger {
        color: var(--danger-red);
        display: block;
    }

    .row {
        margin: 0 -0.5rem;
    }

    .col-md-6, .col-md-12 {
        padding: 0 0.5rem;
    }

    .d-grid {
        display: grid;
    }

    .g-3 {
        --bs-gutter-x: 1rem;
        --bs-gutter-y: 1rem;
    }

    .section-title {
        font-size: 1.3rem;
        font-weight: 600;
        color: var(--primary-black);
        position: relative;
        padding-left: 1rem;
    }

        .section-title::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 4px;
            background: linear-gradient(135deg, var(--teal-green) 0%, #7fb3d3 100%);
            border-radius: 2px;
        }

    .form-section {
        background: rgba(255, 255, 255, 0.6);
        padding: 2rem;
        border-radius: 15px;
        margin-bottom: 2rem;
        border: 1px solid rgba(159, 203, 192, 0.2);
        backdrop-filter: blur(10px);
    }

    /* Responsive design */
    @@media (max-width: 768px) {
        .container {
            padding: 1rem;
        }

        .profile-container {
            border-radius: 15px;
        }

        .profile-title {
            font-size: 2rem;
        }

        .content-section {
            padding: 1.5rem;
        }

        .col-md-6, .col-md-12 {
            width: 100%;
        }

        .gender-section {
            flex-direction: column;
            gap: 0.5rem;
        }

        .avatar-preview {
            width: 100px;
            height: 100px;
        }

        .form-section {
            padding: 1.5rem;
        }
    }

    /* Loading animation for button */
    .btn-update.loading {
        pointer-events: none;
        opacity: 0.8;
    }

        .btn-update.loading::after {
            content: '';
            position: absolute;
            width: 20px;
            height: 20px;
            border: 2px solid transparent;
            border-top: 2px solid var(--white);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

    @@keyframes spin {
        0% {
            transform: translate(-50%, -50%) rotate(0deg);
        }

        100% {
            transform: translate(-50%, -50%) rotate(360deg);
        }
    }
</style>

<div class="container profile-page">
    <div class="profile-container">
        <div class="header-section">
            <h1 class="profile-title">
                <i class="fas fa-user-edit me-2"></i>
                Thông tin tài khoản
            </h1>

            <div class="avatar-section">
                <div class="d-flex align-items-center justify-content-center flex-column flex-md-row">
                    <img id="avatarPreview"
                         src="/images/default-avatar.jpg"
                         alt="Avatar"
                         class="rounded-circle me-md-3 avatar-preview">

                    <div class="avatar-info text-center text-md-start mt-3 mt-md-0">
                        <h5>@Model.Username</h5>
                        <p>@Model.FullName</p>
                        <button type="button" class="btn btn-change-avatar">
                            <i class="fa-solid fa-camera me-1"></i> Thay ảnh đại diện
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="content-section">
            @if (@TempData["Success"] != null)
            {
                <div class="alert-success-custom align-items-center">
                    <i class="fas fa-check-circle me-2"></i>
                    @TempData["Success"]
                </div>
            }

            @if (!ViewData.ModelState.IsValid)
            {
            <div class="alert-danger-custom justify-content-center">
                <i class="fas fa-exclamation-triangle me-2"></i>
                @Html.Raw(string.Join("<br/>", ViewData.ModelState.Values
                                .SelectMany(v => v.Errors)
                                .Select(e => e.ErrorMessage)))
            </div>
                        }

            <form method="post" enctype="multipart/form-data" novalidate id="profileForm">
                <input type="hidden" asp-for="Id" />

                <div class="form-section">
                    <h3 class="section-title">Thông tin cá nhân</h3>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">
                                <i class="fas fa-id-card"></i>
                                Họ và tên
                            </label>
                            <input asp-for="FullName" class="form-control" placeholder="Nhập họ và tên" />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">
                                <i class="fas fa-user"></i>
                                Tên tài khoản
                            </label>
                            <input asp-for="Username" class="form-control" placeholder="Nhập tên tài khoản" />
                            <span asp-validation-for="Username" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">
                                <i class="fas fa-calendar-alt"></i>
                                Ngày sinh
                            </label>
                            <input asp-for="BirthDate" type="date" class="form-control" />
                            <span asp-validation-for="BirthDate" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">
                                <i class="fas fa-venus-mars"></i>
                                Giới tính
                            </label>
                            <div class="gender-section d-flex gap-3">
                                <label class="box-radio flex-fill text-center">
                                    <input asp-for="Gender" type="radio" value="Nam" />
                                    <span>Nam</span>
                                </label>
                                <label class="box-radio flex-fill text-center">
                                    <input asp-for="Gender" type="radio" value="Nữ" />
                                    <span>Nữ</span>
                                </label>
                                <label class="box-radio flex-fill text-center">
                                    <input asp-for="Gender" type="radio" value="Khác" />
                                    <span>Khác</span>
                                </label>
                            </div>
                            <span asp-validation-for="Gender" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="form-section">
                    <h3 class="section-title">Thông tin liên hệ</h3>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">
                                <i class="fas fa-envelope"></i>
                                Email
                            </label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="Nhập email" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">
                                <i class="fas fa-phone"></i>
                                Số điện thoại
                            </label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="Nhập số điện thoại" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">
                                <i class="fas fa-id-card-alt"></i>
                                Số CCCD
                            </label>
                            <input asp-for="IdCard" class="form-control" placeholder="Nhập số căn cước" />
                            <span asp-validation-for="IdCard" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">
                                <i class="fas fa-map-marker-alt"></i>
                                Địa chỉ
                            </label>
                            <input asp-for="Address" class="form-control" placeholder="Nhập địa chỉ" />
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="d-grid" style="margin-top: 0.5rem;">
                    <button type="submit" class="btn btn-update" id="updateBtn">
                        <i class="fas fa-save me-2"></i>
                        Cập nhật thông tin
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const profileForm = document.getElementById('profileForm');
            const updateBtn = document.getElementById('updateBtn');

            // Add loading state to button on form submit
            profileForm.addEventListener('submit', function() {
                updateBtn.classList.add('loading');
                updateBtn.innerHTML = '<span>Đang cập nhật...</span>';
            });

            // Add focus effects to inputs
            const inputs = document.querySelectorAll('.form-control');
            inputs.forEach(input => {
                input.addEventListener('focus', function() {
                    this.style.borderColor = 'var(--primary-black)';
                });

                input.addEventListener('blur', function() {
                    this.style.borderColor = 'var(--teal-green)';
                });
            });

            // Auto-hide alerts
            const successAlert = document.querySelector('.alert-success-custom');
            const errorAlert = document.querySelector('.alert-danger-custom');

            if (successAlert) {
                setTimeout(() => {
                    successAlert.style.transition = "opacity 0.5s ease";
                    successAlert.style.opacity = "0";
                    setTimeout(() => {
                        successAlert.remove();
                    }, 500);
                }, 5000);
            }

            if (errorAlert) {
                setTimeout(() => {
                    errorAlert.style.transition = "opacity 0.5s ease";
                    errorAlert.style.opacity = "0";
                    setTimeout(() => {
                        errorAlert.remove();
                    }, 500);
                }, 5000);
            }

            // Radio button styling
            const radioButtons = document.querySelectorAll('input[type="radio"]');
            radioButtons.forEach(radio => {
                radio.addEventListener('change', function() {
                    // Remove active state from all radio buttons with same name
                    const sameNameRadios = document.querySelectorAll(`input[name="${this.name}"]`);
                    sameNameRadios.forEach(r => {
                        r.parentElement.style.borderColor = 'var(--teal-green)';
                    });

                    // Add active state to selected radio
                    if (this.checked) {
                        this.parentElement.style.borderColor = 'var(--primary-black)';
                    }
                });
            });
        });

        // Avatar preview functionality
        document.querySelector('.btn-change-avatar').addEventListener('click', function() {
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = 'image/*';
            input.onchange = function(e) {
                const file = e.target.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        document.getElementById('avatarPreview').src = e.target.result;
                    }
                    reader.readAsDataURL(file);
                }
            }
            input.click();
        });
    </script>
}