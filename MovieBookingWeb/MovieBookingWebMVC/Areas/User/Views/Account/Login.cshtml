@model MovieBookingWebMVC.Areas.User.Models.ViewModel.LoginViewModel
@{
    ViewBag.Title = "Đăng nhập";
}

<style>
    /* Custom styles for Login page */
    .login-container {
        background: linear-gradient(135deg, #2193b0 0%, #6dd5ed 100%);
        border-radius: 15px;
        padding: 2rem;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        max-width: 500px;
        margin: 3rem auto;
    }

    .login-title {
        color: #000000;
        font-weight: bold;
        text-align: center;
        margin-bottom: 1.5rem;
        font-size: 2rem;
    }

    .login-subtitle {
        color: #000000;
        text-align: center;
        margin-bottom: 2rem;
        font-size: 0.95rem;
    }

    .form-label {
        color: #000000;
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    .form-control {
        border: 2px solid #9FCBC0;
        border-radius: 8px;
        padding: 0.75rem;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            border-color: #9FCBC0;
            box-shadow: 0 0 0 0.2rem rgba(159, 203, 192, 0.25);
        }

        .form-control:hover {
            border-color: #9FCBC0;
            background-color: #F5F5F5;
        }

    .btn-login {
        background: linear-gradient(135deg, #2193b0 0%, #6dd5ed 100%);
        border: none;
        border-radius: 8px;
        padding: 0.75rem;
        font-size: 1.1rem;
        font-weight: 600;
        color: #000000;
        transition: all 0.3s ease;
        width: 100%;
    }

        .btn-login:hover {
            background-color: #F5F5F5;
            border: 2px solid #9FCBC0;
            color: #000000;
            transform: translateY(-2px);
        }

    .register-link {
        color: #9FCBC0;
        text-decoration: none;
        font-weight: 600;
        transition: color 0.3s ease;
    }

        .register-link:hover {
            color: #000000;
            text-decoration: underline;
        }

    .alert-custom {
        background-color: #F5F5F5;
        border: 2px solid #9FCBC0;
        border-radius: 8px;
        color: #000000;
        padding: 1rem;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
    }

    .text-danger {
        color: #dc3545 !important;
        font-size: 0.85rem;
        margin-top: 0.25rem;
    }

    .page-background {
        background-color: #F5F5F5;
        min-height: 100vh;
        padding: 2rem 0;
    }

    /* Responsive design */
    @@media (max-width: 768px) {
        .login-container

    {
        margin: 1rem;
        padding: 1.5rem;
        max-width: 95%;
    }

    .login-title {
        font-size: 1.75rem;
    }

    .login-subtitle {
        font-size: 0.9rem;
    }

    }
</style>

<div class="page-background">
    <div class="container">
        <div class="login-container">
            <h2 class="login-title">Đăng nhập</h2>

            <div class="login-subtitle">
                <p class="mb-2">Đăng nhập vào tài khoản của bạn để tiếp tục sử dụng dịch vụ</p>
                <p class="fw-bold">
                    Chưa có tài khoản?
                    <a asp-area="User" asp-controller="Account" asp-action="Register"
                       class="register-link">
                        Tạo tài khoản
                    </a>
                </p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert-custom text-center">
                    ❌ @Html.Raw(string.Join("<br/>", ViewData.ModelState.Values
                                    .SelectMany(v => v.Errors)
                                    .Select(e => e.ErrorMessage)))
            </div>
                        }

            <form method="post" asp-action="Login">
                <div class="mb-3">
                    <label class="form-label">E-mail/Tên tài khoản</label>
                    <input asp-for="UsernameOrEmail" class="form-control" placeholder="Nhập email hoặc tên tài khoản" />
                    <span class="text-danger" asp-validation-for="UsernameOrEmail"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label">Mật khẩu</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Nhập mật khẩu" />
                    <span class="text-danger" asp-validation-for="Password"></span>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-login">Đăng nhập</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
