@model MovieBookingWebMVC.Areas.User.Models.ViewModel.LoginViewModel
@{
    ViewBag.Title = "Đăng nhập";
}

<style>
    :root {
        --primary-black: #000000;
        --mint-light: #CCFFE4;
        --teal-green: #9FCBC0;
        --light-gray: #F5F5F5;
        --white: #ffffff;
        --success-green: #28a745;
        --warning-orange: #ffc107;
        --danger-red: #dc3545;
        --shadow-light: rgba(0, 0, 0, 0.1);
        --shadow-medium: rgba(0, 0, 0, 0.15);
    }

    body {
        background: linear-gradient(135deg, #2193b0 0%, #6dd5ed 100%);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        margin: 0;
        padding: 0;
    }

    .container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        padding: 2rem;
        z-index: 1;
    }

    .login-container {
        background: var(--white);
        border-radius: 20px;
        box-shadow: 0 10px 30px var(--shadow-light);
        max-width: 600px;
        width: 100%;
        overflow: hidden;
        animation: slideInUp 0.6s ease-out;
    }

    @@keyframes slideInUp {
        from {
            transform: translateY(30px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    .header-section {
        background: linear-gradient(135deg, var(--primary-black) 0%, #333333 100%);
        color: var(--white);
        padding: 2rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .header-section::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(204, 255, 228, 0.1) 0%, transparent 70%);
            animation: rotate 20s linear infinite;
        }

    @@keyframes rotate {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    .login-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin: 0;
        position: relative;
        z-index: 1;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    }

    .content-section {
        padding-left: 2rem;
        padding-right: 2rem;
        padding-top: 1.5rem;
        padding-bottom: 2rem;
        background: var(--mint-light);
        background-image: radial-gradient(circle at 20% 20%, rgba(159, 203, 192, 0.1) 0%, transparent 50%), radial-gradient(circle at 80% 80%, rgba(245, 245, 245, 0.2) 0%, transparent 50%);
    }

    .login-subtitle {
        text-align: center;
        margin-bottom: 2rem;
        color: var(--primary-black);
    }

        .login-subtitle p {
            margin: 0.5rem 0;
            font-size: 1rem;
            line-height: 1.5;
        }

    .register-link {
        color: var(--primary-black);
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
        border-bottom: 2px solid transparent;
    }

        .register-link:hover {
            color: var(--teal-green);
            border-bottom-color: var(--teal-green);
            text-decoration: none;
        }

    .form-label {
        color: var(--primary-black);
        font-weight: 600;
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .login-page .form-control {
        border: 2px solid var(--teal-green);
        border-radius: 12px;
        padding: 1rem 1.25rem;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: rgba(255, 255, 255, 0.9);
        color: var(--primary-black);
        margin-bottom: 0.5rem;
    }

    .form-control:focus {
        border-color: var(--primary-black);
        box-shadow: 0 0 0 0.2rem rgba(159, 203, 192, 0.25);
        background: rgba(255, 255, 255, 1);
        outline: none;
    }

    .form-control::placeholder {
        color: #888;
        opacity: 1;
    }

    .login-page .btn-login {
        background: linear-gradient(135deg, var(--teal-green) 0%, #7fb3d3 100%);
        border: none;
        border-radius: 12px;
        padding: 1rem 2rem;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--white);
        width: 100%;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(159, 203, 192, 0.3);
        position: relative;
        overflow: hidden;
    }

    .btn-login::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
        transition: left 0.5s;
    }

    .btn-login:hover::before {
        left: 100%;
    }

    .btn-login:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(159, 203, 192, 0.5);
        background: linear-gradient(135deg, #8BC1B8 0%, #6fa8c8 100%);
        color: var(--white);
    }

    .btn-login:active {
        transform: translateY(0);
    }

    .alert-custom {
        background: rgba(248, 113, 113, 0.1);
        border: 1px solid rgba(248, 113, 113, 0.3);
        color: #dc2626;
        border-radius: 12px;
        padding: 1rem;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
        animation: slideInDown 0.5s ease-out;
    }

    @@keyframes slideInDown {
        from {
            transform: translateY(-20px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    .text-danger {
        color: var(--danger-red);
        margin-top: 0.25rem;
        display: block;
    }

    .mb-3 {
        margin-bottom: 1.5rem;
    }

    .mb-4 {
        margin-bottom: 2rem;
    }

    .d-grid {
        display: grid;
    }

    .text-center {
        text-align: center;
    }

    /* Input icons */
    .input-group {
        position: relative;
    }

    .input-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--teal-green);
        z-index: 2;
    }

    .form-control.with-icon {
        padding-left: 3rem;
    }

    /* Responsive design */
    @@media (max-width: 768px) {
        .container {
            padding: 1rem;
        }

        .login-container {
            border-radius: 15px;
        }

        .login-title {
            font-size: 2rem;
        }

        .content-section {
            padding: 1.5rem;
        }
    }

    /* Loading animation for button */
    .btn-login.loading {
        pointer-events: none;
        opacity: 0.8;
    }

        .btn-login.loading::after {
            content: '';
            position: absolute;
            width: 20px;
            height: 20px;
            border: 2px solid transparent;
            border-top: 2px solid var(--white);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

    @@keyframes spin {
        0% {
            transform: translate(-50%, -50%) rotate(0deg);
        }

        100% {
            transform: translate(-50%, -50%) rotate(360deg);
        }
    }
</style>

<div class="container login-page">
    <div class="login-container">
        <div class="header-section">
            <h2 class="login-title">
                <i class="fas fa-sign-in-alt me-2"></i>
                Đăng nhập
            </h2>
        </div>

        <div class="content-section">
            <div class="login-subtitle">
                <strong>Đăng nhập vào tài khoản của bạn để tiếp tục sử dụng dịch vụ</strong>
                <p>
                    Chưa có tài khoản?
                    <a asp-area="User" asp-controller="Account" asp-action="Register" class="register-link">
                        Tạo tài khoản
                    </a>
                </p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
            <div class="alert-custom text-center">
                <i class="fas fa-exclamation-triangle me-2"></i>
                @Html.Raw(string.Join("<br/>", ViewData.ModelState.Values
                                .SelectMany(v => v.Errors)
                                .Select(e => e.ErrorMessage)))
            </div>
                        }

            <form method="post" asp-action="Login" id="loginForm">
                <div class="mb-3">
                    <label class="form-label">
                        <i class="fas fa-user"></i>
                        E-mail/Tên tài khoản
                    </label>
                    <div class="input-group">
                        <input asp-for="UsernameOrEmail" class="form-control with-icon"
                               placeholder="Nhập email hoặc tên tài khoản" />
                    </div>
                    <span class="text-danger" asp-validation-for="UsernameOrEmail"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label">
                        <i class="fas fa-lock"></i>
                        Mật khẩu
                    </label>
                    <div class="input-group">
                        <input asp-for="Password" type="password" class="form-control with-icon"
                               placeholder="Nhập mật khẩu" />
                    </div>
                    <span class="text-danger" asp-validation-for="Password"></span>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-login" id="loginBtn">
                        <i class="fas fa-sign-in-alt me-2"></i>
                        Đăng nhập
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const loginForm = document.getElementById('loginForm');
        const loginBtn = document.getElementById('loginBtn');

        // Add loading state to button on form submit
        loginForm.addEventListener('submit', function() {
            loginBtn.classList.add('loading');
            loginBtn.innerHTML = '<span>Đang đăng nhập...</span>';
        });

        // Add focus effects to inputs
        const inputs = document.querySelectorAll('.form-control');
        inputs.forEach(input => {
            input.addEventListener('focus', function() {
                this.parentElement.querySelector('.input-icon').style.color = 'var(--primary-black)';
            });

            input.addEventListener('blur', function() {
                this.parentElement.querySelector('.input-icon').style.color = 'var(--teal-green)';
            });
        });

        // Auto-hide error alerts
        const errorAlert = document.querySelector('.alert-custom');
        if (errorAlert) {
            setTimeout(() => {
                errorAlert.style.transition = "opacity 0.5s ease";
                errorAlert.style.opacity = "0";
                setTimeout(() => {
                    errorAlert.remove();
                }, 500);
            }, 5000);
        }
    });
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}