@{
    ViewData["Title"] = "Truy cập bị từ chối";
    ViewBag.ShowUserSidebar = false;
}

<style>
    :root {
        --primary-black: #000000;
        --mint-light: #CCFFE4;
        --teal-green: #9FCBC0;
        --light-gray: #F5F5F5;
        --white: #ffffff;
        --danger-red: #dc3545;
        --danger-light: #f8d7da;
        --warning-orange: #ffc107;
        --shadow-light: rgba(0, 0, 0, 0.1);
        --shadow-medium: rgba(0, 0, 0, 0.15);
        --shadow-heavy: rgba(0, 0, 0, 0.25);
    }

    body {
        background: linear-gradient(135deg, #2193b0 0%, #6dd5ed 100%);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        min-height: 100vh;
        margin: 0;
        padding: 0;
        overflow-x: hidden;
    }

    .access-denied-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        padding: 2rem;
        position: relative;
    }

        /* Animated background elements */
        .access-denied-container::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(circle at 20% 20%, rgba(220, 53, 69, 0.1) 0%, transparent 50%), radial-gradient(circle at 80% 80%, rgba(159, 203, 192, 0.1) 0%, transparent 50%), radial-gradient(circle at 40% 60%, rgba(255, 255, 255, 0.05) 0%, transparent 50%);
            animation: backgroundMove 15s ease-in-out infinite;
        }

    @@keyframes backgroundMove {
        0%, 100% {
            transform: translateX(0) translateY(0);
        }

        25% {
            transform: translateX(-20px) translateY(-10px);
        }

        50% {
            transform: translateX(20px) translateY(10px);
        }

        75% {
            transform: translateX(-10px) translateY(20px);
        }
    }

    .denied-card {
        background: var(--white);
        border-radius: 25px;
        box-shadow: 0 20px 60px var(--shadow-heavy);
        max-width: 600px;
        width: 100%;
        overflow: hidden;
        position: relative;
        z-index: 1;
        animation: slideInScale 0.8s ease-out;
    }

    @@keyframes slideInScale {
        from {
            transform: translateY(50px) scale(0.9);
            opacity: 0;
        }

        to {
            transform: translateY(0) scale(1);
            opacity: 1;
        }
    }

    .denied-header {
        background: linear-gradient(135deg, var(--danger-red) 0%, #e74c3c 100%);
        color: var(--white);
        padding: 1rem 2rem 2rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .denied-header::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
            animation: headerRotate 20s linear infinite;
        }

    @@keyframes headerRotate {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    .denied-icon {
        font-size: 4.5rem;
        position: relative;
        z-index: 1;
        animation: iconPulse 2s ease-in-out infinite;
        text-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
    }

    @@keyframes iconPulse {
        0%, 100% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.1);
        }
    }

    .denied-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin: 0;
        position: relative;
        z-index: 1;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    }

    .denied-content {
        padding: 2.5rem;
        background: var(--mint-light);
        background-image: radial-gradient(circle at 30% 30%, rgba(159, 203, 192, 0.1) 0%, transparent 50%), radial-gradient(circle at 70% 70%, rgba(245, 245, 245, 0.2) 0%, transparent 50%);
        text-align: center;
    }

    .denied-message {
        font-size: 1.1rem;
        line-height: 1.6;
        color: var(--primary-black);
        margin-bottom: 2rem;
        opacity: 0.9;
    }

    .denied-code {
        background: rgba(220, 53, 69, 0.1);
        border: 2px solid rgba(220, 53, 69, 0.2);
        border-radius: 15px;
        padding: 1rem;
        margin-bottom: 2rem;
        font-family: 'Courier New', monospace;
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--danger-red);
        letter-spacing: 2px;
        box-shadow: 0 4px 15px rgba(220, 53, 69, 0.1);
    }

    .action-buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-home {
        background: linear-gradient(135deg, var(--teal-green) 0%, #7fb3d3 100%);
        border: none;
        border-radius: 12px;
        padding: 1rem 2rem;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--white);
        text-decoration: none;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(159, 203, 192, 0.3);
        position: relative;
        overflow: hidden;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

        .btn-home::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            transition: left 0.5s;
        }

        .btn-home:hover::before {
            left: 100%;
        }

        .btn-home:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(159, 203, 192, 0.5);
            background: linear-gradient(135deg, #8BC1B8 0%, #6fa8c8 100%);
            color: var(--white);
            text-decoration: none;
        }

    .btn-login {
        background: linear-gradient(135deg, var(--primary-black) 0%, #333333 100%);
        border: none;
        border-radius: 12px;
        padding: 1rem 2rem;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--white);
        text-decoration: none;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
        position: relative;
        overflow: hidden;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

        .btn-login::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            transition: left 0.5s;
        }

        .btn-login:hover::before {
            left: 100%;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.5);
            background: linear-gradient(135deg, #333333 0%, #555555 100%);
            color: var(--white);
            text-decoration: none;
        }

    .floating-elements {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        pointer-events: none;
        overflow: hidden;
    }

    .floating-element {
        position: absolute;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
        animation: float 6s ease-in-out infinite;
    }

        .floating-element:nth-child(1) {
            width: 80px;
            height: 80px;
            top: 10%;
            left: 10%;
            animation-delay: 0s;
        }

        .floating-element:nth-child(2) {
            width: 60px;
            height: 60px;
            top: 70%;
            right: 10%;
            animation-delay: 2s;
        }

        .floating-element:nth-child(3) {
            width: 100px;
            height: 100px;
            bottom: 20%;
            left: 20%;
            animation-delay: 4s;
        }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0px) rotate(0deg);
        }

        50% {
            transform: translateY(-20px) rotate(180deg);
        }
    }

    .security-tips {
        background: rgba(255, 255, 255, 0.8);
        border: 2px solid var(--teal-green);
        border-radius: 12px;
        padding: 1.5rem;
        margin-top: 2rem;
        text-align: left;
    }

    .security-tips-title {
        font-weight: 600;
        color: var(--primary-black);
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .security-tips ul {
        margin: 0;
        padding-left: 1.5rem;
        color: var(--primary-black);
    }

    .security-tips li {
        margin-bottom: 0.5rem;
        line-height: 1.4;
    }

    /* Responsive design */
    @@media (max-width: 768px) {
        .access-denied-container {
            padding: 1rem;
        }

        .denied-card {
            border-radius: 20px;
        }

        .denied-header {
            padding: 2rem 1.5rem 1.5rem;
        }

        .denied-title {
            font-size: 2rem;
        }

        .denied-icon {
            font-size: 3.5rem;
        }

        .denied-content {
            padding: 2rem 1.5rem;
        }

        .action-buttons {
            flex-direction: column;
            align-items: center;
        }

        .btn-home, .btn-login {
            width: 100%;
            max-width: 300px;
        }
    }

    @@media (max-width: 480px) {
        .denied-header {
            padding: 1.5rem 1rem;
        }

        .denied-content {
            padding: 1.5rem 1rem;
        }

        .denied-title {
            font-size: 1.75rem;
        }

        .denied-icon {
            font-size: 3rem;
        }
    }
</style>

<div class="access-denied-container">
    <div class="floating-elements">
        <div class="floating-element"></div>
        <div class="floating-element"></div>
        <div class="floating-element"></div>
    </div>

    <div class="denied-card">
        <div class="denied-header">
            <div class="denied-icon">
                <i class="fas fa-shield-alt"></i>
            </div>
            <h1 class="denied-title">Truy cập bị từ chối</h1>
        </div>

        <div class="denied-content">
            <div class="denied-code">
                ERROR 403
            </div>

            <p class="denied-message">
                Bạn không có quyền truy cập vào trang này. Điều này có thể xảy ra do:
                <br><br>
                <strong>• Bạn chưa đăng nhập</strong><br>
                <strong>• Tài khoản không có quyền truy cập</strong><br>
                <strong>• Phiên đăng nhập đã hết hạn</strong>
            </p>

            <div class="action-buttons">
                <a href="~/" class="btn-home">
                    <i class="fas fa-home"></i>
                    Quay lại trang chủ
                </a>
                <a href="~/User/Account/Login" class="btn-login">
                    <i class="fas fa-sign-in-alt"></i>
                    Đăng nhập
                </a>
            </div>

            <div class="security-tips">
                <div class="security-tips-title">
                    <i class="fas fa-lightbulb" style="color: var(--warning-orange);"></i>
                    Gợi ý bảo mật:
                </div>
                <ul>
                    <li>Đăng nhập với tài khoản có quyền truy cập phù hợp</li>
                    <li>Kiểm tra xem phiên đăng nhập có còn hiệu lực không</li>
                    <li>Liên hệ quản trị viên nếu bạn cho rằng đây là lỗi</li>
                    <li>Không chia sẻ thông tin đăng nhập với người khác</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Add click ripple effect to buttons
        const buttons = document.querySelectorAll('.btn-home, .btn-login');

        buttons.forEach(button => {
            button.addEventListener('click', function(e) {
                let ripple = document.createElement('div');
                ripple.style.position = 'absolute';
                ripple.style.borderRadius = '50%';
                ripple.style.background = 'rgba(255, 255, 255, 0.3)';
                ripple.style.transform = 'scale(0)';
                ripple.style.animation = 'ripple 0.6s linear';
                ripple.style.left = (e.clientX - e.target.offsetLeft) + 'px';
                ripple.style.top = (e.clientY - e.target.offsetTop) + 'px';

                this.appendChild(ripple);

                setTimeout(() => {
                    ripple.remove();
                }, 600);
            });
        });

        // Add CSS for ripple animation
        const style = document.createElement('style');
        style.textContent = `
            @@keyframes ripple {
                to {
                    transform: scale(4);
                    opacity: 0;
                }
            }
        `;
        document.head.appendChild(style);

        // Add parallax effect to floating elements
        document.addEventListener('mousemove', function(e) {
            const floatingElements = document.querySelectorAll('.floating-element');
            const mouseX = e.clientX / window.innerWidth;
            const mouseY = e.clientY / window.innerHeight;

            floatingElements.forEach((element, index) => {
                const speed = (index + 1) * 0.5;
                const x = (mouseX - 0.5) * speed * 50;
                const y = (mouseY - 0.5) * speed * 50;

                element.style.transform = `translate(${x}px, ${y}px)`;
            });
        });
    });
</script>