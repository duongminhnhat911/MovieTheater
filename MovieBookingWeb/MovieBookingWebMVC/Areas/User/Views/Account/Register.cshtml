@model MovieBookingWebMVC.Areas.User.Models.ViewModel.RegisterViewModel
@{
    ViewBag.Title = "Đăng ký";
}

<style>
    /* Custom styles for Register page */
    .register-container {
        background: linear-gradient(135deg, #2193b0 0%, #6dd5ed 100%);
        border-radius: 15px;
        padding: 2rem;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        max-width: 800px;
        margin: 2rem auto;
    }

    .register-title {
        color: #000000;
        font-weight: bold;
        text-align: center;
        margin-bottom: 1.5rem;
        font-size: 2rem;
    }

    .register-subtitle {
        color: #000000;
        text-align: center;
        margin-bottom: 2rem;
        font-size: 0.95rem;
    }

    .form-label {
        color: #000000;
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    .form-control {
        border: 2px solid #9FCBC0;
        border-radius: 8px;
        padding: 0.75rem;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            border-color: #9FCBC0;
            box-shadow: 0 0 0 0.2rem rgba(159, 203, 192, 0.25);
        }

        .form-control:hover {
            border-color: #9FCBC0;
            background-color: #F5F5F5;
        }

    .btn-register {
        background: linear-gradient(135deg, #2193b0 0%, #6dd5ed 100%);
        border: none;
        border-radius: 8px;
        padding: 0.75rem;
        font-size: 1.1rem;
        font-weight: 600;
        color: #000000;
        transition: all 0.3s ease;
        width: 100%;
    }

        .btn-register:hover {
            background-color: #F5F5F5;
            border: 2px solid #9FCBC0;
            color: #000000;
            transform: translateY(-2px);
        }

    .login-link {
        color: #9FCBC0;
        text-decoration: none;
        font-weight: 600;
        transition: color 0.3s ease;
    }

        .login-link:hover {
            color: #000000;
            text-decoration: underline;
        }

    .alert-danger-custom {
        background-color: #F5F5F5;
        border: 2px solid #dc3545;
        border-radius: 8px;
        color: #000000;
        padding: 1rem;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
        text-align: center;
    }

    .text-danger {
        color: #dc3545 !important;
        font-size: 0.85rem;
        margin-top: 0.25rem;
    }

    .page-background {
        background-color: #F5F5F5;
        min-height: 100vh;
        padding: 2rem 0;
    }

    .gender-section {
        background-color: #F5F5F5;
        border-radius: 8px;
        padding: 1rem;
        border: 2px solid #9FCBC0;
        margin-top: 0.5rem;
    }

    .form-check-input {
        border: 2px solid #9FCBC0;
        margin-right: 0.5rem;
    }

        .form-check-input:checked {
            background-color: #9FCBC0;
            border-color: #9FCBC0;
        }

    .form-check-label {
        color: #000000;
        font-weight: 500;
        margin-left: 0.5rem;
    }

    .form-check {
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
    }

    .form-section {
        margin-bottom: 1.5rem;
    }

    .form-row {
        display: flex;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .form-col {
        flex: 1;
    }

    /* Responsive design */
    @@media (max-width: 768px) {
        .register-container

    {
        margin: 1rem;
        padding: 1.5rem;
        max-width: 95%;
    }

    .register-title {
        font-size: 1.75rem;
    }

    .register-subtitle {
        font-size: 0.9rem;
    }

    .form-row {
        flex-direction: column;
        gap: 0;
    }

    .col-md-6 {
        margin-bottom: 1rem;
    }

    }

    @@media (max-width: 576px) {
        .register-container

    {
        padding: 1rem;
    }

    .register-title {
        font-size: 1.5rem;
    }

    }
</style>

<div class="page-background">
    <div class="container">
        <div class="register-container">
            <h2 class="register-title">Đăng ký tài khoản</h2>

            <div class="register-subtitle">
                <p class="mb-2">Để có thể sử dụng các dịch vụ của chúng tôi, bạn phải có tài khoản</p>
                <p class="fw-bold">
                    Đã có tài khoản?
                    <a asp-area="User" asp-controller="Account" asp-action="Login" class="login-link">Đăng nhập</a>
                </p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert-danger-custom">
                    ❌ @Html.Raw(string.Join("<br/>", ViewData.ModelState.Values
                                    .SelectMany(v => v.Errors)
                                    .Select(e => e.ErrorMessage)))
            </div>
                        }

            <form asp-action="Register" method="post" novalidate>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Tên tài khoản</label>
                        <input asp-for="Username" class="form-control" placeholder="Nhập tên tài khoản" />
                        <span asp-validation-for="Username" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Họ và tên</label>
                        <input asp-for="FullName" class="form-control" placeholder="Nhập họ và tên" />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Mật khẩu</label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Nhập mật khẩu" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Xác nhận mật khẩu</label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Xác nhận mật khẩu" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Ngày sinh</label>
                        <input asp-for="BirthDate" type="date" class="form-control" />
                        <span asp-validation-for="BirthDate" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Giới tính</label>
                        <div class="gender-section">
                            <div class="form-check">
                                <input asp-for="Gender" class="form-check-input" type="radio" value="Nam" />
                                <label class="form-check-label">Nam</label>
                            </div>
                            <div class="form-check">
                                <input asp-for="Gender" class="form-check-input" type="radio" value="Nữ" />
                                <label class="form-check-label">Nữ</label>
                            </div>
                            <div class="form-check">
                                <input asp-for="Gender" class="form-check-input" type="radio" value="Khác" />
                                <label class="form-check-label">Khác</label>
                            </div>
                        </div>
                        <span asp-validation-for="Gender" class="text-danger"></span>
                    </div>
                    <div class="col-md-12">
                        <label class="form-label">Email</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="Nhập email" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Số CCCD</label>
                        <input asp-for="IdCard" class="form-control" placeholder="Nhập số căn cước công dân" />
                        <span asp-validation-for="IdCard" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Số điện thoại</label>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="Nhập số điện thoại" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>
                    <div class="col-md-12">
                        <label class="form-label">Địa chỉ nhà</label>
                        <input asp-for="Address" class="form-control" placeholder="Nhập địa chỉ" />
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-4 d-grid">
                    <button type="submit" class="btn btn-register">Tạo tài khoản</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
