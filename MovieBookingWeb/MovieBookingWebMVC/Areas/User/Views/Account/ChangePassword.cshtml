@model MovieBookingWebMVC.Areas.User.Models.ViewModel.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<style>
    /* Custom styles for Change Password page */
    .change-password-container {
        background: linear-gradient(135deg, #2193b0 0%, #6dd5ed 100%);
        border-radius: 15px;
        padding: 2rem;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        max-width: 500px;
        margin: 3rem auto;
    }

    .change-password-title {
        color: #000000;
        font-weight: bold;
        text-align: center;
        margin-bottom: 2rem;
        font-size: 2rem;
    }

    .form-label {
        color: #000000;
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    .form-control {
        border: 2px solid #9FCBC0;
        border-radius: 8px;
        padding: 0.75rem;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            border-color: #9FCBC0;
            box-shadow: 0 0 0 0.2rem rgba(159, 203, 192, 0.25);
        }

        .form-control:hover {
            border-color: #9FCBC0;
            background-color: #F5F5F5;
        }

    .btn-change-password {
        background: linear-gradient(135deg, #2193b0 0%, #6dd5ed 100%);
        border: none;
        border-radius: 8px;
        padding: 0.75rem 2rem;
        font-size: 1.1rem;
        font-weight: 600;
        color: #000000;
        transition: all 0.3s ease;
        width: 100%;
    }

        .btn-change-password:hover {
            background-color: #F5F5F5;
            border: 2px solid #9FCBC0;
            color: #000000;
            transform: translateY(-2px);
        }

    .alert-success-custom {
        background-color: #9FCBC0;
        border: 2px solid #9FCBC0;
        border-radius: 8px;
        color: #000000;
        padding: 1rem;
        margin-bottom: 1.5rem;
        font-size: 0.95rem;
        text-align: center;
        font-weight: 500;
    }

    .text-danger {
        color: #dc3545 !important;
        font-size: 0.85rem;
        margin-top: 0.25rem;
    }

    .page-background {
        background-color: #F5F5F5;
        min-height: 100vh;
        padding: 2rem 0;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .password-info {
        background-color: #F5F5F5;
        border: 2px solid #9FCBC0;
        border-radius: 8px;
        padding: 1rem;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
        color: #000000;
    }

    .password-info-title {
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: #000000;
    }

    .password-info ul {
        margin-bottom: 0;
        padding-left: 1.2rem;
    }

    .password-info li {
        margin-bottom: 0.25rem;
    }

    /* Icon styles */
    .form-icon {
        position: relative;
    }

        .form-icon i {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #9FCBC0;
            font-size: 1.1rem;
        }

    .form-control.with-icon {
        padding-right: 40px;
    }

    /* Responsive design */
    @@media (max-width: 768px) {
        .change-password-container

    {
        margin: 1rem;
        padding: 1.5rem;
        max-width: 95%;
    }

    .change-password-title {
        font-size: 1.75rem;
    }

    }

    @@media (max-width: 576px) {
        .change-password-container

    {
        padding: 1rem;
    }

    .change-password-title {
        font-size: 1.5rem;
    }

    }
</style>

<div class="page-background">
    <div class="container">
        <div class="change-password-container">
            <h2 class="change-password-title">Đổi mật khẩu</h2>

            @if (TempData["Success"] != null)
            {
                <div class="alert-success-custom">
                    <i class="fa-solid fa-check-circle" style="color: #000000; margin-right: 0.5rem;"></i>
                    @TempData["Success"]
                </div>
            }

            <div class="password-info">
                <div class="password-info-title">
                    <i class="fa-solid fa-info-circle" style="color: #9FCBC0; margin-right: 0.5rem;"></i>
                    Yêu cầu mật khẩu mới:
                </div>
                <ul>
                    <li>Tối thiểu 8 ký tự</li>
                    <li>Bao gồm chữ hoa và chữ thường</li>
                    <li>Có ít nhất 1 chữ số</li>
                    <li>Có ít nhất 1 ký tự đặc biệt</li>
                </ul>
            </div>

            <form asp-action="ChangePassword" method="post">
                <div class="form-group">
                    <label for="OldPassword" class="form-label">Mật khẩu hiện tại</label>
                    <div class="form-icon">
                        <input asp-for="OldPassword" class="form-control with-icon" type="password" placeholder="Nhập mật khẩu hiện tại" />
                        <i class="fa-solid fa-lock"></i>
                    </div>
                    <span asp-validation-for="OldPassword" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label for="NewPassword" class="form-label">Mật khẩu mới</label>
                    <div class="form-icon">
                        <input asp-for="NewPassword" class="form-control with-icon" type="password" placeholder="Nhập mật khẩu mới" />
                        <i class="fa-solid fa-key"></i>
                    </div>
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label for="ConfirmPassword" class="form-label">Xác nhận mật khẩu mới</label>
                    <div class="form-icon">
                        <input asp-for="ConfirmPassword" class="form-control with-icon" type="password" placeholder="Nhập lại mật khẩu mới" />
                        <i class="fa-solid fa-shield-halved"></i>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-change-password">
                        <i class="fa-solid fa-rotate-right" style="margin-right: 0.5rem;"></i>
                        Đổi mật khẩu
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

