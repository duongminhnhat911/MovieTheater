@model List<MovieBookingWebMVC.Areas.Movie.Models.ViewModel.FilmViewModel>
@{
    ViewData["Title"] = "Trang quản trị";
    int currentPage = ViewBag.CurrentPage as int? ?? 1;
    int totalPages = ViewBag.TotalPages as int? ?? 1;
}

<div class="container">
    <div class="flex-grow-1 mt-5">
        <h2 class="text-center fw-bold mb-4">Danh sách phim</h2>

        @if (TempData["Success"] != null)
        {
            <div id="alertSuccess" class="alert alert-success text-center custom-alert mb-4"
                 style="width: 280px; margin: 0 auto; font-size: 0.9rem;">
                <i class="fa-solid fa-check" style="color: green;"></i> @TempData["Success"]
            </div>
        }

        <a asp-area="Movie" asp-controller="Movie" asp-action="AddMovie" class="btn btn-primary mb-3">
            <i class="fa-solid fa-plus"></i> Thêm phim mới
        </a>

        <table class="table table-bordered table-hover table-striped">
            <thead class="table-dark text-center align-middle">
                <tr>
                    <th style="width: 3%;">ID</th>
                    <th style="width: 22%;">Tựa phim</th>
                    <th style="width: 20%;">Thể loại</th>
                    <th style="width: 10%;">Thời lượng</th>
                    <th style="width: 12%;">Khởi chiếu</th>
                    <th style="width: 10%;">Trạng thái</th>
                    <th style="width: 10%;">Tạo bởi</th>
                    <th style="width: 10%;">Sửa bởi</th>
                    <th style="width: 13%;">Tác vụ</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var film in Model)
                {
                    <tr class="align-middle">
                        <td class="text-center fw-bold">@film.Id</td>
                        <td>@film.Title</td>
                        <td>@(film.Genres != null ? string.Join(", ", film.Genres) : "-")</td>
                        <td class="text-center">@film.Duration</td>
                        <td class="text-center">@film.ReleaseDate?.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">
                            @{
                                var statusDisplay = film.Status switch
                                {
                                    "Active" => "Đang chiếu",
                                    "SoldOut" => "Hết vé",
                                    "Deleted" => "Đã xóa",
                                    _ => "Không xác định"
                                };
                            }
                            @statusDisplay
                        </td>
                        <td class="text-center">@film.CreatedByUsername</td>
                        <td class="text-center">@film.EditedByUsername</td>
                        <td class="text-center">
                            <a asp-area="Movie" asp-controller="Movie" asp-action="EditMovie" asp-route-id="@film.Id" class="btn btn-sm btn-warning">
                                <i class="fas fa-edit"></i> Sửa
                            </a>
                            <form asp-area="Movie" asp-controller="Movie" asp-action="DeleteMovie"
                                  asp-route-id="@film.Id" method="post" style="display:inline;"
                                  onsubmit="return confirm('Bạn có muốn xoá phim này không?');">
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="fas fa-trash-alt"></i> Xoá
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <nav aria-label="Pagination" class="mt-3">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" asp-action="ViewMovie" asp-route-page="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    </div>
</div>
