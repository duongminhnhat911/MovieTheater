@model MovieBookingWebMVC.Areas.Movie.Models.ViewModel.FilmViewModel
@using MovieBookingWebMVC.Areas.Movie.Helper
@using System.Text.Json

@{
    ViewBag.Title = "Thêm phim mới";
    var allGenres = new List<string> { "Hành động", "Hài", "Hoạt hình", "Tâm lý",
        "Khoa học viễn tưởng", "Phiêu lưu", "Kinh dị", "Tình cảm", "Chiến tranh" };
    var allFormats = new List<string> { "2D", "3D" };
    var selectedGenres = Model?.Genres ?? new List<string>();
    var selectedFormats = Model?.Format ?? new List<string>();
    var columnCount = 2;
    var itemsPerColumn = 5;
    var formatColumnCount = 2;
    var formatItemsPerColumn = (int)Math.Ceiling((double)allFormats.Count / formatColumnCount);
    var columns = new List<List<string>>();
    var formatColumns = new List<List<string>>();

    for (int i = 0; i < columnCount; i++)
    {
        columns.Add(allGenres.Skip(i * itemsPerColumn).Take(itemsPerColumn).ToList());
    }
    for (int i = 0; i < formatColumnCount; i++)
    {
        formatColumns.Add(allFormats.Skip(i * formatItemsPerColumn).Take(formatItemsPerColumn).ToList());
    }
}

<style>
    .add-movie-container {
        min-height: 100vh;
        background: linear-gradient(135deg, #2193b0 0%, #6dd5ed 100%);
        padding: 2rem 0;
    }

    .add-movie-card {
        background: #CCFFE4;
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
        padding: 2rem;
        width: 85%;
        max-width: 1200px;
        margin: 0 auto;
        border: 1px solid rgba(0, 0, 0, 0.1);
    }

    .add-movie-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: #000000;
        text-align: center;
        margin-bottom: 0.5rem;
    }

    .add-movie-subtitle {
        color: #000000;
        text-align: center;
        margin-bottom: 2rem;
        font-size: 1rem;
        line-height: 1.5;
    }

    .form-floating {
        margin-bottom: 1.5rem;
    }

        .form-floating > .form-control,
        .form-floating > .form-select {
            border: 2px solid #9FCBC0;
            border-radius: 12px;
            padding: 0.625rem;
            font-size: 1rem;
            transition: all 0.3s ease;
            background: rgba(255, 255, 255, 0.9);
            min-height: calc(3.5rem + 2px);
            color: #000000;
        }

            .form-floating > .form-control:focus,
            .form-floating > .form-select:focus {
                border-color: #000000;
                box-shadow: 0 0 0 0.2rem rgba(159, 203, 192, 0.25);
                background: rgba(255, 255, 255, 1);
            }

            .form-floating > .form-control-plaintext:focus,
            .form-floating > .form-control-plaintext:not(:placeholder-shown),
            .form-floating > .form-control:focus,
            .form-floating > .form-control:not(:placeholder-shown) {
                padding-top: 0.625rem;
                padding-bottom: 0.625rem;
            }

        .form-floating > label {
            color: #000000;
            font-weight: 500;
            padding-left: 1.25rem;
        }

        .form-floating textarea.form-control {
            min-height: 120px;
            resize: vertical;
        }

    .btn-add-movie {
        background: #9FCBC0;
        border: none;
        border-radius: 12px;
        padding: 1rem 2rem;
        font-size: 1.1rem;
        font-weight: 600;
        color: #000000;
        width: 100%;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(159, 203, 192, 0.3);
    }

        .btn-add-movie:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(159, 203, 192, 0.5);
            background: #8BC1B8;
            color: #000000;
        }

        .btn-add-movie:active {
            transform: translateY(0);
        }

    .alert-custom {
        background: rgba(248, 113, 113, 0.1);
        border: 1px solid rgba(248, 113, 113, 0.3);
        color: #dc2626;
        border-radius: 12px;
        padding: 1rem;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
    }

        .alert-custom i {
            margin-right: 0.5rem;
        }

    .alert-success-custom {
        background: rgba(34, 197, 94, 0.1);
        border: 1px solid rgba(34, 197, 94, 0.3);
        color: #059669;
        border-radius: 12px;
        padding: 1rem;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
    }

        .alert-success-custom i {
            margin-right: 0.5rem;
        }

    .cinema-icon {
        font-size: 3rem;
        color: #000000;
        text-align: center;
    }

    .section-title {
        font-size: 1.3rem;
        font-weight: 600;
        color: #000000;
        margin-bottom: 1.5rem;
        margin-top: 2rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #9FCBC0;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .section-title:first-of-type {
            margin-top: 0;
        }

    .checkbox-group {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
        margin-top: 1rem;
    }

    .checkbox-item {
        background: rgba(255, 255, 255, 0.9);
        border: 2px solid #9FCBC0;
        border-radius: 12px;
        padding: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

        .checkbox-item:hover {
            border-color: #000000;
            background: #F5F5F5;
            transform: translateY(-1px);
        }

        .checkbox-item.checked {
            border-color: #000000;
            background: #9FCBC0;
        }

        .checkbox-item input[type="checkbox"] {
            width: 18px;
            height: 18px;
            accent-color: #000000;
        }

        .checkbox-item label {
            cursor: pointer;
            font-weight: 500;
            color: #000000;
            margin: 0;
            flex: 1;
        }

        .checkbox-item.checked label {
            color: #000000;
            font-weight: 600;
        }

    .radio-group {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 1rem;
        margin-top: 1rem;
    }

    .radio-item {
        background: rgba(255, 255, 255, 0.9);
        border: 2px solid #9FCBC0;
        border-radius: 12px;
        padding: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

        .radio-item:hover {
            border-color: #000000;
            background: #F5F5F5;
            transform: translateY(-1px);
        }

        .radio-item.checked {
            border-color: #000000;
            background: #9FCBC0;
        }

        .radio-item input[type="radio"] {
            width: 18px;
            height: 18px;
            accent-color: #000000;
        }

        .radio-item label {
            cursor: pointer;
            font-weight: 500;
            color: #000000;
            margin: 0;
            flex: 1;
        }

        .radio-item.checked label {
            color: #000000;
            font-weight: 600;
        }

    .image-upload-container {
        position: relative;
        margin-bottom: 1.5rem;
    }

    .image-upload-wrapper {
        border: 2px dashed #9FCBC0;
        border-radius: 12px;
        padding: 2rem;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s ease;
        background: rgba(255, 255, 255, 0.9);
    }

        .image-upload-wrapper:hover {
            border-color: #000000;
            background: #F5F5F5;
        }

        .image-upload-wrapper.has-image {
            border-style: solid;
            border-color: #000000;
            background: #9FCBC0;
        }

    .image-upload-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
        color: black;
    }

    .image-upload-text {
        color: #000000;
        font-weight: 500;
        margin-bottom: 0.5rem;
    }

    .image-upload-subtext {
        color: #666666;
        font-size: 0.9rem;
    }

    .image-preview {
        max-height: 200px;
        border-radius: 8px;
        margin-top: 1rem;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    }

    .file-input-hidden {
        display: none;
    }

    /* Field labels styling */
    h6 {
        color: #000000 !important;
        font-weight: 600 !important;
    }

    /* Highlighted text in subtitle */
    .highlight-text {
        font-weight: 600;
    }

    /* Status select styling */
    .status-select {
        border: 2px solid #9FCBC0;
        border-radius: 12px;
        padding: 0.75rem;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: rgba(255, 255, 255, 0.9);
        color: #000000;
        width: 100%;
    }

        .status-select:focus {
            border-color: #000000;
            box-shadow: 0 0 0 0.2rem rgba(159, 203, 192, 0.25);
            background: rgba(255, 255, 255, 1);
        }
</style>

<div class="add-movie-container">
    <div class="add-movie-card">
        <div class="cinema-icon">
            <i class="fas fa-edit"></i>
        </div>

        <h1 class="add-movie-title">Thêm phim mới</h1>
        <p class="add-movie-subtitle">
            Vui lòng nhập đầy đủ thông tin phim để <br>
            <span style="background: black; -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; font-weight: 600;">thêm vào hệ thống quản lý</span>
        </p>

        @if (@TempData["Success"] != null)
        {
            <div id="alertSuccess" class="alert-success-custom text-center">
                <i class="fa-solid fa-check"></i> @TempData["Success"]
            </div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
        <div id="alertDanger" class="alert-custom text-center">
            <i class="fas fa-exclamation-triangle"></i>
            @Html.Raw(string.Join("<br/>", ViewData.ModelState.Values
                        .SelectMany(v => v.Errors)
                        .Select(e => e.ErrorMessage)))
        </div>
                }

        <form asp-area="Movie" asp-action="EditMovie" method="post" enctype="multipart/form-data" novalidate>
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.Id)

            <div class="section-title">
                <i class="fas fa-info-circle"></i>
                Thông tin cơ bản
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <h6 class="mb-3" style="color: #4a5568; font-weight: 600;">
                        Tựa phim
                    </h6>
                    <div class="form-floating">
                        <input asp-for="Title" class="form-control"
                               id="title" placeholder="Tựa phim" />
                    </div>
                </div>

                <div class="col-md-6">
                    <h6 class="mb-3" style="color: #4a5568; font-weight: 600;">
                        Link trailer
                    </h6>
                    <div class="form-floating">
                        <input asp-for="TrailerLink" class="form-control"
                               id="trailerLink" placeholder="Link trailer" />
                    </div>
                </div>

                <div class="col-md-12">
                    <h6 class="mb-3" style="color: #4a5568; font-weight: 600;">
                        Mô tả phim
                    </h6>
                    <div class="form-floating">
                        <textarea asp-for="Description" class="form-control"
                                  id="description" placeholder="Mô tả phim"></textarea>
                    </div>
                </div>

                <div class="col-md-6">
                    <h6 class="mb-3" style="color: #4a5568; font-weight: 600;">
                        Thời lượng (phút)
                    </h6>
                    <div class="form-floating">
                        <input asp-for="Duration" type="number" class="form-control"
                               id="duration" placeholder="Thời lượng" />
                    </div>
                </div>

                <div class="col-md-6">
                    <h6 class="mb-3" style="color: #4a5568; font-weight: 600;">
                        Ngày phát hành
                    </h6>
                    <div class="form-floating">
                        <input asp-for="ReleaseDate" type="date" class="form-control"
                               id="releaseDate" placeholder="Ngày phát hành" />
                    </div>
                </div>
            </div>

            <div class="section-title">
                <i class="fas fa-tags"></i>
                Phân loại và định dạng
            </div>

            <div class="mb-4">
                <h6 class="mb-3" style="color: #4a5568; font-weight: 600;">
                    <i class="fas fa-layer-group me-2"></i>Thể loại phim
                </h6>
                <div class="checkbox-group">
                    @foreach (var genre in allGenres)
                    {
                        <div class="checkbox-item @(selectedGenres.Contains(genre) ? "checked" : "")"
                             onclick="toggleCheckbox(this)">
                            <input class="form-check-input" type="checkbox" name="Genres"
                                   value="@genre" @(selectedGenres.Contains(genre) ? "checked" : "") />
                            <label>@genre</label>
                        </div>
                    }
                </div>
            </div>

            <div class="mb-4">
                <h6 class="mb-3" style="color: #4a5568; font-weight: 600;">
                    <i class="fas fa-certificate me-2"></i>Kiểm duyệt
                </h6>
                <div class="radio-group">
                    @{
                        var ratings = FilmHelper.RatingHelper.GetRatings();
                    }
                    @foreach (var rating in ratings)
                    {
                        <div class="radio-item @(Model!.RatingCode == rating.Key ? "checked" : "")"
                             onclick="toggleRadio(this, 'RatingCode')">
                            <input class="form-check-input" type="radio" name="RatingCode"
                                   value="@rating.Key" @(Model!.RatingCode == rating.Key ? "checked" : "") />
                            <label class="text-uppercase">@rating.Value</label>
                        </div>
                    }
                </div>
            </div>

            <div class="mb-4">
                <h6 class="mb-3" style="color: #4a5568; font-weight: 600;">
                    <i class="fas fa-desktop me-2"></i>Định dạng phim
                </h6>
                <div class="checkbox-group">
                    @foreach (var format in allFormats)
                    {
                        <div class="checkbox-item @(selectedFormats.Contains(format) ? "checked" : "")"
                             onclick="toggleCheckbox(this)">
                            <input class="form-check-input" type="checkbox" name="Format"
                                   value="@format" @(selectedFormats.Contains(format) ? "checked" : "")
                                   onclick="event.stopPropagation();" />
                            <label>@format</label>
                        </div>
                    }
                </div>
            </div>

            <div class="section-title">
                <i class="fas fa-users"></i>
                Thông tin sản xuất
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <h6 class="mb-3" style="color: #4a5568; font-weight: 600;">
                        Nhà sản xuất
                    </h6>
                    <div class="form-floating">
                        <input asp-for="ProductionCompany" class="form-control"
                               id="productionCompany" placeholder="Nhà sản xuất" />
                    </div>
                </div>

                <div class="col-md-6">
                    <h6 class="mb-3" style="color: #4a5568; font-weight: 600;">
                        Đạo diễn
                    </h6>
                    <div class="form-floating">
                        <input asp-for="Director" class="form-control"
                               id="director" placeholder="Đạo diễn" />
                    </div>
                </div>

                <div class="col-md-6">
                    <h6 class="mb-3" style="color: #4a5568; font-weight: 600;">
                        Diễn viên
                    </h6>
                    <div class="form-floating">
                        <textarea asp-for="CastText" class="form-control"
                                  id="castText" placeholder="Diễn viên"></textarea>
                    </div>
                </div>

                <div class="col-md-6">
                    <h6 class="mb-3" style="color: #4a5568; font-weight: 600;">
                        Phụ đề
                    </h6>
                    <div class="form-floating">
                        <input asp-for="Subtitle" class="form-control"
                               id="subtitle" placeholder="Phụ đề" />
                    </div>
                </div>

                <div class="col-md-6">
                    <h6 class="mb-3" style="color: #4a5568; font-weight: 600;">
                        Trạng thái phim
                    </h6>
                    <select asp-for="Status" class="status-select" required>
                        <option value="Active">Đang chiếu</option>
                        <option value="SoldOut">Hết vé</option>
                        <option value="Deleted">Đã xóa</option>
                    </select>
                </div>
            </div>

            <div class="section-title">
                <i class="fas fa-images"></i>
                Hình ảnh
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <div class="image-upload-container">
                        <h6 class="mb-3" style="color: #4a5568; font-weight: 600;">
                            <i class="fas fa-image me-2"></i>Ảnh bìa
                        </h6>
                        <div class="image-upload-wrapper @(string.IsNullOrEmpty(Model?.Image) ? "" : "has-image")"
                             onclick="document.getElementById('imageInput').click()">
                            <div class="image-upload-icon" style="color: black;">
                                <i class="fas fa-cloud-upload-alt"></i>
                            </div>
                            <div class="image-upload-text">Click để tải ảnh bìa</div>
                            <div class="image-upload-subtext">PNG, JPG, GIF up to 10MB</div>
                        </div>
                        <input asp-for="ImageFile" type="file" class="file-input-hidden"
                               id="imageInput" accept="image/*" onchange="previewImage(this, 'imagePreview')" />
                        <img id="imagePreview" class="image-preview"
                             src="@(string.IsNullOrEmpty(Model?.Image) ? "" : Url.Content(Model.Image))"
                             style="@(string.IsNullOrEmpty(Model?.Image) ? "display: none;" : "")" />
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="image-upload-container">
                        <h6 class="mb-3" style="color: #4a5568; font-weight: 600;">
                            <i class="fas fa-images me-2"></i>Ảnh carousel
                        </h6>
                        <div class="image-upload-wrapper @(string.IsNullOrEmpty(Model?.CarouselImage) ? "" : "has-image")"
                             onclick="document.getElementById('carouselImageInput').click()">
                            <div class="image-upload-icon">
                                <i class="fas fa-cloud-upload-alt"></i>
                            </div>
                            <div class="image-upload-text">Click để tải ảnh carousel</div>
                            <div class="image-upload-subtext">PNG, JPG, GIF up to 10MB</div>
                        </div>
                        <input asp-for="CarouselImageFile" type="file" class="file-input-hidden"
                               id="carouselImageInput" accept="image/*" onchange="previewImage(this, 'carouselImagePreview')" />
                        <img id="carouselImagePreview" class="image-preview"
                             src="@(string.IsNullOrEmpty(Model?.CarouselImage) ? "" : Url.Content(Model.CarouselImage))"
                             style="@(string.IsNullOrEmpty(Model?.CarouselImage) ? "display: none;" : "")" />
                    </div>
                </div>
            </div>

            @Html.HiddenFor(m => m.Image)
            @Html.HiddenFor(m => m.CarouselImage)

            <button type="submit" class="btn btn-add-movie mt-4">
                <i class="fas fa-plus me-2"></i>
                Thêm phim vào hệ thống
            </button>

            @* Preserve genres & formats if user unchecks *@
            @foreach (var genre in selectedGenres)
            {
                <input type="hidden" name="Genres" value="@genre" />
            }
            @foreach (var format in selectedFormats)
            {
                <input type="hidden" name="Format" value="@format" />
            }
        </form>
    </div>
</div>

<script>
    function toggleCheckbox(element) {
        // Tìm checkbox trong element
        const checkbox = element.querySelector('input[type="checkbox"]');

        // Kiểm tra xem checkbox có tồn tại không
        if (!checkbox) {
            console.error('Checkbox not found');
            return;
        }

        // Toggle trạng thái checked
        checkbox.checked = !checkbox.checked;

        // Cập nhật class cho styling
        updateCheckboxVisual(element, checkbox.checked);

        // Trigger change event để các event listener khác có thể phản ứng
        checkbox.dispatchEvent(new Event('change', { bubbles: true }));
    }

    function updateCheckboxVisual(element, isChecked) {
        if (isChecked) {
            element.classList.add('checked');
        } else {
            element.classList.remove('checked');
        }
    }

    // Thêm event listener cho checkbox để đồng bộ khi click trực tiếp vào checkbox
    document.addEventListener('DOMContentLoaded', function() {
        const checkboxes = document.querySelectorAll('.checkbox-item input[type="checkbox"]');

        checkboxes.forEach(checkbox => {
            checkbox.addEventListener('change', function(event) {
                // Ngăn việc bubble up để tránh trigger toggleCheckbox
                event.stopPropagation();

                // Cập nhật visual
                const parentElement = this.closest('.checkbox-item');
                updateCheckboxVisual(parentElement, this.checked);
            });

            // Ngăn việc click trên checkbox trigger toggleCheckbox của parent
            checkbox.addEventListener('click', function(event) {
                event.stopPropagation();
            });
        });
    });

    function toggleRadio(element, groupName) {
        // Remove checked class from all radio items in the group
        const radioItems = document.querySelectorAll(`input[name="${groupName}"]`);
        radioItems.forEach(radio => {
            radio.closest('.radio-item').classList.remove('checked');
        });

        // Add checked class to clicked element
        element.classList.add('checked');

        // Set the radio button value
        const radio = element.querySelector('input[type="radio"]');
        radio.checked = true;
    }

    function previewImage(input, previewId) {
        const preview = document.getElementById(previewId);
        const wrapper = input.closest('.image-upload-container').querySelector('.image-upload-wrapper');

        if (input.files && input.files[0]) {
            const reader = new FileReader();

            reader.onload = function(e) {
                preview.src = e.target.result;
                preview.style.display = 'block';
                wrapper.classList.add('has-image');
            }

            reader.readAsDataURL(input.files[0]);
        }
    }

    // Initialize checked states on page load
    document.addEventListener('DOMContentLoaded', function() {
        // Initialize checkboxes
        document.querySelectorAll('.checkbox-item input[type="checkbox"]:checked').forEach(checkbox => {
            checkbox.closest('.checkbox-item').classList.add('checked');
        });

        // Initialize radio buttons
        document.querySelectorAll('.radio-item input[type="radio"]:checked').forEach(radio => {
            radio.closest('.radio-item').classList.add('checked');
        });

        // Initialize image previews
        const imagePreview = document.getElementById('imagePreview');
        const carouselImagePreview = document.getElementById('carouselImagePreview');

        if (imagePreview.src && imagePreview.src !== window.location.href) {
            document.querySelector('#imageInput').closest('.image-upload-container').querySelector('.image-upload-wrapper').classList.add('has-image');
        }

        if (carouselImagePreview.src && carouselImagePreview.src !== window.location.href) {
            document.querySelector('#carouselImageInput').closest('.image-upload-container').querySelector('.image-upload-wrapper').classList.add('has-image');
        }
    });

    // Form submission handler
    $(document).ready(function () {
        $("form").submit(function () {
            $("input[name='Genres']:not(:checked)").remove();
            $("input[name='Format']:not(:checked)").remove();
        });
    });

    // Auto-hide alerts
    document.addEventListener("DOMContentLoaded", function () {
        function fadeOutAndRemove(element) {
            setTimeout(() => {
                element.style.transition = "opacity 0.5s ease";
                element.style.opacity = "0";
                setTimeout(() => {
                    element.remove();
                }, 500);
            }, 3000);
        }

        const successAlert = document.getElementById("alertSuccess");
        const dangerAlert = document.getElementById("alertDanger");

        if (successAlert) {
            fadeOutAndRemove(successAlert);
        }

        if (dangerAlert) {
            fadeOutAndRemove(dangerAlert);
        }
    });
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/alerts.js"></script>
    <script src="~/js/preview.js"></script>
}