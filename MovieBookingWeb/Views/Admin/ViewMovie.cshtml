@model List<MovieBookingWeb.Models.Film>
@{
    ViewData["Title"] = "Trang quản trị";
    int currentPage = ViewBag.CurrentPage as int? ?? 1;
    int totalPages = ViewBag.TotalPages as int? ?? 1;
}

<div class="container">
    <div class="flex-grow-1" style="margin-top: 2rem;">
        <h2 class="text-center fw-bold mb-3">Danh sách phim</h2>

        @if (@TempData["Success"] != null)
        {
        <div id="alertSuccess" class="alert alert-success text-center custom-alert mt-2 mb-3" 
            style="width: 280px; margin: 0 auto; padding: 0.5rem 1rem; font-size: 0.9rem;">
                <i class="fa-solid fa-check" style="color: green;"></i> @TempData["Success"]
        </div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
        <div id="alertDanger" class="alert alert-danger text-center custom-alert mt-2 mb-3"
            style="width: 280px; margin: 0 auto; padding: 0.5rem 1rem; font-size: 0.9rem;">
                <i class="fa-solid fa-xmark" style="color: red;"></i> @Html.Raw(string.Join("<br/>", ViewData.ModelState.Values
                .SelectMany(v => v.Errors)
                .Select(e => e.ErrorMessage)))
        </div>
        }
        
        <a asp-controller="Admin" asp-action="AddMovie" class="btn btn-primary mb-3"><i class="fa-solid fa-plus"></i> Thêm phim mới</a>

        <table class="table table-bordered table-striped mx-auto">
            <thead class="thead-dark">
                <tr>
                    <th class="text-center" style="width: 3%;">ID</th>
                    <th class="text-center" style="width: 24%;">Tựa phim</th>
                    <th class="text-center" style="width: 22%;">Thể loại</th>
                    <th class="text-center" style="width: 13%;">Thời lượng (phút)</th>
                    <th class="text-center" style="width: 10%;">Khởi chiếu</th>
                    <th class="text-center" style="width: 10%;">Trạng thái</th>
                    <th class="text-center" style="width: 8%;">Tạo bởi</th>
                    <th class="text-center" style="width: 8%;">Sửa bởi</th>
                    <th class="text-center" style="width: 12%;">Tác vụ</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var film in Model)
                {
                    <tr>
                        <td class="align-middle text-center fw-bold">@film.Id</td>
                        <td class="align-middle fw-bold">@film.Title</td>
                        <td class="align-middle">@(film.Genres != null ? string.Join(", ", film.Genres) : "")</td>
                        <td class="align-middle text-center">@film.Duration</td>
                        <td class="align-middle text-center">@film.ReleaseDate?.ToString("dd/MM/yyyy")</td>
                        <td class="align-middle text-center">
                            @{
                                var statusDisplay = film.Status switch
                                {
                                    "Active" => "Đang chiếu",
                                    "SoldOut" => "Hết vé",
                                    "Deleted" => "Đã xóa",
                                    _ => "Không xác định"
                                };
                            }
                            @statusDisplay
                        </td>
                        <td class="align-middle text-center">@film.CreatedByUsername</td>
                        <td class="align-middle text-center">@film.EditedByUsername</td>
                        <td class="align-middle text-center">
                            <a asp-controller="Admin" asp-action="EditMovie" asp-route-id="@film.Id" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i> Sửa</a>
                            <form asp-controller="Admin" asp-action="DeleteMovie" asp-route-id="@film.Id" method="post" style="display:inline;" onsubmit="return confirm('Bạn có muốn xoá phim này không?');">
                                <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash-alt"></i> Xoá</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <nav>
            <ul class="pagination">
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" asp-action="ViewMovie" asp-route-page="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    </div>
</div>