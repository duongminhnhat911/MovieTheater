@model List<MovieBookingWeb.Models.UserDto>
@{
    ViewData["Title"] = "Quản lý người dùng";
    int currentPage = ViewBag.CurrentPage as int? ?? 1;
    int totalPages = ViewBag.TotalPages as int? ?? 1;
}

<div class="container">
    <div class="flex-grow-1" style="margin-top: 2rem;">
        <h2 class="text-center fw-bold mb-3">Danh sách thành viên</h2>
        
        @if (@TempData["Success"] != null)
        {
        <div id="alertSuccess" class="alert alert-success text-center custom-alert mt-2 mb-3" 
            style="width: 280px; margin: 0 auto; padding: 0.5rem 1rem; font-size: 0.9rem;">
                <i class="fa-solid fa-check" style="color: green;"></i> @TempData["Success"]
        </div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
        <div id="alertDanger" class="alert alert-danger text-center custom-alert mt-2 mb-3"
            style="width: 280px; margin: 0 auto; padding: 0.5rem 1rem; font-size: 0.9rem;">
                <i class="fa-solid fa-xmark" style="color: red;"></i> @Html.Raw(string.Join("<br/>", ViewData.ModelState.Values
                .SelectMany(v => v.Errors)
                .Select(e => e.ErrorMessage)))
        </div>
        }
        
        @if (!Model.Any())
        {
            <div class="alert alert-info text-center" style="width: 300px; margin: 0 auto;">
                Danh sách trống!
            </div>
        }
        else
        {
            <table class="table table-bordered table-striped mx-auto">
                <thead class="thead-dark">
                    <tr>
                        <th class="text-center" style="width: 3%;">ID</th>
                        <th class="text-center" style="width: 20%;">Tên đăng nhập</th>
                        <th class="text-center" style="width: 24%;">Họ và tên</th>
                        <th class="text-center" style="width: 20%;">Email</th>
                        <th class="text-center" style="width: 9%;">SĐT</th>
                        <th class="text-center" style="width: 9%;">Trạng thái</th>
                        <th class="text-center" style="width: 15%;">Tác vụ</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="align-middle text-center fw-bold">@user.Id</td>
                            <td class="align-middle">@user.Username</td>
                            <td class="align-middle">@user.FullName</td>
                            <td class="align-middle">@user.Email</td>
                            <td class="align-middle">@user.PhoneNumber</td>
                            <td class="align-middle text-center">
                            @if (user.IsLocked)
                            {
                                <span class="text-danger fw-bold">Đã khóa</span>
                            }
                            else
                            {
                                <span class="text-success fw-bold">Hoạt động</span>
                            }
                            </td>
                            <td class="align-middle text-center">
                                <form asp-controller="Admin" asp-action="DeleteAccount" asp-route-id="@user.Id" method="post" style="display:inline;" onsubmit="return confirm('Bạn có muốn xoá người dùng này không?');">
                                    <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash-alt"></i> Xoá</button>
                                </form>
                                <form asp-controller="Admin" asp-action="ToggleLockAccount" asp-route-id="@user.Id" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc muốn @(user.IsLocked ? "mở khóa" : "khóa") tài khoản này không?');">
                                    <button type="submit" class="btn btn-sm @(user.IsLocked ? "btn-success" : "btn-secondary")">
                                        <i class="fa-solid @(user.IsLocked ? "fa-lock-open" : "fa-lock")"></i> @(user.IsLocked ? "Mở khóa" : "Khóa")
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <nav>
            <ul class="pagination">
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" asp-action="ViewAccounts" asp-route-pageNumber="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
        }
    </div>
</div>
