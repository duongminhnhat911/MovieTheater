@model MovieBookingWeb.Models.RegisterViewModel

@{
    ViewBag.Title = "Đăng ký";
}

<div class="container" style="max-width: 600px; margin-top: 2rem;">
    <h2 class="text-center fw-bold mb-3">Đăng ký tài khoản</h2>
    <div class="text-center mb-3">
        <p class="mb-1">Để có thể sử dụng các dịch vụ của chúng tôi, bạn phải có tài khoản</p>
        <p class="mb-0 fw-bold">Đã có tài khoản? <a href="/Account/Login">Đăng nhập</a></p>
    </div>

    @* @if (!ViewData.ModelState.IsValid) *@
    @* { *@
    @*     <div id="alertDanger" class="alert alert-danger text-center custom-alert mb-3" *@
    @*         style="width: 270px; margin: 0 auto; padding: 0.5rem 1rem; font-size: 0.9rem; opacity: 1;"> *@
    @*         ❌ @Html.Raw(string.Join("<br/>", ViewData.ModelState.Values *@
    @*         .SelectMany(v => v.Errors) *@
    @*         .Select(e => e.ErrorMessage))) *@
    @*     </div> *@
    @* } *@

    <form asp-action="Register" method="post" novalidate>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label fw-bold">Tên tài khoản</label>
                <input asp-for="Username" class="form-control" placeholder="Nhập tên tài khoản" />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold">Họ và tên</label>
                <input asp-for="FullName" class="form-control" placeholder="Nhập họ và tên" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold">Mật khẩu</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Nhập mật khẩu" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold">Xác nhận mật khẩu</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Xác nhận mật khẩu" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>
            <div class="col-md-12">
                <label class="form-label fw-bold">Ngày sinh</label>
                <input asp-for="BirthDate" type="date" class="form-control" />
                <span asp-validation-for="BirthDate" class="text-danger"></span>
            </div>
            <div class="col-md-12">
                <label class="form-label fw-bold">Giới tính</label><br />
                <div class="form-check">
                    <input asp-for="Gender" class="form-check-input" type="radio" value="Nam" />
                    <label class="form-check-label">Nam</label>
                </div>
                <div class="form-check">
                    <input asp-for="Gender" class="form-check-input" type="radio" value="Nữ" />
                    <label class="form-check-label">Nữ</label>
                </div>
                <div class="form-check">
                    <input asp-for="Gender" class="form-check-input" type="radio" value="Khác" />
                    <label class="form-check-label">Khác</label>
                </div>
                <span asp-validation-for="Gender" class="text-danger"></span>
            </div>
            <div class="col-md-12">
                <label class="form-label fw-bold">Email</label>
                <input asp-for="Email" type="email" class="form-control" placeholder="Nhập email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="col-md-12">
                <label class="form-label fw-bold">Số CCCD</label>
                <input asp-for="IdCard" class="form-control" placeholder="Nhập số căn cước công dân" />
                <span asp-validation-for="IdCard" class="text-danger"></span>
            </div>
            <div class="col-md-12">
                <label class="form-label fw-bold">Số điện thoại</label>
                <input asp-for="PhoneNumber" class="form-control" placeholder="Nhập số điện thoại" />
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>
            <div class="col-md-12">
                <label class="form-label fw-bold">Địa chỉ nhà</label>
                <input asp-for="Address" class="form-control" rows="3" placeholder="Nhập địa chỉ"></input>
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>
        </div>
        <div class="mt-4 d-grid">
            <button type="submit" class="btn btn-dark btn-lg">Tạo tài khoản</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


