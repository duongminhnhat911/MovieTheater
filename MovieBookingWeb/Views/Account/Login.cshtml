@model MovieBookingWeb.Models.LoginViewModel

@{
    ViewBag.Title = "Đăng nhập";
}

<div class="container" style="max-width: 600px; margin-top: 2rem;">
    <h2 class="text-center fw-bold mb-3">Đăng nhập</h2>
    <div class="text-center mb-3">
        <p class="mb-1">Đăng nhập vào tài khoản của bạn để tiếp tục sử dụng dịch vụ</p>
        <p class="fw-bold">Chưa có tài khoản? <a href="/Account/Register">Tạo tài khoản</a></p>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div id="alertDanger" class="alert alert-danger text-center custom-alert mb-3"
             style="width: 380px; margin: 0 auto; padding: 0.5rem 1rem; font-size: 0.9rem;">
            ❌ @Html.Raw(string.Join("<br/>", ViewData.ModelState.Values
                   .SelectMany(v => v.Errors)
                   .Select(e => e.ErrorMessage)))
        </div>
    }

    <form method="post" asp-action="Login">
        <div class="mb-3">
            <label class="form-label fw-bold">E-mail/Tên tài khoản</label>
            <input asp-for="UsernameOrEmail" class="form-control" placeholder="Nhập email hoặc tên tài khoản" />
            <span class="text-danger" asp-validation-for="UsernameOrEmail"></span>
        </div>
        <div class="mb-3">
            <label class="form-label fw-bold">Mật khẩu</label>
            <input asp-for="Password" type="password" class="form-control" placeholder="Nhập mật khẩu" />
            <span class="text-danger" asp-validation-for="Password"></span>
        </div>
        <div class="mt-4 d-grid">
            <button type="submit" class="btn btn-dark btn-lg">Đăng nhập</button>
        </div>
    </form>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
