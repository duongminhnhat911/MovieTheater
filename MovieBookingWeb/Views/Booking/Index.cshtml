@model MovieBookingWeb.Models.BookingViewModel

@{
    ViewData["Title"] = "Đặt vé - " + Model.Title;
}

<div class="container-sm">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="web-movie-box position-relative">
                <img src="@Model.Image" class="img-fluid rounded" alt="@Model.Title" />
                @if (Model.Format != null && Model.Format.Any())
                {
                    <div class="d-flex position-absolute top-0 start-0">
                        @foreach (var fmt in Model.Format)
                        {
                            <div class="type-movie">
                                <span class="txt">@fmt</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="col-md-8">
            <div class="movie-section">
                <div class="movie-info">
                    <h1 class="fw-bold">@Model.Title</h1>
                    <ul>
                        <li><i class="fas fa-film me-2"></i>@(Model.Genres != null ? string.Join(", ", Model.Genres) : "")</li>
                        <li><i class="far fa-clock me-2"></i>@Model.Duration phút</li>
                        <li style="text-transform: uppercase; font-weight: bold;">
                            <i class="fas fa-certificate me-2"></i>@Model.Rating
                        </li>
                        <li><i class="fas fa-language me-2"></i>@Model.Subtitle</li>
                    </ul>
                </div>

                <div class="movie-desc">
                    <h3 class="fw-bold">Thông tin phim</h3>
                    <ul>
                        <li><strong>Nhà sản xuất:</strong> @Model.ProductionCompany</li>
                        <li><strong>Đạo diễn:</strong> @Model.Director</li>
                        <li><strong>Diễn viên:</strong> @Model.Cast</li>
                        <li><strong>Khởi chiếu:</strong> @Model.ReleaseDate?.ToString("dd/MM/yyyy")</li>
                    </ul>
                </div>

                <div class="movie-content">
                    <h3 class="fw-bold">Nội dung</h3>
                        <p>@Model.Description</p>
                </div>
            </div>
        </div>
        <hr class="section-divider"/>
    </div>
        
    <div class="movie-schedule mb-5">
        <h3 class="mb-3 fw-bold">Lịch chiếu phim</h3>
            <input type="hidden" id="SelectedDate" name="SelectedDate" />
            <input type="hidden" id="SelectedTime" name="SelectedTime" />
            <input type="hidden" id="SelectedRoom" name="SelectedRoom" />

            <div class="slider-dates mb-3">
                @if (Model.AvailableDates != null && Model.AvailableDates.Any())
                {
                    foreach (var date in Model.AvailableDates.OrderBy(d => d))
                    {
                        <button type="button" class="btn btn-outline-primary me-2 date-btn" data-date="@date">
                            @DateTime.Parse(date).ToString("dd/MM/yyyy")
                        </button>
                    }
                }
                else
                {
                    <p class="text-muted">Không có lịch chiếu.</p>
                }
            </div>

        <form method="post" asp-controller="Booking" asp-action="Confirm">            
            <div id="time-section" class="mb-3 d-none">
                <h6>Chọn giờ chiếu:</h6>
                <div id="time-list" class="d-flex flex-wrap gap-2"></div>
            </div>

            <div class="mb-3 d-none" id="seat-section">
                <div class="d-flex justify-content-center align-items-center mb-2">
                    <div class="text-center mb-2">
                        <strong>Chọn ghế - 
                            <span id="selected-room-name" class="text-primary fw-bold"></span>
                        </strong>
                    </div>
                    <div id="room-display" class="d-flex flex-wrap justify-content-center"></div>
                </div>

            <div id="screen-seat-wrapper" style="max-width: 1200px; margin: 0 auto;">
                <div class="d-flex justify-content-center mb-3" id="screen-image">
                    <img src="/images/screen.png" alt="Màn hình chiếu" id="screen-img">
                </div>
                <div id="seatContainer"></div>
            </div>

            <input type="hidden" name="SelectedSeats" id="SelectedSeats" />

            <div id="booking-summary">
                <div class="container-fluid">
                    <div class="d-flex justify-content-between align-items-center flex-wrap">
                        <div class="fw-bold">@Model.Title</div>

                        <div class="text-center">
                            <span class="me-3">
                                <strong>Tổng tiền: </strong>
                                <span id="totalAmount">0</span> VNĐ
                            </span>
                            <span>
                                <strong>Giữ ghế trong: </strong>
                                <span id="countdown">05:00</span>
                            </span>
                        </div>

                        <button type="submit" class="btn btn-success fw-bold" id="submit-btn">
                            <i class="fas fa-ticket-alt"></i> Đặt vé
                        </button>
                    </div>
                </div>
            </div>   
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/booking.js"></script>
    <script>
        const showtimes = @Html.Raw(Json.Serialize(Model.Showtimes ?? new List<Showtime>()));
        window.roomByDateTime = @Html.Raw(Json.Serialize(Model.RoomByDateTime ?? new Dictionary<string, Dictionary<string, string>>()));
        window.bookedSeats = @Html.Raw(Json.Serialize(Model.BookedSeats ?? new Dictionary<string, Dictionary<string, List<string>>>()));
        window.roomLayouts = @Html.Raw(Json.Serialize(Model.RoomLayouts ?? new Dictionary<string, Room>()));
    </script>
}

@section Styles {
    <link rel="stylesheet" href="~/css/booking.css" />
    <link rel="stylesheet" href="~/css/label.css" />
}



